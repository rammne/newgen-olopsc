---
import { getSanityImageUrl } from "../../lib/utils/sanity";
import { getDepartmentUrl } from "../../lib/utils/departmentUrls";

interface Props {
  academicDepartments: {
    title?: string;
    subtitle?: string;
    departments?: Array<{
      _id?: string;
      title?: string;
      slug?: {
        current?: string;
      };
      departmentType?:
        | "preschool"
        | "gradeSchool"
        | "juniorHigh"
        | "seniorHigh"
        | "college";
      hero?: {
        backgroundImage?: {
          asset?: {
            url?: string;
          };
          alt?: string;
        };
      };
    }>;
  };
}

const { academicDepartments } = Astro.props;

const departmentData: Record<string, { title: string; description: string }> = {
  preschool: {
    title: "Preschool",
    description: "Play-based early childhood education fostering foundational learning, curiosity, and Christian values.",
  },
  gradeSchool: {
    title: "Grade School",
    description: "DepEd-accredited primary education focused on core academic competencies and holistic character development.",
  },
  juniorHigh: {
    title: "Junior High School",
    description: "Rigorous, tech-integrated DepEd curriculum preparing students in Marikina for advanced critical thinking.",
  },
  seniorHigh: {
    title: "Senior High School (SHS)",
    description: "Academic Track Clusters and TechPro Track Clusters perfectly aligned with our College degree pipelines.",
  },
  college: {
    title: "College Degree Programs",
    description: "CHED-recognized bachelor's degrees equipping future professionals with industry-ready skills for the global workforce.",
  },
};

const defaultImage = "https://images.unsplash.com/photo-1523050854058-8df90110c9f1?q=80&w=800&auto=format&fit=crop";

---

{
  academicDepartments &&
    academicDepartments.departments &&
    academicDepartments.departments.length > 0 && (
      <section id="academic-departments" class="bg-slate-50 py-20">
        <!-- Header Container -->
        <div class="container mx-auto px-6 max-w-7xl text-center mb-16">
          <h2 class="text-4xl md:text-5xl font-black text-blue-950 mb-4 tracking-tight">
            A Pathway for Every Learner
          </h2>
          <p class="text-lg text-slate-600 max-w-2xl mx-auto">
            Excellence at every stage of growth, from foundational learning to professional excellence.
          </p>
        </div>

        <!-- The Grid Layout -->
        <div class="container mx-auto px-4 lg:px-6 max-w-[1600px]">
          <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-6 lg:gap-6 justify-center">
            {academicDepartments.departments.map((dept) => {
              const imageUrl = dept.hero?.backgroundImage ? getSanityImageUrl(dept.hero.backgroundImage, { width: 800, height: 600, fit: "crop" }) : defaultImage;
              const href = dept.departmentType ? getDepartmentUrl(dept.departmentType) : `/${dept.slug?.current || ""}`;
              const deptData = departmentData[dept.departmentType || ""] || { title: dept.title, description: "" };
              const displayTitle = deptData.title || dept.title;
              const overview = deptData.description;
              
              return (
                <a 
                  href={href}
                  class="group relative overflow-hidden rounded-2xl shadow-lg h-[380px] cursor-pointer block bg-blue-950"
                >
                  <!-- Image Layer -->
                  <img 
                    src={imageUrl} 
                    alt={dept.title || "Department Image"} 
                    loading="lazy"
                    class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-110 z-0" 
                  />
                  
                  <!-- Gradient Overlay -->
                  <div class="absolute inset-0 bg-gradient-to-t from-blue-950 via-blue-950/60 to-transparent opacity-80 group-hover:opacity-95 transition-opacity duration-500 z-10"></div>
                  
                  <!-- Text Payload Layer (Hover Reveal) -->
                  <div class="absolute inset-0 z-20 p-8 flex flex-col justify-end">
                    <h3 class="text-2xl font-bold text-white mb-2 translate-y-0 lg:translate-y-8 group-hover:translate-y-0 transition-transform duration-500">
                      {displayTitle}
                    </h3>
                    <p class="h-[80px] text-slate-300 text-sm leading-relaxed opacity-100 lg:opacity-0 group-hover:opacity-100 transition-opacity duration-500 delay-100">
                      {overview}
                    </p>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      </section>
    )
}
