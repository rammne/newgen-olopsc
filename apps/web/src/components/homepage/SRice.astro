---
import {getSanityImageUrl} from '../../lib/utils/sanity'
import iconS from '../../assets/srice-icons/spirituality.webp';
import iconR from '../../assets/srice-icons/respect-and-responsibility.webp';
import iconI from '../../assets/srice-icons/integrity.webp';
import iconC from '../../assets/srice-icons/caring-culture.webp';
import iconE from '../../assets/srice-icons/excellence.webp';

interface Props {
  sRice?: {
    title?: string
    subtitle?: string
    items?: Array<{
      letter?: string
      title?: string
      description?: string
      image?: {
        asset?: {
          url?: string
        }
        alt?: string
      }
    }>
  }
}

const {sRice} = Astro.props

const items = sRice?.items || [];
// Fallback default image in case one is missing
const defaultImage = items.length > 0 && items[0].image ? getSanityImageUrl(items[0].image, {width: 800, height: 800, fit: 'crop'}) : "https://images.unsplash.com/photo-1562774053-701939374585?q=80&w=800&auto=format&fit=crop";

const iconMap: Record<string, string> = {
  'S': iconS.src,
  'R': iconR.src,
  'I': iconI.src,
  'C': iconC.src,
  'E': iconE.src,
};
---

{items.length > 0 && (
<section class="relative bg-blue-950 py-16 md:py-24 overflow-hidden">
  
  <div class="container mx-auto px-4 lg:px-6 max-w-[1600px] relative z-10">    
    <!-- Section Header -->
    <div class="text-center mb-16">
      <div class="text-yellow-400 font-bold tracking-widest uppercase text-sm mb-3">
        {sRice?.subtitle || "The S-RICE Framework"}
      </div>
      <h2 class="text-3xl md:text-5xl font-black text-white tracking-tight">
        {sRice?.title || "Our Core Values"}
      </h2>
    </div>

    <!-- The Responsive Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-6 lg:gap-8 justify-center">
      
      {items.map((val) => {
        const letter = val.letter?.toUpperCase() || 'S';
        const iconSrc = iconMap[letter] || iconS.src;
        const imageUrl = val.image ? getSanityImageUrl(val.image, {width: 800, height: 800, fit: 'crop'}) : defaultImage;
        
        return (
          <div 
            class="relative rounded-2xl overflow-hidden shadow-2xl flex flex-col justify-start p-5 xl:p-8 h-full group border border-blue-900 hover:border-yellow-400 transition-colors cursor-default bg-blue-950"
          >
            <!-- Background Image -->
            <img 
              src={imageUrl} 
              alt={`${val.title || "Core Value"} - OLOPSC College and School in Marikina, Metro Manila`} 
              loading="lazy"
              class="absolute inset-0 w-full h-full object-cover z-0 transition-transform duration-700 lg:group-hover:scale-105 opacity-20 lg:opacity-100" 
            />
            
            <!-- Contrast Overlay (Desktop only since mobile uses image opacity) -->
            <div class="hidden lg:block absolute inset-0 bg-blue-950/80 group-hover:bg-blue-950/70 transition-colors duration-500 z-10"></div>
            
            <!-- Content Wrapper -->
            <div class="relative z-20 flex flex-col gap-3 lg:gap-4 h-full justify-start mt-2">
              
              <!-- Icon Container -->
              <div class="bg-white rounded-2xl w-20 h-20 xl:w-24 xl:h-24 p-3 shadow-lg flex items-center justify-center transform transition-transform duration-500 group-hover:scale-110 mb-2">
                <img 
                  src={iconSrc} 
                  alt={`${val.title || "Core Value"} Icon`} 
                  loading="lazy"
                  class="w-full h-full object-contain"
                />
              </div>
              
              <!-- Title -->
              <h3 class="font-black lg:font-bold text-white tracking-tight lg:tracking-normal text-xl xl:text-2xl mb-0 lg:mb-2 flex items-start gap-3">
                <!-- The Letter -->
                <span class="bg-yellow-400 text-blue-950 font-black flex items-center justify-center rounded-full w-9 h-9 xl:w-10 xl:h-10 text-lg xl:text-xl flex-shrink-0 shadow-lg mt-0.5">
                  {val.letter}
                </span>
                <span class="break-words leading-tight">
                  {val.title}
                </span>
              </h3>
              
              <!-- Body Text -->
              <p class="text-slate-200 text-sm md:text-base xl:text-base leading-relaxed">
                {val.description}
              </p>
            </div>
          </div>
        );
      })}

    </div>
  </div>
</section>
)}
