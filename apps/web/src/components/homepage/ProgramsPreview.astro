---
import { getSanityImageUrl } from "../../lib/utils/sanity";
import CtaButton from "../common/CtaButton.astro";

interface Props {
  programsPreview?: {
    title?: string;
    subtitle?: string;
    programs?: Array<{
      _id?: string;
      title?: string;
      shortTitle?: string;
      slug?: {
        current?: string;
      };
      cardThumbnail?: {
        asset?: {
          url?: string;
        };
        alt?: string;
      };
      hero?: {
        backgroundImage?: {
          asset?: {
            _id?: string;
            url?: string;
            metadata?: {
              dimensions?: {
                width?: number;
                height?: number;
              };
            };
          };
          alt?: string;
        };
      };
      overview?: string;
    }>;
    cta?: {
      text?: string;
      link?: any;
      style?: string;
      openInNewTab?: boolean;
    };
  };
  thumbnails?: any;
}

const { programsPreview } = Astro.props;

// Fallback Data
const fallbackSubtitle = "CHED-recognized bachelor's degree programs designed for global industry standards.";
const fallbackPrograms = [
  {
    title: "Computer Science & Technology",
    shortTitle: "BSCS & ACT",
    overview: "Outcome-based curriculum covering software engineering, full-stack development, and data structures.",
    slug: { current: "computing-studies" },
    imageUrl: "https://images.unsplash.com/photo-1517694712202-14dd9538aa97?q=80&w=800&auto=format&fit=crop"
  },
  {
    title: "Hospitality Management",
    shortTitle: "BSHM",
    overview: "Industry-standard training in culinary arts, hotel operations, and global hospitality leadership.",
    slug: { current: "hospitality-management" },
    imageUrl: "https://images.unsplash.com/photo-1556745753-b2904692b3cd?q=80&w=800&auto=format&fit=crop"
  },
  {
    title: "Tourism Management",
    shortTitle: "BSTM",
    overview: "Comprehensive preparation for global travel, tour operations, and sustainable destination management.",
    slug: { current: "tourism-management" },
    imageUrl: "https://images.unsplash.com/photo-1436491865332-7a61a109cc05?q=80&w=800&auto=format&fit=crop"
  },
  {
    title: "Business & Entrepreneurship",
    shortTitle: "BSBA",
    overview: "Equipping future business leaders with modern marketing, financial management, and corporate strategy skills.",
    slug: { current: "business-administration-and-entrepreneurship" },
    imageUrl: "https://images.unsplash.com/photo-1552664730-d307ca884978?q=80&w=800&auto=format&fit=crop"
  },
  {
    title: "Education & Liberal Arts",
    shortTitle: "BEEd, BSEd",
    overview: "Shaping future educators with DepEd-aligned methodologies for Elementary and Secondary instruction.",
    slug: { current: "education-and-liberal-arts" },
    imageUrl: "https://images.unsplash.com/photo-1427504494785-319ce8372379?q=80&w=800&auto=format&fit=crop"
  },
  {
    title: "Psychology",
    shortTitle: "BSP",
    overview: "Scientific study of human behavior, preparing graduates for clinical, industrial, and educational roles.",
    slug: { current: "psychology" },
    imageUrl: "https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?q=80&w=800&auto=format&fit=crop"
  }
];

// Determine final data
const title = programsPreview?.title || "Future-Ready Degrees";
const subtitle = fallbackSubtitle;

// Map CMS programs or use fallbacks
const displayPrograms = (programsPreview?.programs && programsPreview.programs.length > 0) 
  ? programsPreview.programs.map((p, index) => {
      const slugValue = p.slug?.current || fallbackPrograms[index]?.slug?.current || "#";
      const singletonThumbData = Astro.props.thumbnails?.[slugValue]?.cardThumbnail;
      const singletonThumbUrl = singletonThumbData?.asset?.url ? getSanityImageUrl(singletonThumbData, { width: 800, height: 600, fit: "crop" }) : null;
      
      return {
        title: p.title || fallbackPrograms[index]?.title || "Program",
        shortTitle: p.shortTitle || fallbackPrograms[index]?.shortTitle || "",
        overview: fallbackPrograms[index]?.overview || p.overview || "",
        slug: { current: slugValue },
        imageUrl: singletonThumbUrl || p.cardThumbnail?.asset?.url || (p.hero?.backgroundImage ? getSanityImageUrl(p.hero.backgroundImage, { width: 800, height: 600, fit: "crop" }) : fallbackPrograms[index]?.imageUrl)
      }
    })
  : fallbackPrograms;

const ctaText = programsPreview?.cta?.text || "View All College Programs";
const ctaLink = typeof programsPreview?.cta?.link === 'string' ? programsPreview.cta.link : "/college-programs";
---

<section class="bg-slate-50 py-20">
  <!-- Header Container -->
  <div class="container mx-auto px-6 max-w-7xl text-center mb-16">
    <h2 class="text-4xl md:text-5xl font-black text-blue-950 mb-4 tracking-tight">
      {title}
    </h2>
    <p class="text-lg text-slate-600 max-w-2xl mx-auto">
      {subtitle}
    </p>
  </div>

  <!-- The Grid Layout -->
  <div class="container mx-auto px-6 max-w-7xl">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {displayPrograms.map((program) => (
        <a 
          href={program.slug.current === "#" ? "#" : `/college/${program.slug.current}`}
          class="group relative overflow-hidden rounded-2xl shadow-lg h-[380px] cursor-pointer block bg-blue-950"
        >
          <!-- Image Layer -->
          <img 
            src={program.imageUrl} 
            alt={program.title} 
            loading="lazy"
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-110 z-0" 
          />
          
          <!-- Gradient Overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-blue-950 via-blue-950/60 to-transparent opacity-80 group-hover:opacity-95 transition-opacity duration-500 z-10"></div>
          
          <!-- Text Payload Layer (Hover Reveal) -->
          <div class="absolute inset-0 z-20 p-8 flex flex-col justify-end">
            <h3 class="text-2xl font-bold text-white mb-2 translate-y-0 lg:translate-y-8 group-hover:translate-y-0 transition-transform duration-500">
              {program.title}
            </h3>
            <p class="text-slate-300 text-sm leading-relaxed opacity-100 lg:opacity-0 group-hover:opacity-100 transition-opacity duration-500 delay-100">
              {program.overview}
            </p>
          </div>
          
          <!-- Acronym Tag -->
          {program.shortTitle && (
            <div class="absolute top-6 right-6 bg-yellow-400 text-blue-950 text-xs font-black px-3 py-1 rounded-full uppercase tracking-wider z-20">
              {program.shortTitle}
            </div>
          )}
        </a>
      ))}
    </div>

    <!-- Global CTA -->
    {programsPreview?.cta ? (
      <div class="text-center mt-12">
        <CtaButton cta={programsPreview.cta} />
      </div>
    ) : (
      <div class="text-center mt-12">
        <a 
          href={ctaLink}
          class="inline-block bg-yellow-400 hover:bg-yellow-500 text-blue-950 font-extrabold py-4 px-10 rounded transition-transform active:scale-95"
        >
          {ctaText}
        </a>
      </div>
    )}
  </div>
</section>
