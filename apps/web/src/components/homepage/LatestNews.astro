---
import { getSanityImageUrl } from "../../lib/utils/sanity";

interface Props {
  latestNews?: any;
  newsArticles?: Array<any>;
}

const { latestNews, newsArticles } = Astro.props;

const displayArticles = (newsArticles || []).map(a => {
  const dateFormatted = a.publishedAt ? new Date(a.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : a.date;
  const imageUrl = a.featuredImage?.asset?.url 
    ? getSanityImageUrl(a.featuredImage, { width: 1200, height: 800, fit: "crop" }) 
    : (a.image?.asset?.url ? getSanityImageUrl(a.image, { width: 1200, height: 800, fit: "crop" }) : "");
  
  return {
    title: a.title || "Untitled Article",
    category: a.academicDepartment?.title || a.category || "News",
    date: dateFormatted || "",
    excerpt: a.excerpt || "",
    image: imageUrl,
    slug: a.slug || { current: "#" }
  };
});

const featuredArticle = displayArticles[0];
const recentArticles = displayArticles.slice(1, 4);
---

<section class="bg-surface py-20">
  <div class="container mx-auto px-6 max-w-7xl flex flex-col md:flex-row md:items-end justify-between mb-12 gap-6">
    <div class="max-w-2xl">
      <h2 class="text-4xl md:text-5xl font-black text-primary mb-3 tracking-tight">
        News & Updates
      </h2>
      <p class="text-lg text-muted max-w-xl">
        Stay informed with the latest announcements, student achievements, and upcoming events at our Marikina campus.
      </p>
    </div>
    
    <div>
      <a href="/news" class="text-primary font-bold hover:text-accent transition-colors flex items-center gap-2">
        View All News
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>
  </div>

  <div class="container mx-auto px-6 max-w-7xl">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-12">
      
      <!-- The Featured Article (Left Side) -->
      {featuredArticle && (
        <div class="lg:col-span-7">
          <a href={`/news/${featuredArticle.slug.current}`} class="group block relative cursor-pointer">
            <div class="w-full h-[400px] rounded-2xl overflow-hidden shadow-sm mb-6">
              <img 
                src={featuredArticle.image} 
                alt={featuredArticle.title}
                loading="lazy"
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              />
            </div>
            
            <div class="flex items-center gap-3 mb-3 text-sm">
              <span class="bg-accent text-primary px-3 py-1 rounded-full font-bold uppercase tracking-wider text-xs">
                {featuredArticle.category}
              </span>
              <span class="text-muted">
                {featuredArticle.date}
              </span>
            </div>
            
            <h3 class="text-3xl font-bold text-primary mb-3 group-hover:text-accent transition-colors">
              {featuredArticle.title}
            </h3>
            
            {featuredArticle.excerpt && (
              <p class="text-muted text-base leading-relaxed line-clamp-3">
                {featuredArticle.excerpt}
              </p>
            )}
          </a>
        </div>
      )}

      <!-- The Recent Articles Stack (Right Side) -->
      {recentArticles.length > 0 && (
        <div class="lg:col-span-5 flex flex-col gap-8">
          {recentArticles.map((article) => (
            <a href={`/news/${article.slug.current}`} class="group flex items-start gap-6 cursor-pointer">
              <div class="w-32 h-32 shrink-0 rounded-xl overflow-hidden shadow-sm">
                <img 
                  src={article.image} 
                  alt={article.title}
                  loading="lazy"
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                />
              </div>
              
              <div class="flex flex-col justify-center h-full">
                <span class="text-accent font-bold uppercase text-xs tracking-wider mb-1">
                  {article.category}
                </span>
                <span class="text-muted text-xs mb-2">
                  {article.date}
                </span>
                
                <h4 class="text-lg font-bold text-primary leading-snug group-hover:text-accent transition-colors line-clamp-3">
                  {article.title}
                </h4>
              </div>
            </a>
          ))}
        </div>
      )}

    </div>
  </div>
</section>
