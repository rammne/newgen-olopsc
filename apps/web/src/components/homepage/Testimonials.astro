---
import { getSanityImageUrl } from "../../lib/utils/sanity";

interface Props {
  testimonials?: {
    title?: string;
    subtitle?: string;
    testimonials?: Array<{
      quote?: string;
      author?: {
        name?: string;
        role?: string;
        image?: {
          asset?: {
            url?: string;
          };
          alt?: string;
        };
        company?: string;
      };
      rating?: number;
    }>;
  };
}

const { testimonials } = Astro.props;

const fallbackSubtitle = "Hear from our graduates and parents about their journey of growth, character-building, and academic excellence.";

const fallbackTestimonials = [
  {
    quote: "OLOPSC didn't just prepare me for my career; it taught me the value of integrity and hard work. The caring culture is real—I always felt supported by my professors.",
    name: "Juan Dela Cruz, CPA",
    role: "Alumni - Class of 2018",
    image: "https://images.unsplash.com/photo-1500648767791-00dcc994a43e?q=80&w=800&auto=format&fit=crop",
    rating: 5
  },
  {
    quote: "The caring environment at OLOPSC allowed me to discover talents I didn't know I had. The holistic approach to education truly shapes you as a person.",
    name: "Miguel R.",
    role: "Alumni",
    image: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?q=80&w=800&auto=format&fit=crop",
    rating: 5
  },
  {
    quote: "I have peace of mind knowing my daughter is in a school that prioritizes moral values just as much as academic grades. The faculty is exceptional.",
    name: "Mrs. Santos",
    role: "Parent",
    image: "https://images.unsplash.com/photo-1438761681033-6461ffad8d80?q=80&w=800&auto=format&fit=crop",
    rating: 5
  }
];

const displaySubtitle = testimonials?.subtitle || fallbackSubtitle;
const displayTitle = testimonials?.title || "Stories from Our Community";

const displayTestimonials = (testimonials?.testimonials && testimonials.testimonials.length > 0)
  ? testimonials.testimonials.map((t) => ({
      quote: t.quote || "",
      name: t.author?.name || "Anonymous",
      role: t.author?.company ? `${t.author.role} - ${t.author.company}` : (t.author?.role || "Community Member"),
      image: t.author?.image?.asset?.url || "https://images.unsplash.com/photo-1500648767791-00dcc994a43e?q=80&w=800&auto=format&fit=crop",
      rating: t.rating || 5
    }))
  : fallbackTestimonials;
---

<section class="bg-surface py-20">
  <div class="container mx-auto px-6 max-w-7xl text-center mb-16">
    <h2 class="text-4xl md:text-5xl font-black text-primary mb-4 tracking-tight">
      {displayTitle}
    </h2>
    <p class="text-lg text-muted max-w-2xl mx-auto">
      {displaySubtitle}
    </p>
  </div>

  <div class="container mx-auto px-6 max-w-7xl">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {displayTestimonials.map((testimonial) => (
        <article class="bg-white p-8 rounded-2xl shadow-sm border border-slate-100 flex flex-col justify-between h-full relative">
          <!-- Quote Icon -->
          <div class="absolute top-6 right-6 text-slate-100 opacity-50">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
            </svg>
          </div>

          <div>
            <!-- Star Rating -->
            <div class="flex gap-1 mb-6 text-accent">
              {Array.from({ length: testimonial.rating }).map(() => (
                <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>

            <!-- The Quote -->
            <blockquote class="text-muted text-base leading-relaxed italic mb-8 relative z-10">
              "{testimonial.quote}"
            </blockquote>
          </div>

          <div>
            <!-- Divider -->
            <div class="w-full h-px bg-slate-100 mb-6"></div>

            <!-- Avatar & Meta Data -->
            <div class="flex items-center gap-4">
              <img 
                src={testimonial.image} 
                alt={testimonial.name} 
                class="w-12 h-12 rounded-full object-cover bg-surface"
              />
              <div class="flex flex-col">
                <p class="text-primary font-bold text-sm">
                  {testimonial.name}
                </p>
                <p class="text-muted text-xs uppercase tracking-wider mt-0.5">
                  {testimonial.role}
                </p>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
