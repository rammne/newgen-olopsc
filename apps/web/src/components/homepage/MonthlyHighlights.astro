---
import { getSanityImageUrl } from "../../lib/utils/sanity";

interface HighlightItem {
  title?: string;
  description?: string;
  date?: string;
  department?: string;
  image?: {
    asset?: { url?: string };
    alt?: string;
  };
}

interface Props {
  monthlyHighlights?: {
    title?: string;
    subtitle?: string;
    highlights?: HighlightItem[];
  };
}

const { monthlyHighlights } = Astro.props;

const currentYear = new Date().getFullYear();
const sectionTitle = monthlyHighlights?.title
  ? `${monthlyHighlights.title} of ${currentYear}`
  : `Monthly Highlights of ${currentYear}`;
const subtitle = monthlyHighlights?.subtitle || "A look at the memorable moments and achievements across our departments this year.";

const highlights = monthlyHighlights?.highlights || [];

const departmentLabels: Record<string, string> = {
  preschool: "Preschool",
  "grade-school": "Grade School",
  "junior-high-school": "Junior High School",
  "senior-high-school": "Senior High School",
  college: "College",
};

const filterTags = [
  { value: "all", label: "All" },
  { value: "preschool", label: "Preschool" },
  { value: "grade-school", label: "Grade School" },
  { value: "junior-high-school", label: "Junior High School" },
  { value: "senior-high-school", label: "Senior High School" },
  { value: "college", label: "College" },
];

function formatHighlightDate(dateString: string | undefined): string {
  if (!dateString) return "";
  const date = new Date(dateString + "T00:00:00");
  return date.toLocaleDateString("en-US", {
    month: "long",
    day: "numeric",
  });
}
---

<section class="mh-section min-h-[60vh] px-5 py-10 sm:px-[60px] sm:py-[100px] relative overflow-hidden">
  <!-- Accent stripe at the top -->
  <div class="mh-accent-stripe"></div>

  <!-- Section Header -->
  <div class="max-w-7xl mx-auto text-center mb-12 sm:mb-16">
    <h2 class="text-section-header-mobile sm:text-section-header-desktop font-semibold text-primary mb-4 tracking-tight">
      {sectionTitle}
    </h2>
    <div class="mh-title-underline mx-auto mb-6"></div>
    <p class="text-main-mobile sm:text-main-desktop text-gray-600 max-w-2xl mx-auto leading-relaxed">
      {subtitle}
    </p>
  </div>

  <!-- CSS-only Filter System -->
  <div class="mh-filter-wrapper max-w-7xl mx-auto">
    {filterTags.map((tag, i) => (
      <input
        type="radio"
        name="mh-filter"
        id={`mh-filter-${tag.value}`}
        class="mh-radio sr-only"
        checked={i === 0}
        data-filter={tag.value}
      />
    ))}

    <!-- Filter Pills -->
    <div class="mh-pills flex flex-wrap justify-center gap-2 sm:gap-3 mb-10 sm:mb-14">
      {filterTags.map((tag) => (
        <label
          for={`mh-filter-${tag.value}`}
          class="mh-pill"
        >
          {tag.label}
        </label>
      ))}
    </div>

    <!-- Grid -->
    <div class="mh-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
      {highlights.map((item) => {
        const imgUrl = getSanityImageUrl(item.image, { width: 600, quality: 80 });
        const alt = item.image?.alt || item.title || "Highlight photo";
        const dept = item.department || "preschool";
        const deptLabel = departmentLabels[dept] || dept;
        const dateStr = formatHighlightDate(item.date);

        return (
          <article class={`mh-card mh-dept-${dept}`} data-dept={dept}>
            <div class="mh-card-inner">
              {/* Image */}
              <div class="mh-card-image-wrap">
                {imgUrl ? (
                  <img
                    src={imgUrl}
                    alt={alt}
                    class="mh-card-img"
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <div class="mh-card-img-placeholder">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                      <circle cx="8.5" cy="8.5" r="1.5"/>
                      <polyline points="21 15 16 10 5 21"/>
                    </svg>
                  </div>
                )}
                {/* Department badge overlay */}
                <span class="mh-badge">{deptLabel}</span>
              </div>

              {/* Content */}
              <div class="mh-card-content">
                {dateStr && (
                  <time class="mh-date">{dateStr}</time>
                )}
                <h3 class="mh-card-title">{item.title || "Untitled Highlight"}</h3>
                <p class="mh-card-desc">{item.description || ""}</p>
              </div>
            </div>
          </article>
        );
      })}
    </div>

    {/* Empty state */}
    {highlights.length === 0 && (
      <div class="text-center py-16">
        <p class="text-gray-400 text-main-desktop">No highlights posted yet. Check back soon!</p>
      </div>
    )}
  </div>
</section>

<style>
  /* ========== SECTION ========== */
  .mh-section {
    background: var(--color-neutral);
    position: relative;
  }

  .mh-accent-stripe {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 5px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-accent), var(--color-primary));
    background-size: 200% 100%;
    animation: mh-stripe-shimmer 4s ease-in-out infinite;
  }

  .mh-title-underline {
    width: 80px;
    height: 4px;
    border-radius: 2px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-accent));
  }

  /* ========== FILTER PILLS ========== */
  .mh-radio {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .mh-pill {
    cursor: pointer;
    padding: 10px 22px;
    border-radius: 999px;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.01em;
    border: 2px solid var(--color-primary);
    color: var(--color-primary);
    background: transparent;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    user-select: none;
    white-space: nowrap;
  }

  .mh-pill:hover {
    background: var(--color-primary);
    color: white;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(10, 9, 95, 0.25);
  }

  /* Active pill state */
  .mh-radio:checked + .mh-pills .mh-pill,
  .mh-pill {
    /* Default inactive state — already defined above */
  }

  /* The nth-of-type selectors for checked radio → matching label */
  #mh-filter-all:checked ~ .mh-pills label[for="mh-filter-all"],
  #mh-filter-preschool:checked ~ .mh-pills label[for="mh-filter-preschool"],
  #mh-filter-grade-school:checked ~ .mh-pills label[for="mh-filter-grade-school"],
  #mh-filter-junior-high-school:checked ~ .mh-pills label[for="mh-filter-junior-high-school"],
  #mh-filter-senior-high-school:checked ~ .mh-pills label[for="mh-filter-senior-high-school"],
  #mh-filter-college:checked ~ .mh-pills label[for="mh-filter-college"] {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-primary);
    box-shadow: 0 4px 16px rgba(237, 192, 84, 0.35);
    transform: translateY(-1px);
  }

  /* ========== CSS-ONLY FILTERING ========== */
  /* By default: show all cards */
  .mh-card {
    transition: opacity 0.35s ease, transform 0.35s ease;
  }

  /* When a specific department filter is checked, hide non-matching cards */
  #mh-filter-preschool:checked ~ .mh-grid .mh-card:not(.mh-dept-preschool),
  #mh-filter-grade-school:checked ~ .mh-grid .mh-card:not(.mh-dept-grade-school),
  #mh-filter-junior-high-school:checked ~ .mh-grid .mh-card:not(.mh-dept-junior-high-school),
  #mh-filter-senior-high-school:checked ~ .mh-grid .mh-card:not(.mh-dept-senior-high-school),
  #mh-filter-college:checked ~ .mh-grid .mh-card:not(.mh-dept-college) {
    display: none;
  }

  /* ========== CARDS ========== */
  .mh-card-inner {
    background: white;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(10, 9, 95, 0.08);
    border-top: 4px solid var(--color-accent);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
                box-shadow 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .mh-card-inner:hover {
    transform: translateY(-6px);
    box-shadow:
      0 12px 28px rgba(10, 9, 95, 0.12),
      0 4px 10px rgba(237, 192, 84, 0.1);
  }

  /* Image */
  .mh-card-image-wrap {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #e8e8f0;
  }

  .mh-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .mh-card-inner:hover .mh-card-img {
    transform: scale(1.06);
  }

  .mh-card-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #b0b0c0;
  }

  /* Department badge */
  .mh-badge {
    position: absolute;
    bottom: 12px;
    left: 12px;
    background: var(--color-primary);
    color: white;
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 5px 12px;
    border-radius: 6px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  /* Content area */
  .mh-card-content {
    padding: 20px 22px 24px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .mh-date {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .mh-date::before {
    content: '';
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-accent);
    animation: mh-pulse 2s ease-in-out infinite;
  }

  .mh-card-title {
    font-family: 'Montserrat', sans-serif;
    font-size: 20px;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1.3;
    margin-bottom: 10px;
  }

  @media (min-width: 640px) {
    .mh-card-title {
      font-size: 22px;
    }
  }

  .mh-card-desc {
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    line-height: 1.7;
    color: #4a4a5a;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  @media (min-width: 640px) {
    .mh-card-desc {
      font-size: 16px;
    }
  }

  /* ========== ANIMATIONS ========== */
  @keyframes mh-stripe-shimmer {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  @keyframes mh-pulse {
    0%, 100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.5;
      transform: scale(0.7);
    }
  }

  /* ========== REDUCED MOTION ========== */
  @media (prefers-reduced-motion: reduce) {
    .mh-accent-stripe {
      animation: none;
    }
    .mh-date::before {
      animation: none;
    }
    .mh-card-inner {
      transition: none;
    }
    .mh-card-img {
      transition: none;
    }
    .mh-pill {
      transition: none;
    }
    .mh-card {
      transition: none;
    }
  }
</style>
