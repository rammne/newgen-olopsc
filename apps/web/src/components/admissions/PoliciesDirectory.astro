---
/**
 * PoliciesDirectory.astro
 * Policies & Helpdesk Directory — Section 4 of College Admission page.
 *
 * Zero-JS layout using native HTML5 <details> accordions.
 * Enterprise Light Mode aesthetic.
 */

interface Policy {
  title: string;
  description: string;
}

interface DirectoryItem {
  department: string;
  email: string;
  phone?: string;
  secondaryEmail?: string;
}

const policies: Policy[] = [
  {
    title: "Shared Responsibility",
    description:
      "Your advisor guides you, but you are ultimately responsible for following your prescribed curriculum sequencing and prerequisites. Non-compliance can cause administrative delays or hold up your academic processing.",
  },
  {
    title: "Priority Advising Cases",
    description:
      "Special attention and fast-tracked advising are given to transferees, shifters, irregular students, students returning from a Leave of Absence (LOA), students on academic probation, and students with special educational needs.",
  },
  {
    title: "Referral System",
    description:
      "If you have concerns that extend beyond basic academic scheduling (such as emotional, deep psychological, or major financial issues), your adviser will formally connect you to specialized offices like the Guidance and Counseling Office or the Scholarship and Financial Assistance Office.",
  },
  {
    title: "Confidentiality",
    description:
      "All information, academic deficiencies, and personal matters discussed during your advising sessions are strictly confidential under institutional policies and data privacy laws.",
  },
];

const directory: DirectoryItem[] = [
  {
    department: "Admissions & Records",
    email: "admissions@olopsc.edu.ph",
    phone: "0998-5957592",
    secondaryEmail: "college.registrar@olopsc.edu.ph",
  },
  {
    department: "Cashier & Accounting",
    email: "collegecashier@olopsc.edu.ph",
    phone: "0917-8227532",
  },
  {
    department: "IT Services",
    email: "it.helpdesk@olopsc.edu.ph",
  },
  {
    department: "Student Support",
    email: "guidance@olopsc.edu.ph",
    secondaryEmail: "scholarships@olopsc.edu.ph",
  },
];
---

<section id="policies-directory" class="py-24 md:py-32 bg-slate-50 relative">
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-20 items-start">
    
    {/* Left Column: Academic Advising Policies */}
    <div class="lg:col-span-7 flex flex-col">
      <div class="mb-10">
        <span class="text-accent font-black tracking-widest uppercase text-xs mb-4 inline-block">
          Institutional Guidelines
        </span>
        <h2 class="text-3xl md:text-4xl font-black tracking-tight text-primary mb-4">
          Key Academic Policies.
        </h2>
        <p class="text-slate-600 leading-relaxed">
          Please review the advising and enrollment policies governing the College of BMSE.
        </p>
      </div>

      <div class="space-y-4">
        {policies.map((policy) => (
          <details class="group bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow">
            <summary class="flex items-center justify-between p-6 cursor-pointer list-none select-none">
              <h3 class="text-lg font-bold text-primary">{policy.title}</h3>
              <span class="w-8 h-8 rounded-full bg-slate-50 flex items-center justify-center text-primary group-open:rotate-180 transition-transform duration-300">
                <svg
                  class="w-4 h-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 9l-7 7-7-7"
                  />
                </svg>
              </span>
            </summary>
            <div class="px-6 pb-6 pt-2 border-t border-slate-100 mt-2">
              <p class="text-slate-600 text-sm leading-relaxed">
                {policy.description}
              </p>
            </div>
          </details>
        ))}
      </div>
    </div>

    {/* Right Column: Helpdesk & Referral Directory (Bento Grid) */}
    <div class="lg:col-span-5 flex flex-col">
      <div class="mb-10">
        <h3 class="text-xl font-black text-primary mb-2">Helpdesk Directory</h3>
        <p class="text-slate-500 text-sm">
          Need assistance? Contact the specific department below.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 gap-4">
        {directory.map((item) => (
          <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm hover:border-accent transition-colors flex flex-col items-start">
            <span class="w-10 h-10 rounded-xl bg-slate-100 text-accent flex items-center justify-center mb-4">
              <svg
                class="w-5 h-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                />
              </svg>
            </span>
            <h4 class="text-base font-bold text-primary mb-3">
              {item.department}
            </h4>
            <div class="flex flex-col space-y-2 w-full">
              <a
                href={"mailto:" + item.email}
                class="text-xs font-medium text-slate-500 hover:text-accent transition-colors truncate"
              >
                {item.email}
              </a>
              {item.secondaryEmail && (
                <a
                  href={"mailto:" + item.secondaryEmail}
                  class="text-xs font-medium text-slate-500 hover:text-accent transition-colors truncate"
                >
                  {item.secondaryEmail}
                </a>
              )}
              {item.phone && (
                <a
                  href={"tel:" + item.phone}
                  class="text-xs font-medium text-slate-500 hover:text-accent transition-colors mt-1 pt-2 border-t border-slate-100 flex items-center gap-2"
                >
                  <svg
                    class="w-3 h-3"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                    />
                  </svg>
                  {item.phone}
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
