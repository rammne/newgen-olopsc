---
/**
 * BasicEducationContent.astro
 * Content for the Basic Education Admission page.
 * Features highly scannable cards, clear procedures, and age requirements.
 */

const generalRequirements = [
  "PSA Birth Certificate (photocopy)",
  "Report of Grades",
  "Report Card / SF9 (Basic Education and 1st Year College applicants)",
  "Copy of Grades or Transcript of Records (College Transferees)",
  "Good Moral Certificate",
  "Two (2) 2x2 photos with white background",
];

const otherRequirements = [
  "Early Childhood Development Checklist (Kinder and Gr. 1 applicants)",
  "ESC Certificate or SHS Voucher (Grades 8-11 applicants, if applicable)",
  "Transfer Credential (College transferee)",
];

const ageRequirements = [
  { level: "Nursery", age: "3 years old" },
  { level: "Pre-Kinder", age: "4 years old" },
  { level: "Kinder", age: "5 years old" },
];

const scholarshipRequirements = [
  "Letter of Intent from Parent or Guardian",
  "Photocopy of PSA Birth Certificate",
  "Latest Report Card",
  "Good Moral Certificate",
  "Recent 2x2 picture w/ white background (2 pcs)",
  "Certificate of Grades signed by Principal",
  "Barangay Certificate of Indigency",
];

const regularProcedure = [
  "Submit application requirements at the Registrar's office.",
  "Pay the application fee at the cashier. (₱500.00)",
  "Take the assessment and/or interview as scheduled.",
];

const scholarshipProcedure = [
  "Submit scholarship application requirements at the Admissions Office.",
  "Take the qualifying examination and interview.",
  "Receive assessment results from the Admissions Office.",
];
---

<section class="py-24 md:py-32 bg-slate-50 border-b border-slate-200">
  <div class="max-w-7xl mx-auto px-6">
    {/* Section Header */}
    <div class="text-center mb-16">
      <span
        class="text-accent font-black tracking-widest uppercase text-xs mb-4 inline-block"
      >
        Basic Education Admissions
      </span>
      <h2
        class="text-3xl md:text-5xl font-black tracking-tight text-primary mb-6"
      >
        Requirements & Procedures.
      </h2>
      <p class="text-lg text-slate-600 leading-relaxed max-w-2xl mx-auto">
        Review the necessary documents, age requirements, and application steps
        for joining OLOPSC Basic Education programs.
      </p>
    </div>

    {/* Requirements Grid */}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-20">
      {/* General Requirements */}
      <div class="bg-white rounded-3xl p-8 shadow-sm border border-slate-200">
        <h3
          class="text-xl font-black text-primary mb-6 pb-4 border-b border-slate-100 flex items-center gap-3"
        >
          <svg
            class="w-6 h-6 text-accent"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
            ></path>
          </svg>
          Admission Requirements
        </h3>
        <ul class="space-y-4">
          {
            generalRequirements.map((item) => (
              <li class="flex items-start gap-3">
                <svg
                  class="w-5 h-5 text-accent shrink-0 mt-0.5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M5 13l4 4L19 7"
                  />
                </svg>
                <span class="text-slate-700 text-sm leading-relaxed">
                  {item}
                </span>
              </li>
            ))
          }
        </ul>
      </div>

      {/* Other Requirements */}
      <div class="bg-white rounded-3xl p-8 shadow-sm border border-slate-200">
        <h3
          class="text-xl font-black text-primary mb-6 pb-4 border-b border-slate-100 flex items-center gap-3"
        >
          <svg
            class="w-6 h-6 text-accent"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
            ></path>
          </svg>
          Other Requirements
        </h3>
        <ul class="space-y-4">
          {
            otherRequirements.map((item) => (
              <li class="flex items-start gap-3">
                <svg
                  class="w-5 h-5 text-accent shrink-0 mt-0.5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M5 13l4 4L19 7"
                  />
                </svg>
                <span class="text-slate-700 text-sm leading-relaxed">
                  {item}
                </span>
              </li>
            ))
          }
        </ul>
      </div>

      {/* Scholarship Requirements */}
      <div class="bg-white rounded-3xl p-8 shadow-sm border border-slate-200">
        <h3
          class="text-xl font-black text-primary mb-6 pb-4 border-b border-slate-100 flex items-center gap-3"
        >
          <svg
            class="w-6 h-6 text-accent"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
            ></path>
          </svg>
          Scholarship Requirements
          <span
            class="text-xs font-normal text-slate-500 ml-auto block sm:inline mt-1 sm:mt-0"
            >(For entering Gr. 7 and 1st year College)</span
          >
        </h3>
        <ul class="space-y-4">
          {
            scholarshipRequirements.map((item) => (
              <li class="flex items-start gap-3">
                <svg
                  class="w-5 h-5 text-accent shrink-0 mt-0.5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M5 13l4 4L19 7"
                  />
                </svg>
                <span class="text-slate-700 text-sm leading-relaxed">
                  {item}
                </span>
              </li>
            ))
          }
        </ul>
      </div>

      {/* Preschool Age Requirements */}
      <div
        class="bg-slate-100 rounded-3xl p-8 shadow-sm border border-slate-200"
      >
        <h3
          class="text-xl font-black text-primary mb-2 flex items-center gap-3"
        >
          <svg
            class="w-6 h-6 text-accent"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
            ></path>
          </svg>
          Preschool Age Requirements
        </h3>
        <p class="text-xs text-slate-500 mb-6 pb-4 border-b border-slate-200">
          Must meet age by October 31 of the school year, per DepEd Order No.
          015, s. 2025
        </p>
        <div class="flex flex-col gap-4">
          {
            ageRequirements.map((req) => (
              <div class="flex justify-between items-center bg-white p-4 rounded-xl border border-slate-100 shadow-sm">
                <span class="font-bold text-primary">{req.level}</span>
                <span class="text-sm font-black text-accent tracking-wider bg-accent/10 px-3 py-1 rounded-full">
                  {req.age}
                </span>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    {/* Procedures Section */}
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-2xl md:text-4xl font-black tracking-tight text-primary">
          Application Procedure
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {/* Regular Procedure */}
        <div class="flex flex-col space-y-6">
          <h3
            class="text-lg font-black text-primary border-b-2 border-accent pb-2 inline-block self-start"
          >
            For Regular Application
          </h3>
          <div
            class="flex flex-col space-y-6 relative before:absolute before:inset-0 before:ml-5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-transparent before:via-slate-200 before:to-transparent hidden"
          >
          </div>
          {
            regularProcedure.map((step, index) => (
              <div class="flex gap-5 items-start group">
                <div class="w-10 h-10 rounded-full bg-slate-100 border-2 border-white shadow-sm flex items-center justify-center text-primary font-black shrink-0 group-hover:bg-accent group-hover:text-white transition-colors duration-300 relative z-10">
                  {index + 1}
                </div>
                <div class="pt-2">
                  <p class="text-slate-700 text-sm leading-relaxed">{step}</p>
                </div>
              </div>
            ))
          }
        </div>

        {/* Scholarship Procedure */}
        <div class="flex flex-col space-y-6">
          <h3
            class="text-lg font-black text-primary border-b-2 border-accent pb-2 inline-block self-start"
          >
            For Scholarship Application
          </h3>
          {
            scholarshipProcedure.map((step, index) => (
              <div class="flex gap-5 items-start group">
                <div class="w-10 h-10 rounded-full bg-slate-100 border-2 border-white shadow-sm flex items-center justify-center text-primary font-black shrink-0 group-hover:bg-accent group-hover:text-white transition-colors duration-300 relative z-10">
                  {index + 1}
                </div>
                <div class="pt-2">
                  <p class="text-slate-700 text-sm leading-relaxed">{step}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
