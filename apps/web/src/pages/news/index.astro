---
import Layout from "../../layouts/Layout.astro";
import { getAllNews } from "../../lib/sanity/queries";
import { getSanityImageUrl, formatDate } from "../../lib/utils/sanity";
import "../../styles/global.css";

// Fetch all news articles
const allNews = await getAllNews();

// Separate hero article and remaining articles
const heroArticle = allNews && allNews.length > 0 ? allNews[0] : null;
const remainingArticles = allNews && allNews.length > 1 ? allNews.slice(1) : [];

const pageTitle = "News & Updates";
const pageDescription =
  "Stay informed with the latest announcements and achievements from our campus.";

// Category color map
const categoryColors: Record<string, { bg: string; text: string }> = {
  announcements: { bg: "bg-[#d97706]", text: "text-white" }, // Amber
  achievements: { bg: "bg-[#16a34a]", text: "text-white" }, // Green
  default: { bg: "bg-[#64748b]", text: "text-white" }, // Slate
};
---

<Layout title={pageTitle} description={pageDescription}>

  {/* ─── Gradient Page Header ─── */}
  <section
    class="relative min-h-[35vh] sm:min-h-[40vh] flex items-center justify-center pt-32 sm:pt-[150px] pb-10 sm:pb-16 overflow-hidden"
    style="background: linear-gradient(135deg, #0a095f 0%, #050340 100%)"
  >
    {/* Decorative circles */}
    <div class="absolute top-10 left-10 w-64 h-64 rounded-full bg-white/[0.03]"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 rounded-full bg-white/[0.02] translate-x-1/3 translate-y-1/3"></div>
    <div class="absolute top-1/2 left-1/2 w-48 h-48 rounded-full bg-[var(--color-accent)]/[0.05] -translate-x-1/2 -translate-y-1/2"></div>

    <div class="relative z-10 text-center px-5">
      <h1 class="text-section-header-mobile sm:text-section-header-desktop text-white mb-4">
        News & Updates
      </h1>
      <p class="text-white/70 text-main-mobile sm:text-main-desktop max-w-xl mx-auto mb-6" style="font-family: 'Inter', sans-serif;">
        Stay informed with the latest announcements and achievements from our campus.
      </p>
      <div class="w-16 h-1 bg-[var(--color-accent)] mx-auto rounded-full"></div>
    </div>
  </section>

  {/* ─── Main Content ─── */}
  <section class="px-5 py-10 sm:px-[60px] sm:py-[100px] bg-[var(--color-neutral)] min-h-[60vh]">
    <div class="container mx-auto max-w-7xl">

      {/* ─── Featured Hero Article ─── */}
      {heroArticle && (
        <div class="mb-16 sm:mb-20">
          <a
            href={`/news/${heroArticle.slug?.current || ""}`}
            class="group flex flex-col lg:flex-row bg-white rounded-2xl overflow-hidden shadow-[0_8px_30px_rgb(0,0,0,0.08)] hover:shadow-[0_20px_40px_rgb(0,0,0,0.12)] transition-all duration-500 hover:-translate-y-1 relative"
          >
            {/* LATEST Badge */}
            <div class="absolute top-6 left-6 z-10">
              <span class="px-4 py-1.5 bg-[var(--color-accent)] text-[var(--color-primary)] text-xs font-black uppercase tracking-widest rounded-full shadow-md">
                Latest
              </span>
            </div>

            {/* Image Side */}
            <div class="lg:w-3/5 h-[300px] sm:h-[400px] lg:h-[450px] overflow-hidden relative">
              {heroArticle.featuredImage?.asset?.url ? (
                <img
                  src={getSanityImageUrl(heroArticle.featuredImage, { width: 1200, height: 600, fit: "crop" })}
                  alt={heroArticle.featuredImage.alt || heroArticle.title || ""}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                />
              ) : (
                <div class="w-full h-full bg-gray-100 flex items-center justify-center">
                  <span class="text-6xl opacity-20">📰</span>
                </div>
              )}
            </div>

            {/* Content Side */}
            <div class="lg:w-2/5 p-8 sm:p-10 lg:p-12 flex flex-col justify-center">
              <div class="flex items-center gap-3 mb-6 flex-wrap">
                {heroArticle.category && (() => {
                  const colors = categoryColors[heroArticle.category.toLowerCase()] || categoryColors.default;
                  return (
                    <span class={`px-3 py-1 ${colors.bg} ${colors.text} text-[11px] font-bold uppercase tracking-wider rounded-full`}>
                      {heroArticle.category}
                    </span>
                  );
                })()}
                <span class="text-[13px] text-gray-500 font-medium" style="font-family: 'Inter', sans-serif;">
                  {heroArticle.academicDepartment?.title || "General"}
                </span>
              </div>

              <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-[var(--color-primary)] mb-5 group-hover:text-[var(--color-accent)] transition-colors leading-tight" style="font-family: 'Montserrat', sans-serif;">
                {heroArticle.title}
              </h2>

              {heroArticle.excerpt && (
                <p class="text-gray-600 text-base sm:text-lg leading-relaxed line-clamp-3 mb-8" style="font-family: 'Inter', sans-serif;">
                  {heroArticle.excerpt}
                </p>
              )}

              <div class="mt-auto flex items-center justify-between">
                {heroArticle.publishedAt && (
                  <span class="text-sm text-gray-400 font-medium flex items-center gap-2" style="font-family: 'Inter', sans-serif;">
                    🕒 {formatDate(heroArticle.publishedAt)}
                  </span>
                )}
                
                <span class="inline-flex items-center gap-2 text-[var(--color-accent)] font-bold text-sm sm:text-base group-hover:gap-3 transition-all uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">
                  Read Article <span class="transition-transform group-hover:translate-x-1">→</span>
                </span>
              </div>
            </div>
          </a>
        </div>
      )}

      {/* ─── Remaining Articles Grid ─── */}
      {remainingArticles && remainingArticles.length > 0 && (
        <div>
          <div class="flex items-center gap-4 mb-8 sm:mb-12">
            <h2 class="text-xl sm:text-2xl font-bold text-[var(--color-primary)]" style="font-family: 'Montserrat', sans-serif;">
              More Articles
            </h2>
            <div class="flex-1 h-px bg-gray-200"></div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
            {remainingArticles.map((article: any) => {
              const colors = article.category ? (categoryColors[article.category.toLowerCase()] || categoryColors.default) : categoryColors.default;
              
              return (
                <a
                  href={`/news/${article.slug?.current || ""}`}
                  class="group flex flex-col bg-white rounded-2xl overflow-hidden shadow-[0_2px_12px_-2px_rgba(0,0,0,0.04)] hover:shadow-[0_16px_32px_-8px_rgba(0,0,0,0.12)] transition-all duration-500 hover:-translate-y-1.5 h-full border border-gray-100/50"
                >
                  {/* Image */}
                  <div class="aspect-video overflow-hidden relative">
                    {article.featuredImage?.asset?.url ? (
                      <img
                        src={getSanityImageUrl(article.featuredImage, { width: 600, height: 400, fit: "crop" })}
                        alt={article.featuredImage.alt || article.title || ""}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                      />
                    ) : (
                      <div class="w-full h-full bg-gray-50 flex items-center justify-center">
                        <span class="text-4xl opacity-20">📰</span>
                      </div>
                    )}
                    
                    {/* Subtle gradient overlay */}
                    <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                  </div>

                  {/* Content */}
                  <div class="p-6 sm:p-8 flex flex-col flex-grow">
                    <div class="flex items-center gap-2 mb-4 flex-wrap">
                      {article.category && (
                        <span class={`px-2.5 py-1 ${colors.bg} ${colors.text} text-[10px] font-bold uppercase tracking-wider rounded-full`}>
                          {article.category}
                        </span>
                      )}
                      <span class="text-[12px] text-gray-400 font-medium" style="font-family: 'Inter', sans-serif;">
                        {article.academicDepartment?.title || "General"}
                      </span>
                    </div>

                    <h3 class="text-lg sm:text-xl font-bold text-[var(--color-primary)] mb-3 group-hover:text-[var(--color-accent)] transition-colors leading-snug line-clamp-2" style="font-family: 'Montserrat', sans-serif;">
                      {article.title}
                    </h3>

                    {article.excerpt && (
                      <p class="text-gray-500 text-sm leading-relaxed line-clamp-2 mb-6 flex-grow" style="font-family: 'Inter', sans-serif;">
                        {article.excerpt}
                      </p>
                    )}

                    <div class="mt-auto pt-4 border-t border-gray-50 flex items-center justify-between">
                      {article.publishedAt && (
                        <span class="text-xs text-gray-400 font-medium flex items-center gap-1.5" style="font-family: 'Inter', sans-serif;">
                          🕒 {formatDate(article.publishedAt)}
                        </span>
                      )}
                      
                      <span class="inline-flex items-center gap-1.5 text-[var(--color-accent)] font-bold text-sm group-hover:gap-2 transition-all uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">
                        Read <span class="transition-transform group-hover:translate-x-1">→</span>
                      </span>
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      )}

      {/* ─── Empty State ─── */}
      {allNews.length === 0 && (
        <div class="flex items-center justify-center py-20">
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-12 sm:p-16 text-center max-w-lg">
            <div class="text-6xl mb-6">📰</div>
            <h3 class="text-xl sm:text-2xl font-bold text-[var(--color-primary)] mb-3" style="font-family: 'Montserrat', sans-serif;">
              No Articles Yet
            </h3>
            <p class="text-gray-500 text-sm sm:text-base" style="font-family: 'Inter', sans-serif;">
              There are no news updates at the moment. Check back soon for the latest announcements and achievements.
            </p>
          </div>
        </div>
      )}

    </div>
  </section>

</Layout>
