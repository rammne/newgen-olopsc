  <section class="py-24 md:py-32 bg-white relative border-t border-slate-100">
    <div class="max-w-7xl mx-auto px-6">
      <!-- Part 1: The Program Chair (Editorial Split) -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-center mb-24 md:mb-32">
        <!-- Left Column (The Portrait) -->
        <div class="lg:col-span-5 relative">
          <div class="relative w-full aspect-[4/5] rounded-3xl overflow-hidden shadow-2xl border border-slate-100">
            <img src={chair.image.url} alt={chair.image.alt} class="w-full h-full object-cover" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-primary/60 to-transparent z-10"></div>
            <div class="absolute bottom-0 left-0 right-0 p-8 z-20">
              <h3 class="text-2xl font-black text-white leading-tight">{chair.name}</h3>
              <span class="text-accent font-bold text-sm tracking-widest uppercase">{chair.title}</span>
              <p class="text-slate-300 text-xs mt-1">{chair.credentials}</p>
            </div>
          </div>
        </div>

        <!-- Right Column (The Manifesto Quote) -->
        <div class="lg:col-span-7 flex flex-col justify-center">
          <span class="text-accent font-black tracking-widest uppercase text-xs mb-6 inline-block">Message from the Chair</span>
          <svg class="w-16 h-16 text-slate-100 mb-6" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h4v10h-10z"/></svg>
          <p class="text-2xl md:text-4xl font-black text-primary leading-snug tracking-tight mb-8">"{chair.quote}"</p>
        </div>
      </div>

      <!-- Part 2: The Faculty Spotlight Grid -->
      <div class="text-center mb-16">
        <h3 class="text-3xl font-black tracking-tight text-primary">Core Faculty & Industry Practitioners</h3>
        <p class="text-slate-600 mt-4 max-w-2xl mx-auto">Learn directly from startup founders, HR directors, and corporate marketing executives.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {faculty.map((member: any) => (
          <div class="group flex flex-col">
            <div class="relative w-full aspect-[3/4] bg-surface rounded-2xl overflow-hidden mb-6 border border-slate-100 shadow-sm">
              <img src={member.image.url} alt={member.image.alt} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-10"></div>
              <div class="absolute top-4 left-4 bg-white/90 backdrop-blur text-primary text-[10px] font-black uppercase tracking-widest py-1.5 px-3 rounded-md shadow-sm z-20">{member.specialty}</div>
            </div>
            <div class="flex flex-col items-center text-center px-2">
              <h4 class="text-lg font-black text-primary mb-1 group-hover:text-accent transition-colors duration-300">{member.name}</h4>
              <span class="text-xs font-bold text-slate-400 uppercase tracking-widest">{member.credentials}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 md:py-32 bg-slate-50 relative border-t border-b border-slate-200">
    <div class="max-w-7xl mx-auto px-6 mb-16 md:mb-24 text-center">
      <span class="text-accent font-black tracking-widest uppercase text-xs mb-4 inline-block">Return on Investment</span>
      <h2 class="text-3xl md:text-5xl font-black tracking-tight text-primary mb-6">Your Blueprint for Market Dominance.</h2>
      <p class="text-lg text-slate-600 leading-relaxed max-w-2xl mx-auto">A Business or Entrepreneurship degree from OLOPSC is a quantifiable asset. Our graduates scale startups, direct human capital, and command global marketing divisions.</p>
    </div>

    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-8">
      {pathways.map((pathway: any) => (
        <div class="bg-white rounded-3xl p-8 md:p-10 shadow-sm hover:shadow-xl border border-slate-100 flex flex-col h-full group transition-all duration-300 hover:-translate-y-1">
          <div class="w-14 h-14 rounded-2xl bg-surface flex items-center justify-center text-primary mb-8 group-hover:bg-accent group-hover:text-white transition-colors duration-500">
            <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
          </div>

          <div class="mb-8 border-b border-slate-100 pb-8">
            <span class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-2 block">{pathway.subtitle}</span>
            <h3 class="text-2xl font-black text-primary leading-tight mb-4">{pathway.title}</h3>
            <p class="text-sm text-slate-600 leading-relaxed">{pathway.description}</p>
          </div>

          <div class="flex-grow flex flex-col">
            <span class="text-xs font-bold text-primary uppercase tracking-widest mb-4 bg-slate-50 self-start px-3 py-1 rounded-md">Executive Roles</span>
            <ul class="space-y-3">
              {pathway.roles?.map((role: string) => (
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg> 
                  <span class="text-slate-700 font-medium text-sm leading-tight">{role}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>

    <div class="max-w-4xl mx-auto px-6 mt-20 text-center">
      <CtaButton cta={{ text: "Begin Your Application Today", link: "/admissions", style: "primary" }} />
    </div>
  </section>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const buttons = document.querySelectorAll('.tab-btn');
      const contents = document.querySelectorAll('.tab-content');

      buttons.forEach(button => {
        button.addEventListener('click', () => {
          // Reset all buttons
          buttons.forEach(btn => {
            btn.classList.remove('bg-primary', 'text-white', 'border-primary', 'active-tab');
            btn.classList.add('bg-white', 'text-slate-500', 'border-slate-200');
          });
          
          // Hide all content blocks
          contents.forEach(content => {
            content.classList.remove('block');
            content.classList.add('hidden');
          });

          // Activate clicked button
          button.classList.remove('bg-white', 'text-slate-500', 'border-slate-200');
          button.classList.add('bg-primary', 'text-white', 'border-primary', 'active-tab');
          
          // Show target content
          const targetId = button.getAttribute('data-target');
          if (targetId) {
            const targetContent = document.getElementById(targetId);
            if (targetContent) {
              targetContent.classList.remove('hidden');
              targetContent.classList.add('block');
            }
          }
        });
      });
    });
  </script>
</Layout>
