---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/homepage/Hero.astro";
import Intro from "../components/homepage/Intro.astro";
import Stats from "../components/homepage/Stats.astro";
import PresidentMessage from "../components/homepage/PresidentMessage.astro";
import SRice from "../components/homepage/SRice.astro";
import Features from "../components/homepage/Features.astro";
import MonthlyHighlights from "../components/homepage/MonthlyHighlights.astro";
import AcademicDepartments from "../components/homepage/AcademicDepartments.astro";
import ProgramsPreview from "../components/homepage/ProgramsPreview.astro";
import LatestNews from "../components/homepage/LatestNews.astro";
import UpcomingEvents from "../components/homepage/UpcomingEvents.astro";
import FinalCta from "../components/homepage/FinalCta.astro";
import ScrollRevealWrapper from "../components/common/ScrollRevealWrapper.astro";
import {
  getHomePage,
  getLatestNews,
  getUpcomingEvents,
  getCollegeProgramThumbnails,
} from "../lib/sanity/queries";
import "../styles/global.css";

// Fetch homepage data
const homePage = await getHomePage();
const thumbnails = await getCollegeProgramThumbnails();

// Fetch featured news (max 3) for home page
let newsArticles = [];
if (homePage?.latestNews) {
  newsArticles = await getLatestNews(3);
}

// Fetch featured events (max 3) for home page
let events = [];
if (homePage?.upcomingEvents) {
  events = await getUpcomingEvents(3);
}

// Set page title from SEO or default
const pageTitle = homePage?.seo?.title || homePage?.title || "Top College & School in Marikina, Metro Manila | OLOPSC";
const pageDescription = homePage?.seo?.description || "Our Lady of Perpetual Succor College (OLOPSC) is a premier private Catholic school and college in Marikina City, Metro Manila offering K-12, Senior High School, and degree programs including Computer Science.";
const ogImage = homePage?.seo?.image?.asset?.url;
---

<Layout title={pageTitle} description={pageDescription} ogImage={ogImage}>
  {homePage?.hero && <Hero hero={homePage.hero} />}

  {
    homePage?.intro && (
      <ScrollRevealWrapper direction="fade" delay={0.1}>
        <Intro intro={homePage.intro} />
      </ScrollRevealWrapper>
    )
  }

  {
    homePage?.programsPreview && (
      <ScrollRevealWrapper direction="up" delay={0.1}>
        <ProgramsPreview programsPreview={homePage.programsPreview} thumbnails={thumbnails} />
      </ScrollRevealWrapper>
    )
  }

  {
    homePage?.keyStats &&
      homePage.keyStats.stats &&
      homePage.keyStats.stats.length > 0 && (
        <ScrollRevealWrapper direction="up" delay={0.1}>
          <Stats keyStats={homePage.keyStats} />
        </ScrollRevealWrapper>
      )
  }

  {
    homePage?.academicDepartments && (
      <ScrollRevealWrapper direction="up" delay={0.2}>
        <AcademicDepartments
          academicDepartments={homePage.academicDepartments}
        />
      </ScrollRevealWrapper>
    )
  }

  {
    homePage?.presidentMessage && (
      <ScrollRevealWrapper direction="up" delay={0.1}>
        <PresidentMessage presidentMessage={homePage.presidentMessage} />
      </ScrollRevealWrapper>
    )
  }

  {
    homePage?.sRice && (
      <ScrollRevealWrapper direction="up" delay={0.1}>
        <SRice sRice={homePage.sRice} />
      </ScrollRevealWrapper>
    )
  }

  {
    homePage?.monthlyHighlights && (
      <ScrollRevealWrapper direction="up" delay={0.1}>
        <MonthlyHighlights monthlyHighlights={homePage.monthlyHighlights} />
      </ScrollRevealWrapper>
    )
  }

  {
    ((homePage?.basicEdFeatures && homePage.basicEdFeatures.length > 0) || 
     (homePage?.collegeFeatures && homePage.collegeFeatures.length > 0)) && (
      <ScrollRevealWrapper direction="up" delay={0.1}>
        <Features 
          basicEdFeatures={homePage.basicEdFeatures} 
          collegeFeatures={homePage.collegeFeatures} 
        />
      </ScrollRevealWrapper>
    )
  }

  {
    homePage?.upcomingEvents && events.length > 0 && (
      <ScrollRevealWrapper direction="up" delay={0.1}>
        <UpcomingEvents
          upcomingEvents={homePage.upcomingEvents}
          events={events}
        />
      </ScrollRevealWrapper>
    )
  }

  {
    homePage?.latestNews && newsArticles.length > 0 && (
      <ScrollRevealWrapper direction="up" delay={0.1}>
        <LatestNews
          latestNews={homePage.latestNews}
          newsArticles={newsArticles}
        />
      </ScrollRevealWrapper>
    )
  }

  {
    homePage?.finalCta && (
      <ScrollRevealWrapper direction="fade" delay={0.1}>
        <FinalCta finalCta={homePage.finalCta} />
      </ScrollRevealWrapper>
    )
  }
</Layout>
