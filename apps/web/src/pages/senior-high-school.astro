---
import Layout from "../layouts/Layout.astro";
import CtaButton from "../components/common/CtaButton.astro";
import { getAcademicDepartmentByType } from "../lib/sanity/queries";
import { getSanityImageUrl } from "../lib/utils/sanity";
import "../styles/global.css";

// Fetch CMS data
const department = await getAcademicDepartmentByType("seniorHigh");

// --- Image Object Mapping ---
interface SanityImage {
  url: string;
  alt: string;
}

const heroImage: SanityImage = {
  url: department?.hero?.backgroundImage?.asset?.url
    ? getSanityImageUrl(department.hero.backgroundImage, { width: 1200, height: 900, fit: "crop" })
    : "https://images.unsplash.com/photo-1523580494863-6f3031224c94?q=80&w=1200&auto=format&fit=crop",
  alt: department?.hero?.backgroundImage?.alt
    ?? "OLOPSC Senior High School students preparing for university life",
};

// --- Helper: find a section image by label ---
function findSectionImage(label: string) {
  return department?.sectionImages?.find((s: any) =>
    s.sectionLabel?.toLowerCase().includes(label.toLowerCase())
  );
}

// Section 2: Academic Track image — pulls from sectionImages
const academicTrackEntry = findSectionImage("academic track") || findSectionImage("academic") || findSectionImage("assh");
const academicTrackImage: SanityImage = {
  url: academicTrackEntry?.image?.asset?.url
    ? getSanityImageUrl(academicTrackEntry.image, { width: 1200, height: 1200, fit: "crop" })
    : "https://images.unsplash.com/photo-1434030216411-0b793f4b4173?q=80&w=1200&auto=format&fit=crop",
  alt: academicTrackEntry?.image?.alt
    ?? "STEM, BE, and ASH academic track students at OLOPSC",
};

// Section 2: TECHPRO Track image — pulls from sectionImages
const techproTrackEntry = findSectionImage("techpro") || findSectionImage("tech-voc") || findSectionImage("ict");
const techproTrackImage: SanityImage = {
  url: techproTrackEntry?.image?.asset?.url
    ? getSanityImageUrl(techproTrackEntry.image, { width: 1200, height: 1200, fit: "crop" })
    : "https://images.unsplash.com/photo-1581092918056-0c4c3acd3789?q=80&w=1200&auto=format&fit=crop",
  alt: techproTrackEntry?.image?.alt
    ?? "ICT and Hospitality & Tourism TECHPRO students",
};

// Section 3: Campus Life gallery — exclusively uses facilityTourImages
interface ShsCultureImage {
  url: string;
  alt: string;
  title: string;
  description: string;
}

const rawGallery = department?.facilityTourImages || [];
const hasValidGallery = rawGallery.length > 0;

const shsCultureGallery: ShsCultureImage[] = hasValidGallery
  ? rawGallery.slice(0, 6).map((img: any) => ({
      url: img?.asset?.url
        ? getSanityImageUrl(img, { width: 1200, height: 900, fit: "crop" })
        : "https://images.unsplash.com/photo-1532094349884-543bc11b234d?q=80&w=1200&auto=format&fit=crop",
      alt: img?.alt || "Campus Facility",
      title: img?.caption || "Campus Facility",
      description: img?.description || "A dynamic and engaging campus facility for our Senior High School students."
    }))
  : [
      {
        title: "Collegiate-Level Science Labs",
        description: "Advanced laboratories designed specifically for STEM track students to conduct university-grade empirical research and complex biological experiments.",
        alt: "SHS STEM students in advanced science laboratory",
        url: "https://images.unsplash.com/photo-1532094349884-543bc11b234d?q=80&w=1200&auto=format&fit=crop"
      },
      {
        title: "Student Council & Autonomy",
        description: "A platform for real student voice. Our SHS leadership bodies actively organize campus-wide events, community extensions, and civic debates.",
        alt: "Senior High School student council leadership",
        url: "https://images.unsplash.com/photo-1523240795612-9a054b0db644?q=80&w=1200&auto=format&fit=crop"
      },
      {
        title: "Collaborative Research Hubs",
        description: "Modern, quiet library spaces and collaboration pods built for independent study, thesis writing, and group project development.",
        alt: "SHS students collaborating in library hub",
        url: "https://images.unsplash.com/photo-1524995997946-a1c2e315a42f?q=80&w=1200&auto=format&fit=crop"
      },
      {
        title: "Specialized ICT Centers",
        description: "High-performance computing environments for Tech-Voc students mastering programming, networking, and digital systems architecture.",
        alt: "ICT track students coding in computer lab",
        url: "https://images.unsplash.com/photo-1517694712202-14dd9538aa97?q=80&w=1200&auto=format&fit=crop"
      },
      {
        title: "Varsity Athletics & Campus Life",
        description: "Elite indoor sports facilities fostering physical conditioning, teamwork, and competitive institutional pride among young adults.",
        alt: "SHS varsity athletes competing on indoor court",
        url: "https://images.unsplash.com/photo-1546519638-68e109498ffc?q=80&w=1200&auto=format&fit=crop"
      },
      {
        title: "Creative Arts & Design Studios",
        description: "Dedicated spaces for arts and design track students to explore visual communication, multimedia arts, and creative expression.",
        alt: "SHS students working on creative arts and design",
        url: "https://images.unsplash.com/photo-1514320291840-2e0a9bf2a9ae?q=80&w=1200&auto=format&fit=crop"
      }
    ];


// SEO metadata
const pageTitle = department?.seo?.title ?? "Senior High School (Grades 11-12) | OLOPSC Marikina";
const pageDescription = department?.seo?.description ?? "CHED-recognized Senior High School offering STEM, Business, Arts & Humanities, and TECHPRO track clusters with DepEd SHS Voucher acceptance at OLOPSC Marikina.";
const ogImage = department?.seo?.image?.asset?.url;
---

<Layout title={pageTitle} description={pageDescription} ogImage={ogImage}>

  <!-- ==================== SECTION 1: The Dual-Hook Hero ==================== -->
  <section class="relative bg-primary text-white py-24 lg:py-32 overflow-hidden">
    <!-- Ambient Glow Layer -->
    <div class="absolute top-0 left-0 w-[500px] h-[500px] bg-primary/5 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2 pointer-events-none z-0"></div>
    <div class="absolute bottom-0 right-0 w-[600px] h-[600px] bg-accent/10 rounded-full blur-3xl translate-x-1/3 translate-y-1/3 pointer-events-none z-0"></div>

    <div class="relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center max-w-7xl mx-auto px-6">

      <!-- Left Column: Text Payload -->
      <div>
        <span class="text-accent font-bold tracking-widest uppercase text-sm mb-4 block">
          Senior High School (Grades 11-12)
        </span>
        <h1 class="text-4xl md:text-6xl font-black tracking-tight leading-none mb-6">
          {department?.hero?.headline || "Command Your Future. We Provide the Blueprint."}
        </h1>
        <p class="text-lg text-slate-300 leading-relaxed mb-8">
          {department?.hero?.subheadline || "Senior High School is the definitive step toward your career. At OLOPSC, we treat our SHS students as responsible young adults, providing the academic freedom to pursue specific passions, while giving parents the peace of mind of a secure, credible, and values-driven Catholic institution."}
        </p>
        <div class="flex flex-wrap gap-4">
          <CtaButton cta={{ text: "Contact Admissions", link: "#track-clusters", style: "primary" }} />
          <a
            href="/admissions"
            class="inline-flex items-center justify-center border-2 border-white text-white hover:bg-white hover:text-[#131312] font-bold py-3 px-8 rounded transition-colors"
          >
            Explore our Scholarship Programs
          </a>
        </div>
      </div>

      <!-- Right Column: Cinematic Visual Frame -->
      <div class="rounded-3xl overflow-hidden shadow-2xl aspect-[4/3] border border-slate-700">
        <img
          src={heroImage.url}
          alt={heroImage.alt}
          width="1200"
          height="900"
          loading="eager"
          decoding="async"
          class="w-full h-full object-cover"
        />
      </div>
    </div>
  </section>

  <!-- ==================== SECTION 1.5: Strengthened Curriculum ==================== -->
  <section class="bg-white py-24 border-b border-slate-200">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">

      <!-- Left: Title & Intro -->
      <div class="lg:col-span-5">
        <span class="text-accent font-bold uppercase tracking-wider text-sm mb-4 block">
          Fully Implemented for School Year 2026–2027
        </span>
        <h2 class="text-3xl md:text-5xl font-black text-primary mb-6 tracking-tight leading-tight">
          {department?.curriculum?.title || "Specialized SHS Track Clusters"}
        </h2>
        <p class="text-lg text-muted leading-relaxed">
          We offer Academic and TechPro Track Clusters designed to help students prepare for college and their future careers.
        </p>
      </div>

      <!-- Right: Scannable Details -->
      <div class="lg:col-span-7 bg-surface p-8 md:p-12 rounded-3xl shadow-sm border border-slate-200">
        <p class="text-muted mb-8 leading-relaxed">
          Students can choose from the following Track Clusters:
        </p>

        <div class="mb-6">
          <h4 class="font-bold text-primary text-lg mb-3">Academic Track Clusters:</h4>
          <ul class="space-y-4 pl-2">
            <li class="flex items-start gap-4">
              <div class="w-6 h-6 rounded-full bg-accent/20 flex items-center justify-center flex-shrink-0 mt-0.5">
                <span class="text-accent text-sm font-bold">✓</span>
              </div>
              <span class="text-primary font-medium leading-relaxed">Arts, Social Sciences and Humanities (ASSH)</span>
            </li>
            <li class="flex items-start gap-4">
              <div class="w-6 h-6 rounded-full bg-accent/20 flex items-center justify-center flex-shrink-0 mt-0.5">
                <span class="text-accent text-sm font-bold">✓</span>
              </div>
              <span class="text-primary font-medium leading-relaxed">Business and Entrepreneurship (BAE)</span>
            </li>
            <li class="flex items-start gap-4">
              <div class="w-6 h-6 rounded-full bg-accent/20 flex items-center justify-center flex-shrink-0 mt-0.5">
                <span class="text-accent text-sm font-bold">✓</span>
              </div>
              <span class="text-primary font-medium leading-relaxed">Science, Technology, Engineering and Mathematics (STEM)</span>
            </li>
          </ul>
        </div>

        <div class="mb-8">
          <h4 class="font-bold text-primary text-lg mb-3">TECHPRO Track Clusters:</h4>
          <ul class="space-y-4 pl-2">
            <li class="flex items-start gap-4">
              <div class="w-6 h-6 rounded-full bg-accent/20 flex items-center justify-center flex-shrink-0 mt-0.5">
                <span class="text-accent text-sm font-bold">✓</span>
              </div>
              <span class="text-primary font-medium leading-relaxed">Hospitality and Tourism (HT)</span>
            </li>
            <li class="flex items-start gap-4">
              <div class="w-6 h-6 rounded-full bg-accent/20 flex items-center justify-center flex-shrink-0 mt-0.5">
                <span class="text-accent text-sm font-bold">✓</span>
              </div>
              <span class="text-primary font-medium leading-relaxed">Information and Communications Technology (ICT)</span>
            </li>
          </ul>
        </div>

        <p class="text-muted mb-6 leading-relaxed">
          Our program combines classroom learning with hands-on skills and character building. This ensures that OLOPSC graduates are ready for college, work, or starting their own business.
        </p>
        <div class="bg-primary/5 p-6 rounded-2xl border-l-4 border-accent">
          <p class="text-primary font-medium italic">
            "At OLOPSC Senior High School, we help every student find their passion and become ready for the future."
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== SECTION 2: The Track Clusters ==================== -->
  <section id="track-clusters" class="bg-surface py-24">
    <div class="max-w-5xl mx-auto px-6 text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-black text-primary mb-6 tracking-tight">
        {department?.trackClusters?.title || "Tailored Pathways for Every Ambition"}
      </h2>
      <p class="text-muted">
        Choose the exact curriculum that aligns with your dream university course or immediate career goals.
      </p>
    </div>

    <!-- Block A: Academic Track Clusters (Text Left, Image Right) -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start mb-20 max-w-7xl mx-auto px-6">
      <div>
        <h3 class="text-3xl font-bold text-primary mb-6">
          Academic Track Clusters
        </h3>
        <div class="flex flex-col gap-8">
          <!-- ASSH -->
          <div>
            <p class="font-bold text-lg text-primary mb-2">
              Arts, Social Sciences and Humanities (ASSH)
            </p>
            <p class="text-muted mb-4">
              Nurtures critical thinking, effective communication, and a deeper understanding of society and human behavior. Learners engage in the study of literature, social sciences, philosophy, culture, media, and the arts.
            </p>
            <div class="space-y-2 text-sm">
              <p>
                <span class="font-semibold text-primary">Skills Developed:</span> <span class="text-muted">Research, analysis, leadership, and advocacy.</span>
              </p>
              <p>
                <span class="font-semibold text-primary">Target Careers:</span> <span class="text-muted">Education, law, public service, psychology, communication, journalism, creative industries, and other humanities-related fields.</span>
              </p>
            </div>
          </div>
          <!-- BAE -->
          <div>
            <p class="font-bold text-lg text-primary mb-2">
              Business and Entrepreneurship (BAE)
            </p>
            <p class="text-muted mb-4">
              Prepares students to become innovative thinkers, future business leaders, and entrepreneurial problem-solvers in an increasingly dynamic economy.
            </p>
            <div class="space-y-2 text-sm">
              <p>
                <span class="font-semibold text-primary">Skills Developed:</span> <span class="text-muted">Business management, marketing, finance, entrepreneurship, organizational leadership, creativity, strategic thinking, and decision-making.</span>
              </p>
              <p>
                <span class="font-semibold text-primary">Target Outcomes:</span> <span class="text-muted">Success in business and enterprise through practical and experiential learning.</span>
              </p>
            </div>
          </div>
          <!-- STEM -->
          <div>
            <p class="font-bold text-lg text-primary mb-2">
              Science, Technology, Engineering and Mathematics (STEM)
            </p>
            <p class="text-muted mb-4">
              Provides a strong foundation in science, mathematics, technology, and innovation. Students engage in advanced learning experiences that strengthen their understanding of real-world scientific applications.
            </p>
            <div class="space-y-2 text-sm">
              <p>
                <span class="font-semibold text-primary">Skills Developed:</span> <span class="text-muted">Analytical thinking, problem-solving, scientific inquiry, research capabilities, and technical competencies.</span>
              </p>
              <p>
                <span class="font-semibold text-primary">Target Outcomes:</span> <span class="text-muted">Rigorous university programs and careers that drive innovation and technological advancement.</span>
              </p>
            </div>
          </div>
        </div>
      </div>
      <div class="aspect-square rounded-3xl overflow-hidden shadow-lg">
        <img
          src={academicTrackImage.url}
          alt={academicTrackImage.alt}
          width="1200"
          height="1200"
          loading="lazy"
          decoding="async"
          class="w-full h-full object-cover"
        />
      </div>
    </div>

    <!-- Block B: TECHPRO Track Clusters (Image Left, Text Right) -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start max-w-7xl mx-auto px-6">
      <div class="aspect-square rounded-3xl overflow-hidden shadow-lg order-2 lg:order-1">
        <img
          src={techproTrackImage.url}
          alt={techproTrackImage.alt}
          width="1200"
          height="1200"
          loading="lazy"
          decoding="async"
          class="w-full h-full object-cover"
        />
      </div>
      <div class="order-1 lg:order-2">
        <h3 class="text-3xl font-bold text-primary mb-6">
          TECHPRO Track Clusters
        </h3>
        <p class="text-muted mb-6">
          An aggressive, hands-on pipeline designed for highly specialized technical skills, NC II certifications, and direct entry into tech or hospitality sectors.
        </p>
        <div class="flex flex-col gap-8">
          <!-- HT -->
          <div>
            <p class="font-bold text-lg text-primary mb-2">
              Hospitality and Tourism (HT)
            </p>
            <p class="text-muted mb-4">
              Equips students with the professionalism and customer service excellence required in one of the world's fastest-growing industries.
            </p>
            <div class="space-y-2 text-sm">
              <p>
                <span class="font-semibold text-primary">Skills Developed:</span> <span class="text-muted">Hospitality operations, tourism management, event coordination, travel services, guest relations, adaptability, and service-oriented competencies.</span>
              </p>
              <p>
                <span class="font-semibold text-primary">Target Outcomes:</span> <span class="text-muted">Confidence and practical knowledge valued in both local and international settings through industry-aligned training and experiential activities.</span>
              </p>
            </div>
          </div>
          <!-- ICT -->
          <div>
            <p class="font-bold text-lg text-primary mb-2">
              Information and Communications Technology (ICT)
            </p>
            <p class="text-muted mb-4">
              Empowers students to thrive in the digital age by developing technical skills in computing, programming, digital systems, and emerging technologies.
            </p>
            <div class="space-y-2 text-sm">
              <p>
                <span class="font-semibold text-primary">Skills Developed:</span> <span class="text-muted">Problem-solving, innovation, and digital literacy skills.</span>
              </p>
              <p>
                <span class="font-semibold text-primary">Target Outcomes:</span> <span class="text-muted">Technology-driven careers and further studies in computing and related disciplines.</span>
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== SECTION 3: Culture & Autonomy ==================== -->
  <section class="bg-white py-24 border-t border-slate-200">
    <div class="max-w-4xl mx-auto px-6 text-center mb-16">
      <span class="text-accent font-bold uppercase tracking-wider text-xs mb-3 block">
        Campus Life & Facilities
      </span>
      <h2 class="text-3xl md:text-5xl font-black text-primary mb-6 tracking-tight">
        {department?.facilitiesHeader?.title || "Independence, Respected."}
      </h2>
      <p class="text-lg text-muted leading-relaxed">
        {department?.facilitiesHeader?.description || "We know you aren't kids anymore. Our Senior High environment is built on mutual respect. You will have access to modern science labs, collegiate-level library hubs, and a vibrant campus culture full of specialized clubs where your ideas are taken seriously. You have the autonomy to lead; we provide the platform."}
      </p>
    </div>

    <!-- The Interactive Description Grid -->
    <div class="container mx-auto max-w-7xl flex md:grid md:grid-cols-3 md:auto-rows-[320px] gap-4 md:gap-6 overflow-x-auto md:overflow-visible snap-x snap-mandatory md:snap-none pb-8 md:pb-0 px-6 md:px-0 scroll-px-6 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
      {shsCultureGallery.map((item, index) => (
        <div class={`group relative overflow-hidden rounded-2xl shadow-sm cursor-pointer block h-[400px] md:h-full w-[85vw] md:w-auto shrink-0 snap-center md:snap-align-none ${index === 0 ? 'md:col-span-2 md:row-span-2' : 'md:col-span-1 md:row-span-1'}`}>
          <!-- Image Layer -->
          <img
            src={item.url}
            alt={item.alt}
            loading="lazy"
            decoding="async"
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105 z-0"
          />
          <!-- Gradient Overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-primary/95 via-primary/60 to-transparent opacity-100 md:opacity-80 group-hover:opacity-100 transition-opacity duration-500 z-10"></div>
          <!-- Text Payload Container -->
          <div class="absolute inset-0 z-20 p-6 md:p-8 flex flex-col justify-end overflow-hidden">
            <h3 class="text-xl md:text-2xl font-bold text-white mb-2 md:transform md:translate-y-8 group-hover:translate-y-0 transition-transform duration-500 ease-out">
              {item.title}
            </h3>
            <p class="text-slate-200 text-sm md:text-base leading-relaxed md:opacity-0 group-hover:opacity-100 md:transform md:translate-y-8 group-hover:translate-y-0 transition-all duration-500 delay-75 line-clamp-3">
              {item.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ==================== SECTION 4: ROI, Logistics & Security ==================== -->
  <section class="bg-primary text-white py-24">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-3xl font-black text-center mb-16">
        An Investment You Can Trust
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        {department?.keyFeatures && department.keyFeatures.length > 0 ? (
          department.keyFeatures.map((feature: any) => (
            <div>
              <h3 class="text-xl font-bold text-accent mb-3">
                {feature.title}
              </h3>
              <p class="text-slate-300 leading-relaxed">
                {feature.description}
              </p>
            </div>
          ))
        ) : (
          <>
            <!-- Card 1: Credibility -->
            <div>
              <h3 class="text-xl font-bold text-accent mb-3">
                Proven Track Record
              </h3>
              <p class="text-slate-300 leading-relaxed">
                Our graduates consistently pass top university entrance exams (UPCAT, ACET, DCAT). Our academic rigor ensures they don't just get accepted—they excel.
              </p>
            </div>

            <!-- Card 2: Financial Clarity -->
            <div>
              <h3 class="text-xl font-bold text-accent mb-3">
                Affordable & Voucher-Ready
              </h3>
              <p class="text-slate-300 leading-relaxed">
                We provide transparent tuition structures with minimal fees. OLOPSC proudly accepts DepEd SHS Vouchers and offers academic scholarships to make elite education accessible.
              </p>
            </div>

            <!-- Card 3: Safety -->
            <div>
              <h3 class="text-xl font-bold text-accent mb-3">
                Secure & Monitored Campus
              </h3>
              <p class="text-slate-300 leading-relaxed">
                While we foster independence, we never compromise on safety. From a strict anti-bullying policy to seamless digital grading portals for parents, you are always in the loop.
              </p>
            </div>
          </>
        )}
      </div>
    </div>
  </section>

  <!-- ==================== SECTION 5: The Transactional Anchor ==================== -->
  <section class="bg-surface py-20 text-center">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-3xl md:text-5xl font-black text-primary mb-6">
        {department?.admissionInfo?.title || "Ready to Start Your Journey?"}
      </h2>
      <p class="text-lg text-primary/80 font-medium mb-10">
        {department?.admissionInfo?.content || "The enrollment process is straightforward. Secure your slot for the upcoming academic year today."}
      </p>
      <CtaButton cta={{ text: "Start Enrollment Process", link: "/admissions", style: "primary" }} />
    </div>
  </section>

</Layout>
