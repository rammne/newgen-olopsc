---
import Layout from "../layouts/Layout.astro";
import { getScholarshipPage } from "../lib/sanity/queries";
import { getSanityImageUrl } from "../lib/utils/sanity";
import { PortableText } from "astro-portabletext";
import "../styles/global.css";

const pageData = await getScholarshipPage();

const pageTitle = pageData?.seo?.title || pageData?.title || "Scholarship Programs";
const pageDescription = pageData?.seo?.description || "Explore our scholarship programs and financial aid opportunities.";
const ogImage = pageData?.seo?.image?.asset?.url;

const defaultImages = [
    "https://images.unsplash.com/photo-1523240795612-9a054b0db644?q=80&w=800&auto=format&fit=crop",
    "https://images.unsplash.com/photo-1541339907198-e08756dedf3f?q=80&w=800&auto=format&fit=crop",
    "https://images.unsplash.com/photo-1524069290683-0457abfe42c3?q=80&w=800&auto=format&fit=crop"
];

const scholarships = pageData?.scholarshipPrograms?.length
    ? pageData.scholarshipPrograms.map((prog: any, i: number) => ({
        id: `scholarship-${i}`,
        name: prog.name,
        coverage: prog.coverage?.details || (prog.coverage?.percentage ? `${prog.coverage.percentage}% Discount` : "Full / Partial Coverage"),
        target: prog.type || "Incoming and Current Students",
        minGpa: prog.eligibility?.gpa || "85%",
        image: {
            url: prog.image?.asset?.url
                ? getSanityImageUrl(prog.image, { width: 800, height: 600, fit: "crop" })
                : defaultImages[i % defaultImages.length],
            alt: prog.image?.alt || prog.name
        },
        eligibility: prog.eligibility?.requirements?.length ? prog.eligibility.requirements : ["Must pass the entrance exam"],
        requirements: prog.documents?.length ? prog.documents : ["Completed Application Form", "2x2 ID Picture", "Photocopy of Report Card"],
        contact: prog.contact || null
    }))
    : [
        {
            id: "academic-valedictorian",
            name: "Valedictorian Scholarship",
            coverage: "100% Tuition Fee Discount",
            target: "Incoming Grade 11 & College Freshmen",
            minGpa: "95%+",
            image: { url: "https://images.unsplash.com/photo-1523240795612-9a054b0db644?q=80&w=800&auto=format&fit=crop", alt: "Students cheering" },
            eligibility: [
                "Must be the officially declared Valedictorian of the graduating batch.",
                "Must present a certification of rank from the Principal.",
                "Must pass the OLOPSC Scholarship Qualifying Examination.",
                "Must maintain a GPA of 1.50 or better every semester."
            ],
            requirements: [
                "Original copy of High School Report Card (Form 138)",
                "Certification of Valedictorian status signed by the Principal",
                "Two (2) copies of 2x2 ID picture",
                "Fully accomplished Scholarship Form"
            ]
        },
        {
            id: "academic-salutatorian",
            name: "Salutatorian Scholarship",
            coverage: "50% Tuition Fee Discount",
            target: "Incoming Grade 11 & College Freshmen",
            minGpa: "93%+",
            image: { url: "https://images.unsplash.com/photo-1541339907198-e08756dedf3f?q=80&w=800&auto=format&fit=crop", alt: "Graduation ceremony" },
            eligibility: [
                "Must be the officially declared Salutatorian of the graduating batch.",
                "Must present a certification of rank from the Principal.",
                "Must pass the OLOPSC Scholarship Qualifying Examination.",
                "Must maintain a GPA of 1.75 or better every semester."
            ],
            requirements: [
                "Original copy of High School Report Card (Form 138)",
                "Certification of Salutatorian status signed by the Principal",
                "Two (2) copies of 2x2 ID picture",
                "Fully accomplished Scholarship Form"
            ]
        },
        {
            id: "financial-aid",
            name: "OLOPSC Financial Grant",
            coverage: "Php 10,000 / Semester",
            target: "Current Students with Financial Need",
            minGpa: "85%+",
            image: { url: "https://images.unsplash.com/photo-1524069290683-0457abfe42c3?q=80&w=800&auto=format&fit=crop", alt: "Student studying in library" },
            eligibility: [
                "Must have a combined annual family income not exceeding Php 300,000.",
                "Must submit an Income Tax Return (ITR) or Certificate of Indigency.",
                "Must not be a recipient of any other major scholarship.",
                "Must maintain good moral character."
            ],
            requirements: [
                "Certificate of Indigency from Barangay or Parents' ITR",
                "Photocopy of latest Report Card",
                "Letter of request signed by parent/guardian",
                "Fully accomplished Financial Aid Form"
            ]
        }
    ];
---

<Layout title={pageTitle} description={pageDescription} ogImage={ogImage}>
    <!-- ==================== HERO SECTION ==================== -->
    <section class="relative bg-primary pt-32 pb-20 lg:pt-40 lg:pb-28 overflow-hidden">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-accent/20 via-primary to-primary pointer-events-none z-0"></div>

      <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
        <span class="inline-block py-1 px-3 rounded-full bg-white/10 border border-accent/50 text-accent font-bold uppercase tracking-widest text-xs mb-6 backdrop-blur-sm">Scholarship Programs</span>
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-black tracking-tight leading-[1.1] mb-6 text-white">Merit Meets <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-yellow-200">Opportunity.</span></h1>
        <p class="text-lg md:text-xl text-slate-300 leading-relaxed max-w-2xl mx-auto">Discover the pathways waiting for you. OLOPSC offers comprehensive scholarship programs to support driven, high-achieving students throughout their academic journey.</p>
      </div>
    </section>

    <!-- ==================== SCHOLARSHIP GRID ==================== -->
    <section class="py-24 bg-slate-50">
      <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 items-start">
        {scholarships.map((scholarship) => (
          <div class="bg-white rounded-3xl overflow-hidden shadow-lg border border-slate-100 flex flex-col">

            <div class="relative w-full h-48 bg-surface">
              <img src={scholarship.image.url} alt={scholarship.image.alt} class="w-full h-full object-cover" loading="lazy" />
              <div class="absolute top-4 left-4 bg-primary text-white text-xs font-black uppercase tracking-widest py-1.5 px-3 rounded-md shadow-md">Academic Excellence</div>
            </div>

            <div class="p-8 flex flex-col flex-grow">
              <h3 class="text-2xl font-black text-primary mb-4 leading-tight">{scholarship.name}</h3>
              <div class="bg-accent/10 border border-accent/20 text-yellow-700 font-bold text-sm py-2 px-4 rounded-lg mb-4">{scholarship.coverage}</div>
              <p class="text-slate-600 text-sm mb-6 pb-6 border-b border-slate-100">{scholarship.target}</p>

              <div class="flex justify-between items-center mb-6">
                <div class="flex flex-col">
                  <span class="text-xs font-bold text-slate-400 uppercase tracking-widest">Required</span>
                  <span class="text-lg font-black text-primary">Min. GPA {scholarship.minGpa}</span>
                </div>
              </div>

              <details class="group border border-slate-200 rounded-xl overflow-hidden mt-auto">
                <summary class="flex justify-between items-center font-bold cursor-pointer list-none p-4 bg-slate-50 text-primary hover:bg-slate-100 transition-colors">
                  <span>Eligibility & Requirements</span>
                  <span class="transition-transform group-open:rotate-180">&plus;</span>
                </summary>
                <div class="p-5 bg-white text-sm text-slate-600 border-t border-slate-200 space-y-6">
                  <div class="flex flex-col">
                    <h4 class="font-bold text-primary mb-3 text-xs uppercase tracking-widest bg-slate-50 self-start px-2 py-1 rounded">Qualifications</h4>
                    <ul class="list-none space-y-2">
                      {scholarship.eligibility.map((item: string) => (
                        <li class="flex gap-3"><span class="text-accent">&bull;</span> {item}</li>
                      ))}
                    </ul>
                  </div>
                  <div class="flex flex-col">
                    <h4 class="font-bold text-primary mb-3 text-xs uppercase tracking-widest bg-slate-50 self-start px-2 py-1 rounded">Required Documents</h4>
                    <ul class="list-none space-y-2">
                      {scholarship.requirements.map((item: string) => (
                        <li class="flex gap-3"><span class="text-accent">&bull;</span> {item}</li>
                      ))}
                    </ul>
                  </div>
                  {scholarship.contact && (
                    <div class="flex flex-col pt-4 border-t border-slate-100">
                      <h4 class="font-bold text-primary mb-3 text-xs uppercase tracking-widest bg-slate-50 self-start px-2 py-1 rounded">Contact Information</h4>
                      <ul class="list-none space-y-2">
                        {scholarship.contact.name && <li class="flex gap-3"><span class="text-slate-400 font-bold">Person:</span> {scholarship.contact.name}</li>}
                        {scholarship.contact.email && <li class="flex gap-3"><span class="text-slate-400 font-bold">Email:</span> <a href={`mailto:${scholarship.contact.email}`} class="text-primary hover:underline transition-colors">{scholarship.contact.email}</a></li>}
                        {scholarship.contact.phone && <li class="flex gap-3"><span class="text-slate-400 font-bold">Phone:</span> {scholarship.contact.phone}</li>}
                      </ul>
                    </div>
                  )}
                </div>
              </details>
            </div>

          </div>
        ))}
      </div>

    </section>

    <!-- ==================== APPLICATION PROTOCOL ==================== -->
    <section class="py-24 md:py-32 bg-primary relative overflow-hidden border-t border-slate-800">
      <div class="max-w-4xl mx-auto px-6 text-center mb-16 md:mb-24">
        <span class="inline-block py-1 px-3 rounded-full bg-white/10 border border-accent/50 text-accent font-bold uppercase tracking-widest text-xs mb-6">Next Steps</span>
        <h2 class="text-3xl md:text-5xl font-black tracking-tight text-white mb-6">How to Claim Your Scholarship.</h2>
        <p class="text-lg text-slate-300 leading-relaxed">Financial aid processing is strictly handled on-campus to ensure data privacy and immediate verification. Follow this 3-step protocol.</p>
      </div>

      <div class="max-w-6xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 relative z-10 mb-16">
        <div class="bg-white/5 border border-white/10 rounded-3xl p-8 relative">
          <div class="text-5xl font-black text-white/10 absolute top-4 right-6">01</div>
          <h3 class="text-xl font-bold text-white mb-4 relative z-10">Compile Requirements</h3>
          <p class="text-sm text-slate-300 leading-relaxed relative z-10">Expand the "Eligibility & Requirements" tab on your specific scholarship card above. Gather all required physical documents and photocopies into a secure folder before proceeding to the Registrar.</p>
        </div>

        <div class="bg-white/5 border border-white/10 rounded-3xl p-8 relative">
          <div class="text-5xl font-black text-white/10 absolute top-4 right-6">02</div>
          <h3 class="text-xl font-bold text-white mb-4 relative z-10">On-Site Submission</h3>
          <p class="text-sm text-slate-300 leading-relaxed relative z-10">Proceed directly to the OLOPSC Registrar's Office. Ensure your Scholarship Application Form is completely filled out and signed by a parent or guardian.</p>
        </div>

        <div class="bg-white/5 border border-white/10 rounded-3xl p-8 relative">
          <div class="text-5xl font-black text-white/10 absolute top-4 right-6">03</div>
          <h3 class="text-xl font-bold text-white mb-4 relative z-10">Verification & Approval</h3>
          <p class="text-sm text-slate-300 leading-relaxed relative z-10">The administration will review your academic standing and submitted documents. Approved scholars will receive official notification regarding tuition adjustments.</p>
        </div>
      </div>

      <div class="max-w-3xl mx-auto px-6 text-center">
        <div class="inline-flex flex-col md:flex-row items-center gap-4 md:gap-8 bg-black/30 border border-white/10 py-4 px-8 rounded-2xl">
          <div class="flex items-center gap-3">
            <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
            <span class="text-sm font-bold text-white uppercase tracking-widest">Registrar Hours</span>
          </div>
          <div class="hidden md:block w-px h-8 bg-white/20"></div>
          <div class="text-sm font-mono text-accent">Mon-Fri: 7:30 AM - 4:30 PM</div>
          <div class="hidden md:block text-slate-500">&bull;</div>
          <div class="text-sm font-mono text-accent">Sat: 8:00 AM - 12:00 PM</div>
        </div>
      </div>
    </section>
</Layout>
