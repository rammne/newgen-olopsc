---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/homepage/Hero.astro";
import FinalCta from "../components/homepage/FinalCta.astro";
import ScrollRevealWrapper from "../components/common/ScrollRevealWrapper.astro";
import IdentitySection from "../components/about/IdentitySection.astro";
import MissionVisionValues from "../components/about/MissionVisionValues.astro";
import TenPointAgenda from "../components/about/TenPointAgenda.astro";
import HistorySection from "../components/about/HistorySection.astro";
import LeadershipSection from "../components/about/LeadershipSection.astro";
import AccreditationsSection from "../components/about/AccreditationsSection.astro";
import { getAboutPage } from "../lib/sanity/queries";
import { getSanityImageUrl } from "../lib/utils/sanity";
import "../styles/global.css";

// Fetch about page data
const aboutPage = await getAboutPage();

// Set page title from SEO or default
const pageTitle = aboutPage?.seo?.title || aboutPage?.title || "About Us";
const pageDescription =
    aboutPage?.seo?.description ||
    "Learn more about OLOPSC history, mission, and vision.";
const ogImage = aboutPage?.seo?.image?.asset?.url;

const heroBackground = {
    url: aboutPage?.hero?.backgroundImage?.asset?.url
        ? getSanityImageUrl(aboutPage.hero.backgroundImage, { width: 1920, height: 1080, fit: "crop" })
        : "https://images.unsplash.com/photo-1541339907198-e08756dedf3f?q=80&w=1920&auto=format&fit=crop",
    alt: aboutPage?.hero?.backgroundImage?.alt ?? "Classic university library and academic heritage"
};

const identityMainImage = {
    url: aboutPage?.identity?.mainImage?.asset?.url
        ? getSanityImageUrl(aboutPage.identity.mainImage, { width: 800, height: 600, fit: "crop" })
        : "https://images.unsplash.com/photo-1541339907198-e08756dedf3f?q=80&w=800&auto=format&fit=crop",
    alt: aboutPage?.identity?.mainImage?.alt ?? "OLOPSC Main Campus Marikina"
};

const identitySubImage = {
    url: aboutPage?.identity?.subImage?.asset?.url
        ? getSanityImageUrl(aboutPage.identity.subImage, { width: 600, height: 600, fit: "crop" })
        : "https://images.unsplash.com/photo-1523240795612-9a054b0db644?q=80&w=600&auto=format&fit=crop",
    alt: aboutPage?.identity?.subImage?.alt ?? "OLOPSC Students Collaborating"
};
---

<Layout title={pageTitle} description={pageDescription} ogImage={ogImage}>
    <!-- ==================== NEW CUSTOM HERO ==================== -->
    <section class="relative bg-primary pt-32 pb-20 lg:pt-40 lg:pb-28 overflow-hidden">
      <!-- Background Image -->
      <img src={heroBackground.url} alt={heroBackground.alt} class="absolute inset-0 w-full h-full object-cover opacity-75 mix-blend-luminosity pointer-events-none" loading="eager" />

      <!-- Gradient Overlay -->
      <div class="absolute inset-0 bg-gradient-to-b from-primary/80 via-primary/90 to-primary z-0"></div>

      <!-- Ambient Glow (CSS Only) -->
      <div class="absolute top-0 left-1/2 w-[800px] h-[400px] bg-primary/20 rounded-full blur-[120px] -translate-x-1/2 -translate-y-1/2 pointer-events-none z-0"></div>

      <!-- Typography Payload & Trust Strip Container -->
      <div class="relative z-10 max-w-5xl mx-auto px-6 text-center">
        <!-- Subheading -->
        <span class="inline-block py-1 px-3 rounded-full bg-white/10 border border-accent/50 text-accent font-bold uppercase tracking-widest text-xs mb-8 backdrop-blur-sm">Founded 1978</span>

        <!-- H1 -->
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-black tracking-tight leading-[1.1] mb-8 text-white">A Legacy of <span class="text-transparent bg-clip-text bg-gradient-to-r from-white to-slate-300">Academic Excellence.</span></h1>

        <!-- Paragraph -->
        <p class="text-lg md:text-xl text-slate-200 leading-relaxed max-w-3xl mx-auto mb-16">We cultivate intellectual rigor, ethical leadership, and a lifelong passion for scholarly inquiry. OLOPSC stands as a premier non-sectarian institution, preparing the leaders of tomorrow through uncompromising academic standards.</p>

        <!-- The "By the Numbers" Trust Strip -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-0 max-w-4xl mx-auto bg-white/10 border border-white/20 rounded-2xl md:rounded-full p-8 md:p-4 backdrop-blur-md md:divide-x divide-white/20 shadow-2xl">

          <div class="flex flex-col items-center justify-center text-center px-4">
            <span class="text-4xl font-black text-accent mb-1 tracking-tighter">4,000+</span>
            <span class="text-xs font-bold text-slate-200 uppercase tracking-wider">Active Students</span>
          </div>

          <div class="flex flex-col items-center justify-center text-center px-4">
            <span class="text-4xl font-black text-white mb-1 tracking-tighter">45+</span>
            <span class="text-xs font-bold text-slate-200 uppercase tracking-wider">Years of Heritage</span>
          </div>

          <div class="flex flex-col items-center justify-center text-center px-4">
            <span class="text-4xl font-black text-primary bg-accent px-4 py-1 rounded-md mb-1 tracking-tighter shadow-sm">Level III</span>
            <span class="text-xs font-bold text-slate-200 uppercase tracking-wider">PAASCU Accredited</span>
          </div>

        </div>
      </div>
    </section>
    <!-- ==================== WHO WE ARE (IDENTITY) ==================== -->
    <section class="py-24 md:py-32 bg-white overflow-hidden">
      <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">

        <!-- Left Column: Typography & SEO Payload -->
        <div class="flex flex-col relative z-10">
          <span class="text-accent font-black tracking-widest uppercase text-xs mb-4">The OLOPSC Identity</span>
          <h2 class="text-3xl md:text-5xl font-black tracking-tight text-primary mb-6 leading-[1.1]">A Premier Private Education in Marikina City.</h2>
          <p class="text-lg text-slate-600 leading-relaxed mb-6">Founded in 1978, Our Lady of Perpetual Succor College (OLOPSC) is a premier, affordable non-sectarian educational institution. As one of the biggest co-educational private schools in Marikina City, we offer a seamless educational journey from preschool through senior high school, culminating in our CHED-recognized higher education division: the College of Business, Management, Science, and Education (BMSE).</p>
          <p class="text-lg text-slate-600 leading-relaxed mb-10">Every program is engineered for academic excellence, ensuring accessible, outcome-based learning that forms future-ready, socially responsible professionals.</p>

          <!-- <a href="#history" class="inline-flex items-center gap-2 text-primary font-bold hover:text-accent transition-colors group w-fit">
            <span>Explore Our History</span>
            <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a> -->
        </div>

        <!-- Right Column: Asymmetric Dual-Image Composition -->
        <div class="relative w-full aspect-square md:aspect-[4/3] lg:aspect-square flex items-center justify-center">

          <!-- Background Decorative Element -->
          <div class="absolute right-0 top-0 w-3/4 h-3/4 bg-surface rounded-3xl -z-10 translate-x-4 -translate-y-4"></div>

          <!-- Main Image (Back/Large) -->
          <div class="absolute left-0 bottom-12 w-[75%] aspect-[4/3] rounded-3xl overflow-hidden shadow-2xl border border-slate-100 z-10">
            <img src={identityMainImage.url} alt="OLOPSC Main Campus Marikina" class="w-full h-full object-cover" loading="lazy" />
          </div>

          <!-- Sub Image (Front/Small) -->
          <div class="absolute right-4 top-12 w-[50%] aspect-square rounded-3xl overflow-hidden shadow-2xl border-4 border-white z-20">
            <img src={identitySubImage.url} alt="OLOPSC Students Collaborating" class="w-full h-full object-cover" loading="lazy" />
          </div>

        </div>

      </div>
    </section>

    <!-- ==================== THE MANIFESTO (MISSION & VISION) ==================== -->
    <section class="bg-primary py-24 md:py-32 border-y border-slate-800">
      <div class="max-w-7xl mx-auto px-6">

        <!-- The Vision -->
        <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-16 mb-24 md:mb-32">
          <div class="md:col-span-3 flex md:justify-end border-b md:border-b-0 md:border-r border-white pb-4 md:pb-0 md:pr-8">
            <h3 class="text-accent font-black tracking-widest uppercase text-sm writing-mode-horizontal md:text-right">OLOPSC Vision 2026</h3>
          </div>
          <div class="md:col-span-9">
            <p class="text-3xl md:text-5xl lg:text-6xl font-black text-white leading-tight tracking-tight">Our Lady of Perpetual Succor College envisions itself as a <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-yellow-200">premier and caring educational institution</span>, developing values-driven, globally competent, and empowered learners who are equipped to lead with integrity and responsibility for a sustainable and peaceful society.</p>
          </div>
        </div>

        <!-- The Mission -->
        <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-16">
          <div class="md:col-span-3 flex md:justify-end border-b md:border-b-0 md:border-r border-white pb-4 md:pb-0 md:pr-8">
            <h3 class="text-accent font-black tracking-widest uppercase text-sm md:text-right">OLOPSC Mission 2026</h3>
          </div>
          <div class="md:col-span-9 max-w-4xl">
            <p class="text-xl md:text-2xl text-slate-300 font-medium leading-relaxed mb-8">OLOPSC commits to providing relevant, quality, and holistic education by:</p>
            <ul class="grid grid-cols-1 md:grid-cols-2 gap-6 text-slate-400 text-lg leading-relaxed">
              <li class="flex gap-4"><span class="text-accent text-2xl leading-none">&bull;</span> nurturing excellence and innovation through responsive, inclusive, and learner-centered education;</li>
              <li class="flex gap-4"><span class="text-accent text-2xl leading-none">&bull;</span> forming God-loving individuals guided by the Marian virtues of humility, obedience, and selfless service;</li>
              <li class="flex gap-4"><span class="text-accent text-2xl leading-none">&bull;</span> integrating our core institutional values into our daily life and culture;</li>
              <li class="flex gap-4"><span class="text-accent text-2xl leading-none">&bull;</span> advancing impact-driven research and social initiatives;</li>
              <li class="flex gap-4"><span class="text-accent text-2xl leading-none">&bull;</span> developing highly employable and globally competent graduates;</li>
              <li class="flex gap-4"><span class="text-accent text-2xl leading-none">&bull;</span> promoting environmental stewardship and sustainable development; and</li>
              <li class="flex gap-4"><span class="text-accent text-2xl leading-none">&bull;</span> strengthening governance and partnerships for institutional effectiveness.</li>
            </ul>
          </div>
        </div>

        <!-- The S-RICE Core Values -->
        <div class="mt-24 md:mt-32 pt-12 border-t border-white flex flex-wrap justify-center items-center gap-6 md:gap-12 opacity-60 hover:opacity-100 transition-opacity duration-500">
          <span class="text-sm md:text-base font-bold text-white uppercase tracking-widest">Spirituality</span>
          <span class="text-accent text-2xl leading-none">&bull;</span>
          <span class="text-sm md:text-base font-bold text-white uppercase tracking-widest">Responsibility</span>
          <span class="text-accent text-2xl leading-none">&bull;</span>
          <span class="text-sm md:text-base font-bold text-white uppercase tracking-widest">Integrity</span>
          <span class="text-accent text-2xl leading-none">&bull;</span>
          <span class="text-sm md:text-base font-bold text-white uppercase tracking-widest">Caring Culture</span>
          <span class="text-accent text-2xl leading-none">&bull;</span>
          <span class="text-sm md:text-base font-bold text-white uppercase tracking-widest">Excellence</span>
        </div>

      </div>
    </section>

    <!-- ==================== 10-POINT STRATEGIC AGENDA ==================== -->
    <section class="bg-surface py-24 md:py-32 relative">
      <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-24 relative">

        <!-- Left Column: The Sticky Anchor -->
        <div class="lg:col-span-5 relative h-full">
          <div class="sticky top-32 flex flex-col">
            <span class="text-accent font-black tracking-widest uppercase text-xs mb-4">Strategic Roadmap</span>
            <h2 class="text-3xl md:text-5xl font-black tracking-tight text-primary mb-6 leading-[1.1]">The 10-Point Agenda</h2>
            <p class="text-lg text-slate-600 leading-relaxed">Explore our strategic roadmap that outlines our uncompromising commitment to educational excellence, innovation, and community engagement. This is the foundation for the future of OLOPSC.</p>
          </div>
        </div>

        <!-- Right Column: The Scrolling Ledger -->
        <div class="lg:col-span-7 flex flex-col">
          <div class="group relative py-8 md:py-10 border-b border-slate-200 flex items-center gap-8 md:gap-12 hover:bg-white transition-colors duration-300 px-6 -mx-6 rounded-2xl">
            <div class="text-5xl md:text-6xl font-black text-slate-200 group-hover:text-accent transition-colors duration-500 shrink-0 w-16 text-right font-mono tracking-tighter">01</div>
            <h3 class="text-xl md:text-2xl font-bold text-primary leading-tight group-hover:translate-x-2 transition-transform duration-300">Excellence in Instruction</h3>
          </div>

          <div class="group relative py-8 md:py-10 border-b border-slate-200 flex items-center gap-8 md:gap-12 hover:bg-white transition-colors duration-300 px-6 -mx-6 rounded-2xl">
            <div class="text-5xl md:text-6xl font-black text-slate-200 group-hover:text-accent transition-colors duration-500 shrink-0 w-16 text-right font-mono tracking-tighter">02</div>
            <h3 class="text-xl md:text-2xl font-bold text-primary leading-tight group-hover:translate-x-2 transition-transform duration-300">Pursuit of Quality Assurance & Effective Systems</h3>
          </div>

          <div class="group relative py-8 md:py-10 border-b border-slate-200 flex items-center gap-8 md:gap-12 hover:bg-white transition-colors duration-300 px-6 -mx-6 rounded-2xl">
            <div class="text-5xl md:text-6xl font-black text-slate-200 group-hover:text-accent transition-colors duration-500 shrink-0 w-16 text-right font-mono tracking-tighter">03</div>
            <h3 class="text-xl md:text-2xl font-bold text-primary leading-tight group-hover:translate-x-2 transition-transform duration-300">Strengthened Support Systems for Teaching, Learning & Research</h3>
          </div>

          <div class="group relative py-8 md:py-10 border-b border-slate-200 flex items-center gap-8 md:gap-12 hover:bg-white transition-colors duration-300 px-6 -mx-6 rounded-2xl">
            <div class="text-5xl md:text-6xl font-black text-slate-200 group-hover:text-accent transition-colors duration-500 shrink-0 w-16 text-right font-mono tracking-tighter">04</div>
            <h3 class="text-xl md:text-2xl font-bold text-primary leading-tight group-hover:translate-x-2 transition-transform duration-300">Robust Research and Extension Programs</h3>
          </div>

          <div class="group relative py-8 md:py-10 border-b border-slate-200 flex items-center gap-8 md:gap-12 hover:bg-white transition-colors duration-300 px-6 -mx-6 rounded-2xl">
            <div class="text-5xl md:text-6xl font-black text-slate-200 group-hover:text-accent transition-colors duration-500 shrink-0 w-16 text-right font-mono tracking-tighter">05</div>
            <h3 class="text-xl md:text-2xl font-bold text-primary leading-tight group-hover:translate-x-2 transition-transform duration-300">Strengthened Local & International Linkage Programs</h3>
          </div>

          <div class="group relative py-8 md:py-10 border-b border-slate-200 flex items-center gap-8 md:gap-12 hover:bg-white transition-colors duration-300 px-6 -mx-6 rounded-2xl">
            <div class="text-5xl md:text-6xl font-black text-slate-200 group-hover:text-accent transition-colors duration-500 shrink-0 w-16 text-right font-mono tracking-tighter">06</div>
            <h3 class="text-xl md:text-2xl font-bold text-primary leading-tight group-hover:translate-x-2 transition-transform duration-300">Creative Resource Generation & Reliable Resource Management</h3>
          </div>

          <div class="group relative py-8 md:py-10 border-b border-slate-200 flex items-center gap-8 md:gap-12 hover:bg-white transition-colors duration-300 px-6 -mx-6 rounded-2xl">
            <div class="text-5xl md:text-6xl font-black text-slate-200 group-hover:text-accent transition-colors duration-500 shrink-0 w-16 text-right font-mono tracking-tighter">07</div>
            <h3 class="text-xl md:text-2xl font-bold text-primary leading-tight group-hover:translate-x-2 transition-transform duration-300">Modernization & Expansion of Physical, Instructional & ICT Facilities</h3>
          </div>

          <div class="group relative py-8 md:py-10 border-b border-slate-200 flex items-center gap-8 md:gap-12 hover:bg-white transition-colors duration-300 px-6 -mx-6 rounded-2xl">
            <div class="text-5xl md:text-6xl font-black text-slate-200 group-hover:text-accent transition-colors duration-500 shrink-0 w-16 text-right font-mono tracking-tighter">08</div>
            <h3 class="text-xl md:text-2xl font-bold text-primary leading-tight group-hover:translate-x-2 transition-transform duration-300">Strong Promotion of Student Affairs, Welfare & Success</h3>
          </div>

          <div class="group relative py-8 md:py-10 border-b border-slate-200 flex items-center gap-8 md:gap-12 hover:bg-white transition-colors duration-300 px-6 -mx-6 rounded-2xl">
            <div class="text-5xl md:text-6xl font-black text-slate-100 group-hover:text-accent transition-colors duration-500 shrink-0 w-16 text-right font-mono tracking-tighter">09</div>
            <h3 class="text-xl md:text-2xl font-bold text-primary leading-tight group-hover:translate-x-2 transition-transform duration-300">A Model School for Environmental Sustainability</h3>
          </div>

          <div class="group relative py-8 md:py-10 border-b border-slate-200 flex items-center gap-8 md:gap-12 hover:bg-white transition-colors duration-300 px-6 -mx-6 rounded-2xl">
            <div class="text-5xl md:text-6xl font-black text-slate-200 group-hover:text-accent transition-colors duration-500 shrink-0 w-16 text-right font-mono tracking-tighter">10</div>
            <h3 class="text-xl md:text-2xl font-bold text-primary leading-tight group-hover:translate-x-2 transition-transform duration-300">Enhanced Human Resource & Organizational Development</h3>
          </div>
        </div>

      </div>
    </section>

    {
        aboutPage?.history && (
            <HistorySection history={aboutPage.history} />
        )
    }

    {
        aboutPage?.leadership && (
            <ScrollRevealWrapper direction="up" delay={0.1}>
                <LeadershipSection leadership={aboutPage.leadership} />
            </ScrollRevealWrapper>
        )
    }

    {
        aboutPage?.accreditations && (
            <ScrollRevealWrapper direction="up" delay={0.1}>
                <AccreditationsSection
                    accreditations={aboutPage.accreditations}
                />
            </ScrollRevealWrapper>
        )
    }

    {
        aboutPage?.cta && (
            <ScrollRevealWrapper direction="fade" delay={0.1}>
                {/* Reusing FinalCta but mapping the single CTA object to what FinalCta expects or using it as Primary CTA */}
                <FinalCta
                    finalCta={{
                        headline: "Join the OLOPSC Community",
                        subheadline:
                            "Be part of our growing family aimed at excellence.",
                        primaryCta: aboutPage.cta,
                        backgroundImage: aboutPage.hero?.backgroundImage, // Fallback to hero image if needed, or specific one
                    }}
                />
            </ScrollRevealWrapper>
        )
    }
</Layout>
