          <div class="absolute inset-0 bg-gradient-to-t from-primary/90 via-primary/40 to-transparent z-10"></div>
          <div class="relative z-20">
            <span class="text-accent font-bold text-xs uppercase tracking-widest mb-2 block">Media & Discourse</span>
            <h3 class="text-xl md:text-2xl font-black text-white mb-2 leading-tight">The Literary & Publishing Workstation</h3>
