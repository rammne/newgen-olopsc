---
import Layout from "../../layouts/Layout.astro";
import ScrollRevealWrapper from "../../components/common/ScrollRevealWrapper.astro";
import sdg4 from "../../assets/sdg-icons/sdg-4.jpg";
import sdg5 from "../../assets/sdg-icons/sdg-5.jpg";
import sdg10 from "../../assets/sdg-icons/sdg-10.jpg";
import sdg16 from "../../assets/sdg-icons/sdg-16.jpg";
import CtaButton from "../../components/common/CtaButton.astro";
import { getEducationLiberalArtsPage } from "../../lib/sanity/queries";
import { getSanityImageUrl } from "../../lib/utils/sanity";

const pageData = await getEducationLiberalArtsPage();

const heroBackground = {
  url: pageData?.heroBackground?.asset?.url
    ? getSanityImageUrl(pageData.heroBackground, { width: 1920, height: 1080, fit: "crop" })
    : "https://images.unsplash.com/photo-1524178232363-1fb2b075b655?q=80&w=1200&auto=format&fit=crop",
  alt: pageData?.heroBackground?.alt || "Education and Liberal Arts Interactive Classroom"
};

const quickFacts = {
  duration: pageData?.quickFacts?.duration || "4 Years",
  units: pageData?.quickFacts?.units || "145+ Units",
  format: pageData?.quickFacts?.format || "On-Campus & Teaching Practicum"
};

const tracks = pageData?.tracks && pageData.tracks.length > 0
  ? pageData.tracks
  : [
      { title: "Elementary Education", subtitle: "BEED", description: "Learn how to teach young children, understand child psychology, and create a fun, effective learning environment." },
      { title: "Secondary Education (Mathematics)", subtitle: "BSED Mathematics", description: "Gain the skills to teach math effectively to high school students and help them succeed in their academics." },
      { title: "Secondary Education (English)", subtitle: "BSED English", description: "Discover how to teach English, literature, and communication skills to high school students." },
      { title: "English Language", subtitle: "BAEL", description: "Develop excellent communication and writing skills perfect for careers in media, writing, and public relations." }
    ];

const overviewMainImage = {
  url: pageData?.overviewMainImage?.asset?.url
    ? getSanityImageUrl(pageData.overviewMainImage, { width: 800, height: 600, fit: "crop" })
    : "https://images.unsplash.com/photo-1577896851231-70ef18881754?q=80&w=800&auto=format&fit=crop",
  alt: pageData?.overviewMainImage?.alt || "Educational Leadership and Pedagogy"
};

const overviewSubImage = {
  url: pageData?.overviewSubImage?.asset?.url
    ? getSanityImageUrl(pageData.overviewSubImage, { width: 800, height: 600, fit: "crop" })
    : "https://images.unsplash.com/photo-1522202176988-66273c2fd55f?q=80&w=800&auto=format&fit=crop",
  alt: pageData?.overviewSubImage?.alt || "Advanced Linguistics and Communication"
};

const outcomes = pageData?.outcomes && pageData.outcomes.length > 0
  ? pageData.outcomes
  : [
      { title: "Teaching Young Learners (BEED)", description: "Learn the best ways to teach young children, understand how they learn, and make a positive impact in their early years." },
      { title: "High School Teaching (BSED)", description: "Gain the confidence to manage a classroom and effectively teach specific subjects like Math or English to teenagers." },
      { title: "Effective Communication (BAEL)", description: "Develop strong writing, speaking, and analytical skills for careers in journalism, corporate communication, and media." },
      { title: "Educational Leadership", description: "Learn how to design effective lessons, improve student learning, and prepare for leadership roles in schools." }
    ];

const curriculumTracks = pageData?.curriculumTracks && pageData.curriculumTracks.length > 0
  ? pageData.curriculumTracks
  : [
      {
        id: "beed",
        name: "BEED (Elementary)",
        roadmap: [
          { year: "Year 1", title: "Foundations of Pedagogy", subjects: ["Child & Adolescent Development", "The Teaching Profession", "Foundations of Special Needs Ed."] },
          { year: "Year 2", title: "Instructional Methodologies", subjects: ["Teaching Math in Primary Grades", "Early Literacy", "Assessment in Learning 1."] },
          { year: "Year 3", title: "Curriculum & Technology", subjects: ["Technology for Teaching", "Curriculum Development", "Educational Research."] },
          { year: "Year 4", title: "Clinical Practice", subjects: ["Field Study 1 & 2", "Teaching Internship", "LET Intensive Review."] }
        ]
      },
      {
        id: "bsed-english",
        name: "BSED (English)",
        roadmap: [
          { year: "Year 1", title: "Language Foundations", subjects: [
              "[1st Sem] The Child Adolescent Learner and Learning Principles",
              "[1st Sem] Foundations of Special and Inclusive Education",
              "[1st Sem] Introduction to Linguistics",
              "[1st Sem] Language, Culture, and Society",
              "[2nd Sem] Building and Enhancing New Literacies Across the Curriculum",
              "[2nd Sem] Facilitating Learner-Centered Teaching",
              "[2nd Sem] Structures of English",
              "[2nd Sem] Literary Criticism"
          ] },
          { year: "Year 2", title: "Pedagogical Methodologies", subjects: [
              "[1st Sem] Technology for Teaching and Learning 1",
              "[1st Sem] Principles and Theories of Language Acquisition and Learning",
              "[1st Sem] Teaching and Assessment of the Macroskills",
              "[1st Sem] Teaching and Assessment of the Literature Studies",
              "[2nd Sem] The Teacher and the School Curriculum",
              "[2nd Sem] Technology for Teaching and Learning 2 (Secondary Language Education)",
              "[2nd Sem] Technical Writing",
              "[2nd Sem] Teaching and Assessment of Grammar"
          ] },
          { year: "Year 3", title: "Advanced Literature & Assessment", subjects: [
              "[1st Sem] Assessment of Student Learning 1",
              "[1st Sem] Special Topic/Elective (x2)",
              "[1st Sem] Children and Adolescent Literature",
              "[1st Sem] Lang. Programs and Policies in Multilingual Societies",
              "[1st Sem] Language Learning Materials Development",
              "[1st Sem] Mythology and Folklore",
              "[2nd Sem] Assessment of Student Learning 2",
              "[2nd Sem] The Teaching Profession",
              "[2nd Sem] The Teacher and the Community, School Culture and Organizational Leadership",
              "[2nd Sem] Language Education Research",
              "[2nd Sem] Contemporary Popular and Emergent Literature",
              "[2nd Sem] Speech and Stage Arts",
              "[2nd Sem] Field Study 1"
          ] },
          { year: "Year 4", title: "Clinical Practice & Internship", subjects: [
              "[1st Sem] Survey of Philippine Literature in English",
              "[1st Sem] Survey of English and American Literature",
              "[1st Sem] Survey of Afro-Asian Literature",
              "[1st Sem] Campus Journalism",
              "[1st Sem] Field Study 2",
              "[2nd Sem] Teaching Internship"
          ] }
        ]
      },
      {
        id: "bsed-math",
        name: "BSED (Mathematics)",
        roadmap: [
          { year: "Year 1", title: "Mathematical Foundations", subjects: [
              "[1st Sem] The Child Adolescent Learner and Learning Principles",
              "[1st Sem] Foundations of Special and Inclusive Education",
              "[1st Sem] History of Mathematics",
              "[1st Sem] College and Advance Algebra",
              "[2nd Sem] Building and Enhancing New Literacies Across the Curriculum",
              "[2nd Sem] Facilitating Learner-Centered Teaching",
              "[2nd Sem] Plane and Solid Geometry",
              "[2nd Sem] Logic and Set Theory"
          ] },
          { year: "Year 2", title: "Advanced Calculus & Geometry", subjects: [
              "[1st Sem] Technology for Teaching and Learning 1",
              "[1st Sem] Trigonometry",
              "[1st Sem] Abstract Algebra",
              "[1st Sem] Linear Algebra",
              "[2nd Sem] The Teacher and the School Curriculum",
              "[2nd Sem] Technology for Teaching and Learning 2 (Instrumentation & Technology in Mathematics)",
              "[2nd Sem] Modern Geometry",
              "[2nd Sem] Calculus I with Analytic Geometry"
          ] },
          { year: "Year 3", title: "Statistical Modeling & Assessment", subjects: [
              "[1st Sem] Assessment of Student Learning 1",
              "[1st Sem] Special Topic/Elective (x2)",
              "[1st Sem] Number Theory",
              "[1st Sem] Elementary Statistics and Probability",
              "[1st Sem] Calculus II",
              "[1st Sem] Problem Solving, Math Investigation and Modelling",
              "[2nd Sem] Assessment of Student Learning 2",
              "[2nd Sem] The Teaching Profession",
              "[2nd Sem] The Teacher and the Community, School Culture and Organizational Leadership",
              "[2nd Sem] Advance Statistics",
              "[2nd Sem] Research in Mathematics",
              "[2nd Sem] Field Study 1"
          ] },
          { year: "Year 4", title: "Clinical Practice & Internship", subjects: [
              "[1st Sem] Calculus III",
              "[1st Sem] Mathematics of Investment",
              "[1st Sem] Principles & Strategies in Teaching Mathematics",
              "[1st Sem] Assessment and Evaluation in Mathematics",
              "[1st Sem] Field Study 2",
              "[2nd Sem] Teaching Internship"
          ] }
        ]
      },
      {
        id: "bael",
        name: "BAEL (English Language)",
        roadmap: [
          { year: "Year 1", title: "Linguistic Foundations", subjects: ["Intro to Linguistics", "Structure of English", "History of the English Language."] },
          { year: "Year 2", title: "Advanced Syntax & Semantics", subjects: ["Phonetics & Phonology", "Semantics & Pragmatics", "Language & Society."] },
          { year: "Year 3", title: "Corporate & Media Communication", subjects: ["Technical Writing", "Discourse Analysis", "English for Specific Purposes."] },
          { year: "Year 4", title: "Research & Practicum", subjects: ["Linguistic Research", "Corporate Practicum (OJT)", "Translation & Editing."] }
        ]
      }
    ];

const ecosystemImages = {
  modelClassroom: {
    url: pageData?.ecosystemImages?.modelClassroom?.asset?.url
      ? getSanityImageUrl(pageData.ecosystemImages.modelClassroom, { width: 1200, height: 800, fit: "crop" })
      : "https://images.unsplash.com/photo-1577896851231-70ef18881754?q=80&w=1200&auto=format&fit=crop",
    alt: pageData?.ecosystemImages?.modelClassroom?.alt || "Interactive Model Classroom"
  },
  speechLab: {
    url: pageData?.ecosystemImages?.speechLab?.asset?.url
      ? getSanityImageUrl(pageData.ecosystemImages.speechLab, { width: 800, height: 800, fit: "crop" })
      : "https://images.unsplash.com/photo-1590402494682-bf346f4c97bb?q=80&w=800&auto=format&fit=crop",
    alt: pageData?.ecosystemImages?.speechLab?.alt || "Digital Phonetics & Speech Suite"
  },
  literacyHub: {
    url: pageData?.ecosystemImages?.literacyHub?.asset?.url
      ? getSanityImageUrl(pageData.ecosystemImages.literacyHub, { width: 800, height: 800, fit: "crop" })
      : "https://images.unsplash.com/photo-1522202176988-66273c2fd55f?q=80&w=800&auto=format&fit=crop",
    alt: pageData?.ecosystemImages?.literacyHub?.alt || "The Literary & Publishing Workstation"
  },
  resourceCenter: {
    url: pageData?.ecosystemImages?.resourceCenter?.asset?.url
      ? getSanityImageUrl(pageData.ecosystemImages.resourceCenter, { width: 800, height: 800, fit: "crop" })
      : "https://images.unsplash.com/photo-1588534510807-86dfb5ed5d5b?q=80&w=800&auto=format&fit=crop",
    alt: pageData?.ecosystemImages?.resourceCenter?.alt || "Curriculum Design & Media Lab"
  }
};

const chair = pageData?.chair || {
  name: "Dr. Maria Santos",
  title: "Program Chair, Education & Liberal Arts",
  credentials: "Ed.D, MA in Education",
  quote: "Teaching is about inspiring the next generation and making a real difference in their lives. Our goal is to guide students to become passionate, effective teachers and excellent communicators who are ready to change the world.",
  image: { url: "https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?q=80&w=600&auto=format&fit=crop", alt: "Program Chair" }
};

if (pageData?.chair?.image?.asset?.url) {
  chair.image = {
    url: getSanityImageUrl(pageData.chair.image, { width: 800, height: 1000, fit: "crop" }),
    alt: pageData.chair.image.alt || chair.name
  };
}

const faculty = pageData?.faculty && pageData.faculty.length > 0
  ? pageData.faculty.map((f: any) => ({
      ...f,
      image: {
        url: f.image?.asset?.url ? getSanityImageUrl(f.image, { width: 600, height: 800, fit: "crop" }) : "https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?q=80&w=600&auto=format&fit=crop",
        alt: f.image?.alt || f.name
      }
    }))
  : [
      { name: "Eleanor Rigby", specialty: "Early Childhood Pedagogy", credentials: "MA in Early Childhood Education", image: { url: "https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?q=80&w=600&auto=format&fit=crop", alt: "Faculty" } },
      { name: "John Keating", specialty: "Secondary Curriculum Strategy", credentials: "PhD in Education", image: { url: "https://images.unsplash.com/photo-1560250097-0b93528c311a?q=80&w=600&auto=format&fit=crop", alt: "Faculty" } },
      { name: "Henry Higgins", specialty: "Applied Linguistics & Syntax", credentials: "PhD in Linguistics", image: { url: "https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?q=80&w=600&auto=format&fit=crop", alt: "Faculty" } },
      { name: "Anne Sullivan", specialty: "Special Needs Education", credentials: "MA in Special Education", image: { url: "https://images.unsplash.com/photo-1580489944761-15a19d654956?q=80&w=600&auto=format&fit=crop", alt: "Faculty" } }
    ];

const pathways = pageData?.pathways && pageData.pathways.length > 0
  ? pageData.pathways
  : [
      {
        title: "Elementary Teaching",
        subtitle: "BEED Career Path",
        description: "Help children develop a love for learning in their early years. Create fun, engaging, and supportive classrooms for young students.",
        roles: ["Elementary School Teacher", "Early Childhood Educator", "School Administrator", "Private Tutor"]
      },
      {
        title: "High School Teaching (Mathematics)",
        subtitle: "BSED Math Career Path",
        description: "Make math easy to understand for high school students. Help teenagers develop problem-solving skills they can use in life.",
        roles: ["High School Math Teacher", "Curriculum Developer", "School Administrator", "Math Tutor"]
      },
      {
        title: "High School Teaching (English)",
        subtitle: "BSED English Career Path",
        description: "Inspire high school students to read, write, and express themselves effectively. Guide them to become better communicators.",
        roles: ["High School English Teacher", "Curriculum Developer", "School Administrator", "Language Instructor"]
      },
      {
        title: "Professional Communication",
        subtitle: "BAEL Career Path",
        description: "Use your advanced English skills for careers outside the classroom. Work in media, writing, public relations, or corporate communications.",
        roles: ["Public Relations Officer", "Writer / Editor", "Corporate Communications Specialist", "ESL Teacher"]
      }
    ];

const pageTitle = pageData?.seo?.title || "College of Education & Liberal Arts in Marikina, Metro Manila | OLOPSC College of BMSE";
const pageDescription = pageData?.seo?.description || "Become a Teacher or Communication Expert. Pursue degrees in Elementary Education, Secondary Education, and English Language at OLOPSC College of BMSE in Marikina, Metro Manila.";

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Course",
      "name": "Bachelor of Elementary Education",
      "description": "Master foundational pedagogy and child psychology for early learning environments at OLOPSC College of BMSE in Marikina, Metro Manila.",
      "provider": {
        "@type": "CollegeOrUniversity",
        "name": "OLOPSC College of BMSE",
        "sameAs": "https://www.olopsc.edu.ph"
      }
    },
    {
      "@type": "Course",
      "name": "Bachelor of Secondary Education major in Mathematics",
      "description": "Command advanced mathematical principles and adolescent development to lead high school quantitative classrooms at OLOPSC College of BMSE in Marikina, Metro Manila.",
      "provider": {
        "@type": "CollegeOrUniversity",
        "name": "OLOPSC College of BMSE",
        "sameAs": "https://www.olopsc.edu.ph"
      }
    },
    {
      "@type": "Course",
      "name": "Bachelor of Secondary Education major in English",
      "description": "Master language acquisition, literature, and pedagogical strategies to lead high school English classrooms at OLOPSC College of BMSE in Marikina, Metro Manila.",
      "provider": {
        "@type": "CollegeOrUniversity",
        "name": "OLOPSC College of BMSE",
        "sameAs": "https://www.olopsc.edu.ph"
      }
    },
    {
      "@type": "Course",
      "name": "Bachelor of Arts in English Language",
      "description": "Master advanced linguistics, corporate communication, and structural syntax for global media and publishing at OLOPSC College of BMSE in Marikina, Metro Manila.",
      "provider": {
        "@type": "CollegeOrUniversity",
        "name": "OLOPSC College of BMSE",
        "sameAs": "https://www.olopsc.edu.ph"
      }
    }
  ]
};
const schemaString = JSON.stringify(schema);
---

<Layout title={pageTitle} description={pageDescription} additionalSchema={schemaString}>
  <!-- Hero Section -->
  <section class="relative bg-primary pt-32 pb-24 lg:pt-40 lg:pb-32 overflow-hidden border-b border-slate-800">
    <div class="absolute inset-0 bg-gradient-to-r from-primary via-primary/95 to-transparent z-0"></div>
    <img src={heroBackground.url} alt={heroBackground.alt} class="absolute inset-y-0 right-0 w-full lg:w-[75%] h-full object-cover opacity-40 md:opacity-60 z-0" style="mask-image: linear-gradient(to right, transparent, black 40%); -webkit-mask-image: linear-gradient(to right, transparent, black 40%);" loading="eager" />

    <ScrollRevealWrapper animation="slide-up" class="relative z-10 max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-12">
      <div class="lg:col-span-7 flex flex-col">
        <h2 class="inline-block self-start py-1 px-3 rounded-full bg-white/10 border border-accent/50 text-accent font-bold uppercase tracking-widest text-xs mb-6 backdrop-blur-sm">College of BMSE &bull; Bachelor's Degrees</h2>
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-black tracking-tight leading-[1.1] mb-6 text-white">Inspire Students. <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-yellow-200">Master English.</span></h1>
        <p class="text-lg md:text-xl text-slate-300 leading-relaxed max-w-2xl mb-10">As a core part of the College of Business, Management, Science, and Education (BMSE), this department offers specialized degrees in Elementary Education, Secondary Education, and the English Language. We will guide you to become an inspiring teacher or an effective communication professional.</p>
        <div class="flex flex-wrap gap-4">
          <CtaButton cta={{ text: "Explore Curriculum", link: { type: "anchor", anchor: "curriculum" } }} variant="primary" />
          <CtaButton cta={{ text: "View Career Opportunities", link: { type: "anchor", anchor: "outcomes" } }} variant="secondary" />
        </div>
      </div>
    </ScrollRevealWrapper>
  </section>

  <!-- Quick Facts Strip -->
  <div class="bg-surface border-b border-slate-200 relative z-20 shadow-sm">
    <ScrollRevealWrapper direction="fade" delay={0.2} class="max-w-7xl mx-auto px-6 py-8 grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-0 md:divide-x divide-slate-200">

      <!-- Fact 1: Degree Options -->
      <div class="flex flex-col items-center text-center px-4">
        <span class="text-slate-400 mb-2"><svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222" /></svg></span>
        <span class="text-xl font-black text-primary tracking-tight">BEED &bull; BSED &bull; BAEL</span>
        <span class="text-xs font-bold text-slate-500 uppercase tracking-wider mt-1">Specialized Tracks</span>
      </div>

      <!-- Fact 2: Duration -->
      <div class="flex flex-col items-center text-center px-4">
        <span class="text-slate-400 mb-2"><svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></span>
        <span class="text-xl font-black text-primary tracking-tight">{quickFacts.duration || '4 Years'}</span>
        <span class="text-xs font-bold text-slate-500 uppercase tracking-wider mt-1">Standard Completion</span>
      </div>

      <!-- Fact 3: Workload -->
      <div class="flex flex-col items-center text-center px-4">
        <span class="text-slate-400 mb-2"><svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg></span>
        <span class="text-xl font-black text-primary tracking-tight">{quickFacts.units || '145+ Units'}</span>
        <span class="text-xs font-bold text-slate-500 uppercase tracking-wider mt-1">Average Academic Load</span>
      </div>

      <!-- Fact 4: Format -->
      <div class="flex flex-col items-center text-center px-4">
        <span class="text-slate-400 mb-2"><svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg></span>
        <span class="text-xl font-black text-primary tracking-tight">{quickFacts.format || 'On-Campus & Teaching Practicum'}</span>
        <span class="text-xs font-bold text-slate-500 uppercase tracking-wider mt-1">Learning Format</span>
      </div>

    </ScrollRevealWrapper>
  </div>

  <div class="bg-white border-b border-slate-100 relative z-20">
    <div class="max-w-7xl mx-auto px-6 py-5 flex flex-col sm:flex-row items-center justify-center gap-4">
      <span class="text-xs font-bold text-slate-400 uppercase tracking-widest shrink-0">SDG Commitment</span>
      <div class="flex items-center gap-3">
        <img src={sdg4.src} alt="SDG 4: Quality Education" class="w-12 h-12 rounded-lg shadow-sm border border-slate-100 hover:scale-110 transition-transform" />
        <img src={sdg5.src} alt="SDG 5: Gender Equality" class="w-12 h-12 rounded-lg shadow-sm border border-slate-100 hover:scale-110 transition-transform" />
        <img src={sdg10.src} alt="SDG 10: Reduced Inequalities" class="w-12 h-12 rounded-lg shadow-sm border border-slate-100 hover:scale-110 transition-transform" />
        <img src={sdg16.src} alt="SDG 16: Peace, Justice and Strong Institutions" class="w-12 h-12 rounded-lg shadow-sm border border-slate-100 hover:scale-110 transition-transform" />
      </div>
    </div>
  </div>

  <!-- Degree Tracks Matrix -->
  <section id="programs" class="py-16 md:py-24 bg-primary relative border-b border-slate-800">
    <ScrollRevealWrapper animation="slide-up">
      <div class="max-w-7xl mx-auto px-6 mb-12 text-center">
        <span class="text-accent font-black tracking-widest uppercase text-xs mb-4 inline-block">Our Programs</span>
        <h2 class="text-3xl md:text-4xl font-black tracking-tight text-white">Choose Your Path to Success.</h2>
      </div>

      <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-6">
        {tracks.map((track: any) => (
          <div class="bg-white/5 border border-white/10 rounded-2xl p-8 backdrop-blur-sm hover:bg-white/10 transition-colors duration-300 flex flex-col">
            <span class="text-accent font-bold text-xs uppercase tracking-widest mb-3">{track.subtitle}</span>
            <h3 class="text-2xl font-black text-white mb-4 leading-tight">{track.title}</h3>
            <p class="text-slate-300 text-sm leading-relaxed">{track.description}</p>
          </div>
        ))}
      </div>
    </ScrollRevealWrapper>
  </section>

  <!-- Program Overview -->
  <section class="py-24 md:py-32 bg-white overflow-hidden">
    <ScrollRevealWrapper animation="slide-left" class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">

      <!-- Left Column: Typography & Department Payload -->
      <div class="flex flex-col relative z-10">
        <span class="text-accent font-black tracking-widest uppercase text-xs mb-4">Program Overview</span>
        <h2 class="text-3xl md:text-5xl font-black tracking-tight text-primary mb-6 leading-[1.1]">Learn to Teach and Communicate.</h2>
