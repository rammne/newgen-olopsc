---
import Layout from "../../layouts/Layout.astro";
import CtaButton from "../../components/common/CtaButton.astro";
import ScrollRevealWrapper from "../../components/common/ScrollRevealWrapper.astro";
import "../../styles/global.css";

import { getTourismManagementPage } from '../../lib/sanity/queries';

const sanityData = await getTourismManagementPage();

const heroBackground = sanityData?.heroBackground?.asset?.url ? {
    url: sanityData.heroBackground.asset.url,
    alt: sanityData.heroBackground.alt || "Premium hotel lobby or airport terminal"
} : {
    url: "https://images.unsplash.com/photo-1542296332-2e4473faf563?q=80&w=1920&auto=format&fit=crop",
    alt: "Premium hotel lobby or airport terminal"
};

const quickFacts = sanityData?.quickFacts || {
    duration: "4 Years",
    units: "156 Units",
    format: "Hybrid + Practicum"
};

const overviewMainImage = sanityData?.overviewMainImage?.asset?.url ? {
    url: sanityData.overviewMainImage.asset.url,
    alt: sanityData.overviewMainImage.alt || "Global Tourism Operations"
} : {
    url: "https://images.unsplash.com/photo-1542314831-c53cd3816002?q=80&w=1920&auto=format&fit=crop",
    alt: "Global Tourism Operations"
};

const overviewSubImage = sanityData?.overviewSubImage?.asset?.url ? {
    url: sanityData.overviewSubImage.asset.url,
    alt: sanityData.overviewSubImage.alt || "Hospitality Logistics Management"
} : {
    url: "https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?q=80&w=1920&auto=format&fit=crop",
    alt: "Hospitality Logistics Management"
};

const outcomes = sanityData?.outcomes && sanityData.outcomes.length > 0 ? sanityData.outcomes : [
    {
        title: "Global Travel & Aviation Logistics",
        description: "Mastery in coordinating international travel operations, modern GDS (Global Distribution Systems) ticketing, and aviation management."
    },
    {
        title: "Corporate Event & MICE Execution",
        description: "The capability to architect, budget, and execute large-scale Meetings, Incentives, Conferences, and Exhibitions (MICE) for enterprise clients."
    },
    {
        title: "Sustainable Destination Management",
        description: "The application of business strategies to develop, market, and manage tourist destinations while ensuring ecological and economic sustainability."
    },
    {
        title: "Premium Hospitality Operations",
        description: "A deeply ingrained understanding of luxury service standards, hotel enterprise management, and elite guest experience design."
    }
];

const curriculum = sanityData?.curriculum && sanityData.curriculum.length > 0 ? sanityData.curriculum : [
    {
        year: "Year 1",
        title: "Foundations of Global Tourism",
        description: "Master the fundamental concepts of the hospitality industry, global geography, and corporate management.",
        subjects: [
            "[1st Sem] Macro Perspectives of Tourism and Hospitality",
            "[1st Sem] Risk Management as Applied to Safety, Security and Sanitation",
            "[2nd Sem] Philippine Culture and Tourism Geography",
            "[2nd Sem] Micro Perspective of Tourism and Hospitality",
            "[2nd Sem] Professional Development and Applied Ethics"
        ]
    },
    {
        year: "Year 2",
        title: "Travel Operations & Logistics",
        description: "Dive into the mechanics of moving people globally, focusing on aviation, ticketing, and marketing.",
        subjects: [
            "[1st Sem] Tourism and Hospitality Marketing",
            "[1st Sem] Foreign Language 1",
            "[1st Sem] Global Culture and Tourism Geography",
            "[1st Sem] Tour Guiding (Professional Elective 1)",
            "[2nd Sem] Applied Business Tools and Technologies in Tourism",
            "[2nd Sem] Tour and Travel Management",
            "[2nd Sem] Sustainable Tourism",
            "[2nd Sem] Foreign Language 2",
            "[2nd Sem] Cabin Service Operation (Professional Elective 2)"
        ]
    },
    {
        year: "Year 3",
        title: "Enterprise Management & MICE",
        description: "Learn to architect large-scale events and manage sustainable tourism enterprises.",
        subjects: [
            "[1st Sem] Recreation and Leisure Management (Professional Elective 3)",
            "[1st Sem] Legal Aspects in Tourism and Hospitality",
            "[1st Sem] Quality Service Management in Tourism and Hospitality",
            "[1st Sem] Foreign Language 3",
            "[1st Sem] Research in Tourism 1",
            "[1st Sem] Domestic and International Tour Planning, Packaging and Pricing (Professional Elective 4)",
            "[1st Sem] Travel Writing and Photography (Professional Elective 5)",
            "[2nd Sem] Multi-Cultural Diversity in the Workplace for the Tourism Professional",
            "[2nd Sem] Foreign Language 4",
            "[2nd Sem] Introduction to Meetings, Incentives, Conferences and Events Management",
            "[2nd Sem] Operations Management",
            "[2nd Sem] Accommodation Operation Management (Professional Elective 6)",
            "[2nd Sem] Heritage Tourism (Professional Elective 7)",
            "[2nd Sem] Research in Tourism 2"
        ]
    },
    {
        year: "Year 4",
        title: "Practicum & Strategic Leadership",
        description: "Apply your operational knowledge in real-world local and international practicum settings.",
        subjects: [
            "[1st Sem] Strategic Management",
            "[1st Sem] Entrepreneurship in Tourism and Hospitality",
            "[1st Sem] Meal Management for Tourism Professionals (Professional Elective 8)",
            "[1st Sem] Transportation Management",
            "[1st Sem] Agritourism (Professional Elective 9)",
            "[1st Sem] Cruise Tourism (Professional Elective 10)",
            "[1st Sem] Destination Management and Marketing (Professional Elective 11)",
            "[2nd Sem] Practicum (600 hours)"
        ]
    }
];

const ecosystemImages = sanityData?.ecosystemImages ? {
    facilities: sanityData.ecosystemImages.lab?.asset?.url ? { url: sanityData.ecosystemImages.lab.asset.url, alt: sanityData.ecosystemImages.lab.alt || "Aviation & Hospitality Simulation Suites" } : { url: "https://images.unsplash.com/photo-1566073771259-6a8506099945?q=80&w=1920&auto=format&fit=crop", alt: "Aviation & Hospitality Simulation Suites" },
    society: sanityData.ecosystemImages.society?.asset?.url ? { url: sanityData.ecosystemImages.society.asset.url, alt: sanityData.ecosystemImages.society.alt || "The OLOPSC Tourism Society" } : { url: "https://images.unsplash.com/photo-1511632765486-a01980e01a18?q=80&w=1920&auto=format&fit=crop", alt: "The OLOPSC Tourism Society" },
    events: sanityData.ecosystemImages.research?.asset?.url ? { url: sanityData.ecosystemImages.research.asset.url, alt: sanityData.ecosystemImages.research.alt || "Annual Travel & MICE Expo" } : { url: "https://images.unsplash.com/photo-1515169067868-5387ec356754?q=80&w=1920&auto=format&fit=crop", alt: "Annual Travel & MICE Expo" },
    sustainability: sanityData.ecosystemImages.community?.asset?.url ? { url: sanityData.ecosystemImages.community.asset.url, alt: sanityData.ecosystemImages.community.alt || "Sustainable Destination Advocacy" } : { url: "https://images.unsplash.com/photo-1469854523086-cc02fe5d8800?q=80&w=1920&auto=format&fit=crop", alt: "Sustainable Destination Advocacy" }
} : {
    facilities: { url: "https://images.unsplash.com/photo-1566073771259-6a8506099945?q=80&w=1920&auto=format&fit=crop", alt: "Aviation & Hospitality Simulation Suites" },
    society: { url: "https://images.unsplash.com/photo-1511632765486-a01980e01a18?q=80&w=1920&auto=format&fit=crop", alt: "The OLOPSC Tourism Society" },
    events: { url: "https://images.unsplash.com/photo-1515169067868-5387ec356754?q=80&w=1920&auto=format&fit=crop", alt: "Annual Travel & MICE Expo" },
    sustainability: { url: "https://images.unsplash.com/photo-1469854523086-cc02fe5d8800?q=80&w=1920&auto=format&fit=crop", alt: "Sustainable Destination Advocacy" }
};

const chair = sanityData?.chair ? {
    name: sanityData.chair.name || "Dr. Maria Santos, PhD, CHA",
    title: sanityData.chair.title || "Program Chair & Faculty, Tourism Management",
    credentials: sanityData.chair.credentials || "",
    quote: sanityData.chair.quote || "Hospitality is an art, but global tourism is a rigorous science of logistics, enterprise, and execution. Our goal is to forge leaders who command both.",
    image: sanityData.chair.image?.asset?.url ? { url: sanityData.chair.image.asset.url, alt: sanityData.chair.image.alt || "Program Chair" } : { url: "https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?q=80&w=800&auto=format&fit=crop", alt: "Program Chair" }
} : {
    name: "Dr. Maria Santos, PhD, CHA",
    title: "Program Chair & Faculty, Tourism Management",
    credentials: "",
    quote: "Hospitality is an art, but global tourism is a rigorous science of logistics, enterprise, and execution. Our goal is to forge leaders who command both.",
    image: { url: "https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?q=80&w=800&auto=format&fit=crop", alt: "Program Chair" }
};

const faculty = sanityData?.faculty && sanityData.faculty.length > 0 ? sanityData.faculty.map((f: any) => ({
    name: f.name || "Faculty Name",
    specialty: f.specialty || "Specialty",
    credentials: f.credentials || "Credentials",
    image: f.image?.asset?.url ? { url: f.image.asset.url, alt: f.image.alt || "Faculty" } : { url: "https://images.unsplash.com/photo-1560250097-0b93528c311a?q=80&w=800&auto=format&fit=crop", alt: "Faculty" }
})) : [
    {
        name: "Capt. Roberto Reyes",
        specialty: "Aviation Management",
        credentials: "M.S., Commercial Pilot",
        image: { url: "https://images.unsplash.com/photo-1560250097-0b93528c311a?q=80&w=800&auto=format&fit=crop", alt: "Faculty" }
    },
    {
        name: "Elena Cruz",
        specialty: "Luxury Hotel Operations",
        credentials: "M.A., Former GM",
        image: { url: "https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?q=80&w=800&auto=format&fit=crop", alt: "Faculty" }
    },
    {
        name: "Dr. Miguel Torres",
        specialty: "MICE & Corporate Events",
        credentials: "Ph.D., Event Architect",
        image: { url: "https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?q=80&w=800&auto=format&fit=crop", alt: "Faculty" }
    },
    {
        name: "Sarah Villanueva",
        specialty: "Sustainable Tourism",
        credentials: "M.S., Eco-Tourism Consultant",
        image: { url: "https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?q=80&w=800&auto=format&fit=crop", alt: "Faculty" }
    },
    {
        name: "Sarah Villanueva",
        specialty: "Sustainable Tourism",
        credentials: "M.S., Eco-Tourism Consultant",
        image: { url: "https://images.unsplash.com/photo-1580489944761-15a19d654956?q=80&w=800&auto=format&fit=crop", alt: "Faculty" }
    }
];

const pathways = sanityData?.pathways && sanityData.pathways.length > 0 ? sanityData.pathways : [
    {
        title: "Aviation & Global Travel",
        subtitle: "Transportation Logistics",
        description: "Command the logistical networks that move millions of travelers. Step into leadership roles within international airlines, cruise lines, and global travel agencies.",
        roles: ["Flight Attendant / Cabin Crew", "Aviation Ground Operations Manager", "Travel Agency Director", "Tourism Attaché"]
    },
    {
        title: "Premium Hospitality",
        subtitle: "Luxury Enterprise Management",
        description: "Direct the operations of world-class accommodations. Master the financial and operational mechanics of running 5-star hotels and international resorts.",
        roles: ["Hotel General Manager", "Guest Relations Executive", "Resort Operations Director", "Food & Beverage Manager"]
    },
    {
        title: "MICE & Corporate Events",
        subtitle: "Large-Scale Execution",
        description: "Architect and execute massive corporate gatherings, international conventions, and destination marketing campaigns for enterprise clients.",
        roles: ["MICE Director / Event Architect", "Convention Coordinator", "Corporate Travel Manager", "Destination Marketing Executive"]
    }
];
const pageTitle = sanityData?.seo?.title || "BS Tourism Management in Marikina, Metro Manila | OLOPSC College of BMSE";
const pageDescription = sanityData?.seo?.description || "Master the business of global travel, aviation logistics, and premium hospitality at OLOPSC College of BMSE in Marikina, Metro Manila.";

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Course",
      "name": "Bachelor of Science in Tourism Management",
      "description": "An intensive, business-focused program equipping students with the operational expertise to direct international hospitality brands and travel logistics in Marikina, Metro Manila.",
      "provider": {
        "@type": "CollegeOrUniversity",
        "name": "OLOPSC College of BMSE",
        "sameAs": "https://www.olopsc.edu.ph"
      }
    }
  ]
};
const schemaString = JSON.stringify(schema);
---

<Layout title={pageTitle} description={pageDescription} additionalSchema={schemaString}>
  <section class="relative bg-primary pt-32 pb-24 lg:pt-40 lg:pb-32 overflow-hidden border-b border-slate-800">
    <div class="absolute inset-0 bg-gradient-to-r from-primary via-primary/95 to-transparent z-0"></div>
    <img src={heroBackground.url} alt={heroBackground.alt} class="absolute inset-y-0 right-0 w-full lg:w-[75%] h-full object-cover opacity-40 md:opacity-60 z-0" style="mask-image: linear-gradient(to right, transparent, black 40%); -webkit-mask-image: linear-gradient(to right, transparent, black 40%);" loading="eager" />

    <ScrollRevealWrapper animation="slide-up" class="relative z-10 max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-12">
      <div class="lg:col-span-7 flex flex-col">
        <h2 class="inline-block self-start py-1 px-3 rounded-full bg-white/10 border border-accent/50 text-accent font-bold uppercase tracking-widest text-xs mb-6 backdrop-blur-sm">College of BMSE &bull; Bachelor of Science</h2>
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-black tracking-tight leading-[1.1] mb-6 text-white">Master the Business of <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-yellow-200">Global Travel.</span></h1>
        <p class="text-lg md:text-xl text-slate-300 leading-relaxed max-w-2xl mb-10">As a premier program within the College of Business, Management, Science, and Education (BMSE), our B.S. in Tourism Management goes far beyond hospitality. We engineer leaders capable of managing global travel operations, executing large-scale events, and directing international tourism enterprises.</p>
        <div class="flex flex-wrap gap-4 mt-10">
          <CtaButton cta={{ text: "Explore Curriculum", link: "#curriculum" }} variant="primary" />
          <CtaButton cta={{ text: "View Corporate Paths", link: "#outcomes" }} variant="secondary" />
        </div>
      </div>
    </ScrollRevealWrapper>
  </section>

  <div class="bg-surface border-b border-slate-200 relative z-20 shadow-sm">
    <ScrollRevealWrapper direction="fade" delay={0.2} class="max-w-7xl mx-auto px-6 py-8 grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-0 md:divide-x divide-slate-200">

      <div class="flex flex-col items-center text-center px-4">
        <span class="text-slate-400 mb-2"><svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></span>
        <span class="text-xl font-black text-primary tracking-tight">B.S. Tourism</span>
        <span class="text-xs font-bold text-slate-500 uppercase tracking-wider mt-1">Degree Program</span>
      </div>

      <div class="flex flex-col items-center text-center px-4">
        <span class="text-slate-400 mb-2"><svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></span>
        <span class="text-xl font-black text-primary tracking-tight">{quickFacts.duration || '4 Years'}</span>
        <span class="text-xs font-bold text-slate-500 uppercase tracking-wider mt-1">Standard Completion</span>
      </div>

      <div class="flex flex-col items-center text-center px-4">
        <span class="text-slate-400 mb-2"><svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg></span>
        <span class="text-xl font-black text-primary tracking-tight">{quickFacts.units || '156 Units'}</span>
        <span class="text-xs font-bold text-slate-500 uppercase tracking-wider mt-1">Total Academic Load</span>
      </div>

      <div class="flex flex-col items-center text-center px-4">
        <span class="text-slate-400 mb-2"><svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg></span>
        <span class="text-xl font-black text-primary tracking-tight">{quickFacts.format || 'Hybrid + Practicum'}</span>
        <span class="text-xs font-bold text-slate-500 uppercase tracking-wider mt-1">Learning Format</span>
      </div>

    </ScrollRevealWrapper>
  </div>

  <section class="py-24 md:py-32 bg-white overflow-hidden">
    <ScrollRevealWrapper animation="slide-left" class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      <div class="flex flex-col relative z-10">
        <span class="text-accent font-black tracking-widest uppercase text-xs mb-4">Program Overview</span>
        <h2 class="text-3xl md:text-5xl font-black tracking-tight text-primary mb-6 leading-[1.1]">The Architecture of Global Hospitality.</h2>
        <p class="text-lg text-slate-600 leading-relaxed mb-6">The Bachelor of Science in Tourism Management is an intensive, business-focused program engineered for the modern global economy. This four-year degree equips students with the operational expertise to direct international hospitality brands, manage complex travel logistics, and execute large-scale corporate events.</p>
        <p class="text-lg text-slate-600 leading-relaxed">Moving far beyond basic service, our curriculum integrates sustainable destination management, digital tourism marketing, and enterprise operations. Graduates are prepared for high-yield leadership roles in aviation, premium hotel chains, and global travel conglomerates.</p>
      </div>

      <div class="relative w-full aspect-[4/3] lg:aspect-square flex items-center justify-center mt-12 lg:mt-0 group">
        <div class="absolute right-12 top-12 w-2/3 h-2/3 bg-surface rounded-full blur-3xl -z-10 opacity-50"></div>

        <div class="absolute left-0 bottom-0 w-[80%] aspect-[4/3] rounded-3xl overflow-hidden shadow-2xl z-10">
          <img src={overviewMainImage.url} alt={overviewMainImage.alt} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
        </div>

        <div class="absolute right-0 top-0 w-[55%] aspect-square rounded-3xl overflow-hidden shadow-2xl border-8 border-white z-20">
          <img src={overviewSubImage.url} alt={overviewSubImage.alt} class="w-full h-full object-cover" loading="lazy" />
        </div>
      </div>
    </ScrollRevealWrapper>
  </section>

  <section class="py-24 md:py-32 bg-white relative border-b border-slate-100">
    <ScrollRevealWrapper animation="slide-up" class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-24 items-start relative">

      <div class="lg:col-span-5 relative h-full">
        <div class="sticky top-32 flex flex-col">
          <span class="text-accent font-black tracking-widest uppercase text-xs mb-4">The OLOPSC Advantage</span>
          <h2 class="text-3xl md:text-5xl font-black tracking-tight text-primary mb-6 leading-[1.1]">More than hospitality. True operational command.</h2>
          <p class="text-lg text-slate-600 leading-relaxed mb-8">We do not just teach you about destinations; we train you to manage the complex logistics that move millions of people globally. Our curriculum strips away the fluff, focusing heavily on sustainable enterprise management, aviation logistics, and corporate event execution. When you graduate, you aren't just holding a degree—you possess a distinct set of highly marketable management capabilities.</p>
        </div>
      </div>

      <div class="lg:col-span-7 flex flex-col">
        <h3 class="text-xl font-bold text-slate-300 mb-8 pb-4 border-b border-slate-100 uppercase tracking-widest">Graduate Capabilities</h3>

        {outcomes.map((outcome: any) => (
          <div class="group relative py-8 border-b border-slate-100 flex flex-col md:flex-row gap-6 md:gap-8 items-start hover:bg-slate-50 transition-colors duration-300 px-6 -mx-6 rounded-2xl">
            <div class="w-12 h-12 rounded-full bg-surface flex items-center justify-center shrink-0 border border-slate-200 group-hover:border-accent group-hover:bg-accent/10 transition-colors duration-500">
              <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </div>
            <div class="flex flex-col">
              <h4 class="text-xl font-black text-primary mb-3 leading-tight group-hover:translate-x-1 transition-transform duration-300">{outcome.title}</h4>
              <p class="text-slate-600 leading-relaxed text-base">{outcome.description}</p>
            </div>
          </div>
        ))}
      </div>

    </ScrollRevealWrapper>
  </section>

  <section id="curriculum" class="py-24 md:py-32 bg-slate-50 relative border-b border-slate-100">
    <ScrollRevealWrapper animation="fade-in" class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-16">
        <span class="text-accent font-black tracking-widest uppercase text-xs mb-4 inline-block">Academic Roadmap</span>
        <h2 class="text-3xl md:text-5xl font-black tracking-tight text-primary mb-6">What Will You Study?</h2>
        <p class="text-lg text-slate-600 leading-relaxed">Our 4-year curriculum is strategically sequenced. We focus on core operational competencies, preparing you to lead in aviation, premium hospitality, and global event management.</p>
      </div>

      <div class="space-y-4">
        {curriculum.map((item: any) => (
          <details class="group bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow">
            <summary class="flex items-center justify-between p-6 md:p-8 cursor-pointer list-none select-none">
              <div class="flex items-center gap-6">
                <span class="text-3xl md:text-4xl font-black text-slate-200 group-open:text-accent transition-colors tracking-tighter">{item.year}</span>
                <h3 class="text-xl md:text-2xl font-bold text-primary">{item.title}</h3>
              </div>
              <span class="w-10 h-10 rounded-full bg-slate-50 flex items-center justify-center text-primary group-open:rotate-180 transition-transform duration-300 bg-surface">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
              </span>
            </summary>

            <div class="px-6 md:px-8 pb-8 pt-2 border-t border-slate-100 mt-2">
              <p class="text-slate-600 mb-6 leading-relaxed">{item.description}</p>
              <div class="flex flex-col gap-3">
                <h4 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Core Major Subjects</h4>
                <div class="flex flex-wrap gap-3">
                  {item.subjects.map((subject: string) => (
                    <span class="bg-surface text-primary border border-slate-100 py-2 px-4 rounded-lg text-sm font-bold shadow-sm">{subject}</span>
                  ))}
                </div>
              </div>
            </div>
          </details>
        ))}
      </div>
    </ScrollRevealWrapper>
  </section>

  <section class="py-24 md:py-32 bg-primary relative overflow-hidden">
    <ScrollRevealWrapper animation="slide-up">
      <div class="max-w-7xl mx-auto px-6 mb-16 text-center">
        <span class="text-accent font-black tracking-widest uppercase text-xs mb-4 inline-block">The Department Ecosystem</span>
        <h2 class="text-3xl md:text-5xl font-black tracking-tight text-white mb-6">Where Theory Meets Operations.</h2>
