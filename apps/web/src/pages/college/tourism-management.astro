            <span class="text-accent font-bold text-xs uppercase tracking-widest mb-2 block">Social Responsibility</span>
            <h3 class="text-xl md:text-2xl font-black text-white mb-2 leading-tight">Sustainable Destination Advocacy</h3>
          </div>
        </div>

      </div>
