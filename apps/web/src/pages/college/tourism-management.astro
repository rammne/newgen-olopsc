    </ScrollRevealWrapper>
  </section>

  <section id="outcomes" class="py-24 md:py-32 bg-slate-50 relative border-t border-b border-slate-200">
    <ScrollRevealWrapper animation="slide-up">
      <div class="max-w-7xl mx-auto px-6 mb-16 md:mb-24 text-center">
        <span class="text-accent font-black tracking-widest uppercase text-xs mb-4 inline-block">Your Career Pathways</span>
        <h2 class="text-3xl md:text-5xl font-black tracking-tight text-primary mb-6">Where Will This Degree Take You?</h2>
        <p class="text-lg text-slate-600 leading-relaxed max-w-2xl mx-auto">A degree in Tourism Management opens up many fun and exciting career opportunities. Whether you want to travel the world as a flight attendant or plan memorable events, our graduates are ready for the job.</p>
      </div>

      <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-8">
        {pathways.map((pathway: any) => (
          <div class="bg-white rounded-3xl p-8 md:p-10 shadow-sm hover:shadow-xl border border-slate-100 flex flex-col h-full group transition-all duration-300 hover:-translate-y-1">

            <div class="w-14 h-14 rounded-2xl bg-surface flex items-center justify-center text-primary mb-8 group-hover:bg-accent group-hover:text-white transition-colors duration-500">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
            </div>

            <div class="mb-8 border-b border-slate-100 pb-8">
