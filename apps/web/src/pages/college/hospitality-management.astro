          <div class="relative z-20">
            <span class="text-accent font-bold text-xs uppercase tracking-widest mb-2 block">Student Community</span>
            <h3 class="text-2xl md:text-3xl font-black text-white mb-2 leading-tight">The Culinary Class</h3>
            <p class="text-slate-300 text-sm max-w-md hidden md:block">Our hospitality management students dressed in their full chef uniforms, ready for their culinary training and kitchen practice.</p>
          </div>
        </div>

        <!-- Block 2: The Society -->
