          <div class="absolute inset-0 bg-gradient-to-t from-primary/90 via-primary/40 to-transparent z-10"></div>
          <div class="relative z-20">
            <span class="text-accent font-bold text-xs uppercase tracking-widest mb-2 block">Hands-On Learning</span>
            <h3 class="text-2xl md:text-3xl font-black text-white mb-2 leading-tight">Culinary Arts Training</h3>
            <p class="text-slate-300 text-sm">Learn directly from experienced instructors as they guide you through cooking techniques and culinary mastery in our fully-equipped kitchens.</p>
          </div>
        </div>

        <!-- Block 3: Banquet Execution -->
        <div class="md:col-span-1 md:row-span-1 group relative rounded-3xl overflow-hidden flex flex-col justify-end p-8 border border-white/10">
          <img src={ecosystemImages.catering.url} alt={ecosystemImages.catering.alt} class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 z-0" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-primary/90 via-primary/40 to-transparent z-10"></div>
          <div class="relative z-20">
            <span class="text-accent font-bold text-xs uppercase tracking-widest mb-2 block">Culinary Creations</span>
            <h3 class="text-xl md:text-2xl font-black text-white mb-2 leading-tight">Gourmet Plating</h3>
            <p class="text-slate-300 text-sm mt-2 hidden sm:block">Learn the art of preparing and presenting beautiful, restaurant-quality dishes.</p>
          </div>
        </div>

        <!-- Block 4: Restaurant Simulation -->
        <div class="md:col-span-1 md:row-span-1 group relative rounded-3xl overflow-hidden flex flex-col justify-end p-8 border border-white/10">
          <img src={ecosystemImages.restaurant.url} alt={ecosystemImages.restaurant.alt} class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 z-0" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-primary/90 via-primary/40 to-transparent z-10"></div>
          <div class="relative z-20">
            <span class="text-accent font-bold text-xs uppercase tracking-widest mb-2 block">Real-World Practice</span>
            <h3 class="text-xl md:text-2xl font-black text-white mb-2 leading-tight">Food & Beverage Service</h3>
            <p class="text-slate-300 text-sm mt-2 hidden sm:block">Practice your serving and dining management skills in our simulated restaurant environment.</p>
          </div>
        </div>
      </div>
    </ScrollRevealWrapper>
  </section>

  <section class="py-24 md:py-32 bg-white relative border-t border-slate-100">
