---
import Layout from "../../layouts/Layout.astro";
import Hero from "../../components/homepage/Hero.astro";
import { getAdmissionsPage } from "../../lib/sanity/queries";
import "../../styles/global.css";

// Fetch admissions page data for the hero
const admissionsPage = await getAdmissionsPage();

const pageTitle =
  admissionsPage?.seo?.title || admissionsPage?.title || "Admissions — OLOPSC";
const pageDescription =
  admissionsPage?.seo?.description ||
  "Join OLOPSC. Explore our admissions pathways for College and Basic Education programs.";
const ogImage = admissionsPage?.seo?.image?.asset?.url;

const admissionPaths = [
  {
    title: "College Admission",
    subtitle: "College of BMSE",
    description:
      "Enrollment procedures, tuition structures, and academic policies for incoming freshmen, transferees, and continuing college students.",
    href: "/admissions/college-admission",
    icon: "graduation",
  },
  {
    title: "Basic Education Admission",
    subtitle: "Preschool · Grade School · JHS · SHS",
    description:
      "Admissions requirements, enrollment steps, and fee schedules for our K-12 Basic Education programs.",
    href: "/admissions/basic-education-admission",
    icon: "school",
  },
];
---

<Layout title={pageTitle} description={pageDescription} ogImage={ogImage}>
  {/* Hero Section */}
  {admissionsPage?.hero && <Hero hero={admissionsPage.hero} />}

  {/* Section 2: Admission Pathway Selector */}
  <section id="admission-pathways" class="py-24 md:py-32 bg-slate-50">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-16">
        <span class="text-accent font-black tracking-widest uppercase text-xs mb-4 inline-block">
          Choose Your Path
        </span>
        <h2 class="text-3xl md:text-5xl font-black tracking-tight text-primary mb-6">
          Select Your Enrollment Track.
        </h2>
        <p class="text-lg text-slate-600 leading-relaxed max-w-2xl mx-auto">
          OLOPSC offers dedicated admissions processes for College and Basic Education.
          Choose the pathway that applies to you.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {admissionPaths.map((path) => (
          <a
            href={path.href}
            class="group relative flex flex-col bg-white rounded-3xl p-10 border border-slate-200 shadow-sm
                   transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:border-accent
                   no-underline cursor-pointer"
          >
            {/* Icon */}
            <div class="w-16 h-16 rounded-2xl bg-slate-100 group-hover:bg-accent/10 flex items-center justify-center mb-8 transition-colors duration-300">
              {path.icon === "graduation" ? (
                <svg class="w-8 h-8 text-primary group-hover:text-accent transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" />
                </svg>
              ) : (
                <svg class="w-8 h-8 text-primary group-hover:text-accent transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
                </svg>
              )}
            </div>

            {/* Text Content */}
            <span class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-2 block">
              {path.subtitle}
            </span>
            <h3 class="text-2xl font-black text-primary mb-4 group-hover:text-accent transition-colors duration-300">
              {path.title}
            </h3>
            <p class="text-sm text-slate-600 leading-relaxed mb-8 flex-grow">
              {path.description}
            </p>

            {/* Arrow CTA */}
            <div class="flex items-center gap-2 text-sm font-bold text-primary group-hover:text-accent transition-colors duration-300">
              <span>View Details</span>
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
