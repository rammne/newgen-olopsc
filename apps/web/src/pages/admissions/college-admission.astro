---
import Layout from "../../layouts/Layout.astro";
import AdmissionEngine from "../../components/admissions/AdmissionEngine.astro";
import TuitionStructures from "../../components/admissions/TuitionStructures.astro";
import PoliciesDirectory from "../../components/admissions/PoliciesDirectory.astro";
import LocationMap from "../../components/common/LocationMap.astro";
import { getAdmissionsPage } from "../../lib/sanity/queries";
import "../../styles/global.css";

// Fetch admissions page data (reuse existing Sanity query for the hero)
const admissionsPage = await getAdmissionsPage();

const pageTitle = "College Admission — OLOPSC College of BMSE";
const pageDescription =
  "Learn how to enroll at the OLOPSC College of Business, Management, Sciences, and Education. Step-by-step admission procedures for freshmen, transferees, and continuing students.";
const ogImage = admissionsPage?.seo?.image?.asset?.url;
---

<Layout title={pageTitle} description={pageDescription} ogImage={ogImage}>
  {/* Simple Hero Section */}
  <section class="relative bg-[var(--color-primary)] pt-32 pb-16 lg:pt-40 lg:pb-24 overflow-hidden">
    {/* Subtle animated background glow */}
    <div class="absolute top-[-50%] left-1/2 -translate-x-1/2 w-[70%] h-[150%] rounded-full bg-[#facc15]/5 blur-[120px] animate-pulse"></div>

    <div class="max-w-4xl mx-auto px-6 lg:px-8 relative z-10 text-center">
      <div class="animate-fade-in-up" style="animation: fade-in-up 0.8s ease-out forwards;">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white leading-[1.15] tracking-tight mb-6 font-['Montserrat']">
          <span class="text-[var(--color-accent)]">College</span> Admission Process
        </h1>
        <p class="text-base sm:text-lg lg:text-xl text-slate-200 leading-relaxed font-['Inter'] max-w-2xl mx-auto">
          Take the next step in your academic journey. The College of Business, Management, Sciences, and Education (BMSE) welcomes you with a straightforward enrollment process.
        </p>
      </div>
    </div>
  </section>

  <style>
    @keyframes fade-in-up {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  </style>

  {/* Section 2: Interactive Admission Engine */}
  <AdmissionEngine />

  {/* Section 3: Tuition Payment Structures */}
  <TuitionStructures />

  {/* Section 4: Policies & Helpdesk Directory */}
  <PoliciesDirectory />

  {/* Section 5: Location Map */}
  <section class="py-12 md:py-16 bg-slate-50">
    <LocationMap />
  </section>
</Layout>
