---
import Layout from "../layouts/Layout.astro";
import CtaButton from "../components/common/CtaButton.astro";
import ScrollRevealWrapper from "../components/common/ScrollRevealWrapper.astro";
import { getAcademicDepartmentByType, getCollegeProgramThumbnails } from "../lib/sanity/queries";
import { getSanityImageUrl } from "../lib/utils/sanity";
import "../styles/global.css";

// Fetch CMS data
const department = await getAcademicDepartmentByType("college");
const thumbnails = await getCollegeProgramThumbnails();

// --- Image Object Mapping ---
interface SanityImage {
  url: string;
  alt: string;
}

const heroImage: SanityImage = {
  url: department?.hero?.backgroundImage?.asset?.url
    ? getSanityImageUrl(department.hero.backgroundImage, { width: 1200, height: 900, fit: "crop" })
    : "https://images.unsplash.com/photo-1523580494863-6f3031224c94?q=80&w=1200&auto=format&fit=crop",
  alt: department?.hero?.backgroundImage?.alt
    ?? "OLOPSC College students collaborating on industry-ready projects",
};

const roiImage: SanityImage = {
  url: department?.facilityTourImages?.[0]?.asset?.url
    ? getSanityImageUrl(department.facilityTourImages[0], { width: 1200, height: 900, fit: "crop" })
    : "https://images.unsplash.com/photo-1541339907198-e08756dedf3f?q=80&w=1200&auto=format&fit=crop",
  alt: department?.facilityTourImages?.[0]?.alt
    ?? "OLOPSC College graduates transitioning into successful careers",
};

const bmseShieldLogo: SanityImage = {
  url: "/OLOPSC%20_BMSE_Official_Logo.webp",
  alt: "OLOPSC BMSE Official Shield"
};

interface CollegeCultureImage {
  url: string;
  alt: string;
  title: string;
  description: string;
}

const rawGallery = department?.facilityTourImages || [];
const hasValidGallery = rawGallery.length > 0;

const collegeCultureGallery: CollegeCultureImage[] = hasValidGallery
  ? rawGallery.slice(0, 6).map((img: any) => ({
      url: img?.asset?.url
        ? getSanityImageUrl(img, { width: 1200, height: 900, fit: "crop" })
        : "https://images.unsplash.com/photo-1532094349884-543bc11b234d?q=80&w=1200&auto=format&fit=crop",
      alt: img?.alt || "Campus Facility",
      title: img?.caption || "Campus Facility",
      description: img?.description || "A dynamic and engaging campus facility for our College students."
    }))
  : [
      {
        title: "Modern Library & Study Areas",
        description: "Quiet study zones and collaborative spaces designed to help you focus on your research, thesis writing, and group projects.",
        alt: "College students studying in a modern university library",
        url: "https://images.unsplash.com/photo-1532094349884-543bc11b234d?q=80&w=1200&auto=format&fit=crop"
      },
      {
        title: "Active Student Organizations",
        description: "Join academic clubs and student organizations to meet new friends, build your leadership skills, and get involved in campus activities.",
        alt: "College students participating in a student organization event",
        url: "https://images.unsplash.com/photo-1523240795612-9a054b0db644?q=80&w=1200&auto=format&fit=crop"
      },
      {
        title: "Modern Computer & Science Labs",
        description: "Get hands-on experience using our modern computing facilities and laboratories that prepare you for your future career.",
        alt: "College students working in a modern computer laboratory",
        url: "https://images.unsplash.com/photo-1517694712202-14dd9538aa97?q=80&w=1200&auto=format&fit=crop"
      },
      {
        title: "Sports & Recreation Facilities",
        description: "Stay active and healthy with our indoor sports courts and fitness areas that promote wellness, teamwork, and school spirit.",
        alt: "College students playing sports in an indoor court",
        url: "https://images.unsplash.com/photo-1546519638-68e109498ffc?q=80&w=1200&auto=format&fit=crop"
      },
      {
        title: "Job Fairs & Career Seminars",
        description: "Prepare for your future career through on-campus job fairs, resume workshops, and talks from competitive industry professionals.",
        alt: "College students attending a career seminar and networking event",
        url: "https://images.unsplash.com/photo-1524995997946-a1c2e315a42f?q=80&w=1200&auto=format&fit=crop"
      },
      {
        title: "Industry & Educational Tours",
        description: "Broaden your learning experience through industry visits, educational tours, and community partnerships that provide practical insights.",
        alt: "College students participating in an educational industry tour",
        url: "https://images.unsplash.com/photo-1528605248644-14dd04022da1?q=80&w=1200&auto=format&fit=crop"
      }
    ];

// SEO metadata
const pageTitle = "Best College in Marikina | OLOPSC-BMSE Degree Programs";
const pageDescription = "Looking for a top-tier college in Marikina City? The OLOPSC College of Business, Management, Science, and Education (BMSE) offers CHED-recognized bachelor degrees in IT, Business, Tourism, and Psychology.";
const ogImage = department?.seo?.image?.asset?.url;

// Degree Matrix data — thumbnails come from each program's singleton schema
const degreeMatrix = [
  {
    department: "Computing Studies",
    tags: ["BSCS", "ACT"],
    text: "Master software engineering, algorithms, and full-stack development for the booming global tech industry.",
    href: "/college/computing-studies",
    thumbnailKey: "computing-studies",
  },
  {
    department: "Business Administration & Entrepreneurship",
    tags: ["BSBA-HRM", "BSBA-MM", "BSE"],
    text: "Corporate leadership and startup incubation focused on marketing, human resources, and business creation.",
    href: "/college/business-administration-and-entrepreneurship",
    thumbnailKey: "business-administration-and-entrepreneurship",
  },
  {
    department: "Education & Liberal Arts",
    tags: ["BEED", "BSED", "BAEL"],
    text: "Shaping the next generation of educators and communicators with modern pedagogical strategies and linguistic mastery.",
    href: "/college/education-and-liberal-arts",
    thumbnailKey: "education-and-liberal-arts",
  },
  {
    department: "Hospitality Management",
    tags: ["BSHM"],
    text: "World-class training for global hotel, restaurant, and resort operations, emphasizing premium customer experience.",
    href: "/college/hospitality-management",
    thumbnailKey: "hospitality-management",
  },
  {
    department: "Tourism Management",
    tags: ["BSTM"],
    text: "Navigating the international travel economy with expertise in destination marketing, aviation, and tour operations.",
    href: "/college/tourism-management",
    thumbnailKey: "tourism-management",
  },
  {
    department: "Psychology",
    tags: ["BSP"],
    text: "Analyzing human behavior and cognitive processes for careers in clinical assessment, corporate HR, and mental health.",
    href: "/college/psychology",
    thumbnailKey: "psychology",
  },
].map(item => {
  const thumbData = thumbnails?.[item.thumbnailKey]?.cardThumbnail;
  const imageUrl = thumbData?.asset?.url
    ? getSanityImageUrl(thumbData, { width: 800, height: 450, fit: "crop" })
    : null;

  return {
    ...item,
    image: imageUrl,
    alt: thumbData?.alt || `${item.department} thumbnail`
  };
});

interface FacultyMember {
  image: {
    url: string;
    alt: string;
  };
  name: string;
  position: string;
  department: string;
  achievements: string;
  background: string;
}

const dean = {
  name: department?.dean?.name || "Dr. Maria Santos",
  title: department?.dean?.title || "Dean, College of BMSE",
  credentials: department?.dean?.credentials || "",
  quote: department?.dean?.quote || "Welcome to our academic community, where excellence and sustainability serve as the foundation of our mission and aspirations. As we prepare our students for a rapidly evolving world, we remain committed to providing quality education that fosters intellectual growth, ethical leadership, innovation, and social responsibility. We believe that true excellence is not measured solely by achievement, but by the positive and lasting impact we create for our communities and future generations. To our students, alumni, and partners,  I invite you to join us in advancing a culture of lifelong learning, meaningful engagement, and sustainable development as we continue to shape leaders and professionals who will make a difference in an increasingly interconnected world.",
  image: {
    url: department?.dean?.image?.asset?.url
      ? getSanityImageUrl(department.dean.image, { width: 800, height: 1000, fit: "crop" })
      : "https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?q=80&w=800&auto=format&fit=crop",
    alt: department?.dean?.image?.alt || "College Dean"
  }
};

const rawFaculty = department?.faculty || [];
const hasValidFaculty = rawFaculty.length > 0;

const facultyMembers: FacultyMember[] = hasValidFaculty
  ? rawFaculty.map((member: any) => ({
      image: {
        url: member?.photo?.asset?.url
          ? getSanityImageUrl(member.photo, { width: 400, height: 400, fit: "crop" })
          : "https://images.unsplash.com/photo-1560250097-0b93528c311a?q=80&w=400&auto=format&fit=crop",
        alt: member?.photo?.alt ?? `Professional headshot of ${member?.name || 'faculty member'}`
      },
      name: member?.name || "Faculty Member",
      position: member?.role || "Instructor",
      department: member?.department || "Department",
      achievements: Array.isArray(member?.qualifications) ? member.qualifications.join(" | ") : (member?.qualifications || "Credentials unavailable"),
      background: member?.bio || "Background information unavailable"
    }))
  : [
      {
        name: "Prof. Alejandro Ramos",
        position: "Department Chair",
        department: "Computing Studies",
        achievements: "MS in Computer Science | CCNP",
        background: "Former Lead Systems Architect at a global enterprise tech firm.",
        image: {
          url: "https://images.unsplash.com/photo-1560250097-0b93528c311a?q=80&w=400&auto=format&fit=crop",
          alt: "Professional headshot of Prof. Alejandro Ramos"
        }
      },
      {
        name: "Dr. Elena Valenzuela",
        position: "Senior Lecturer",
        department: "Business Admin",
        achievements: "Ph.D. in Business | Registered Marketer",
        background: "Former Corporate Strategy Director for multinational FMCG brands.",
        image: {
          url: "https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?q=80&w=400&auto=format&fit=crop",
          alt: "Professional headshot of Dr. Elena Valenzuela"
        }
      },
      {
        name: "Prof. Marcus Santos",
        position: "Industry Practitioner",
        department: "Hospitality",
        achievements: "MBA in Hospitality | Certified Hospitality Professional",
        background: "Former Executive Chef at international five-star resort chains.",
        image: {
          url: "https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?q=80&w=400&auto=format&fit=crop",
          alt: "Professional headshot of Prof. Marcus Santos"
        }
      },
      {
        name: "Dr. Clara Mendoza",
        position: "Clinical Supervisor",
        department: "Psychology",
        achievements: "Psy.D. Clinical Psychology | RPm, RPsy",
        background: "Active clinical practitioner specializing in cognitive behavioral therapy.",
        image: {
          url: "https://images.unsplash.com/photo-1559839734-2b71ea197ec2?q=80&w=400&auto=format&fit=crop",
          alt: "Professional headshot of Dr. Clara Mendoza"
        }
      },
      {
        name: "Prof. David Torres",
        position: "Program Director",
        department: "Tourism",
        achievements: "MS in Tourism Development | IATA Certified",
        background: "Former Aviation Operations Manager for a major international airline.",
        image: {
          url: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?q=80&w=400&auto=format&fit=crop",
          alt: "Professional headshot of Prof. David Torres"
        }
      }
    ];

interface IndustryPartner {
  logoUrl: string;
  companyName: string;
}

const rawPartners = department?.industryPartners || [];
const hasValidPartners = rawPartners.length > 0;

const industryPartners: IndustryPartner[] = hasValidPartners
  ? rawPartners.map((partner: any) => ({
      logoUrl: partner?.logoUrl || partner?.logo?.asset?.url || "https://placehold.co/200x80/e4e4e4/0a095f?text=Partner",
      companyName: partner?.companyName || "Industry Partner",
    }))
  : [
      { companyName: "Tech Innovators Corp", logoUrl: "https://placehold.co/200x80/e4e4e4/0a095f?text=Tech+Innovators" },
      { companyName: "Global Hospitality Group", logoUrl: "https://placehold.co/200x80/e4e4e4/0a095f?text=Global+Hospitality" },
      { companyName: "Metro Banking Union", logoUrl: "https://placehold.co/200x80/e4e4e4/0a095f?text=Metro+Banking" },
      { companyName: "EduTech Solutions", logoUrl: "https://placehold.co/200x80/e4e4e4/0a095f?text=EduTech+Solutions" },
      { companyName: "Apex Travel & Tours", logoUrl: "https://placehold.co/200x80/e4e4e4/0a095f?text=Apex+Travel" },
      { companyName: "Prime Medical Hub", logoUrl: "https://placehold.co/200x80/e4e4e4/0a095f?text=Prime+Medical" },
    ];

interface OutcomeStat {
  value: string;
  label: string;
  context: string;
}

interface AlumniStory {
  name: string;
  degree: string;
  batch: string;
  role: string;
  company: string;
  quote: string;
  imageUrl: string;
}

const rawOutcomeStats = department?.outcomeStats || [];
const hasValidOutcomeStats = rawOutcomeStats.length > 0;
const outcomeStats: OutcomeStat[] = hasValidOutcomeStats
  ? rawOutcomeStats.map((stat: any) => ({
      value: stat?.value || "N/A",
      label: stat?.label || "Stat Label",
      context: stat?.context || "",
    }))
  : [
      { value: "85%", label: "Board Exam Passing Rate", context: "Consistently above the national average." },
      { value: "92%", label: "Employment Rate", context: "Graduates employed within 6 months." },
      { value: "10k+", label: "Global Alumni Network", context: "Professionals across 20+ countries." },
    ];

const rawAlumniStories = department?.alumniStories || [];
const hasValidAlumniStories = rawAlumniStories.length > 0;
const alumniStories: AlumniStory[] = hasValidAlumniStories
  ? rawAlumniStories.map((alumni: any) => ({
      name: alumni?.name || "Alumni Name",
      degree: alumni?.degree || "Degree",
      batch: alumni?.batch || "Batch",
      role: alumni?.role || "Role",
      company: alumni?.company || "Company",
      quote: alumni?.quote || "Quote unavailable.",
      imageUrl: alumni?.image?.asset?.url
        ? getSanityImageUrl(alumni.image, { width: 150, height: 150, fit: "crop" })
        : "https://images.unsplash.com/photo-1560250097-0b93528c311a?q=80&w=150&auto=format&fit=crop",
    }))
  : [
      { name: "Mark Bautista", degree: "BS Computer Science", batch: "Class of 2022", role: "Junior Cloud Engineer", company: "Accenture", quote: "The rigorous OBE framework at OLOPSC meant I wasn't just learning theory—I was deploying real applications. I walked into my technical interview with a complete portfolio.", imageUrl: "https://images.unsplash.com/photo-1560250097-0b93528c311a?q=80&w=150&auto=format&fit=crop" },
      { name: "Sarah Medina, RPm", degree: "BS Psychology", batch: "Class of 2021", role: "Licensed Psychometrician", company: "Medical City", quote: "The clinical professors pushed us beyond our limits. Passing the board exams felt like a natural next step because the standard of excellence was drilled into us from day one.", imageUrl: "https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?q=80&w=150&auto=format&fit=crop" },
      { name: "Leo Fernandez", degree: "BS Hospitality Management", batch: "Class of 2020", role: "Operations Manager", company: "Marriott Hotels", quote: "The international immersion programs and industry-grade laboratories at OLOPSC prepared me for the intense pressure of global hospitality.", imageUrl: "https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?q=80&w=150&auto=format&fit=crop" },
    ];
---

<Layout title={pageTitle} description={pageDescription} ogImage={ogImage}>
  <script type="application/ld+json" slot="head" set:html={`
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [{
      "@type": "Question",
      "name": "What is the College Department of OLOPSC called?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The College Department of Our Lady of Perpetual Succor College (OLOPSC) in Marikina is officially named the College of Business, Management, Science, and Education, or OLOPSC-BMSE. It offers accredited bachelor's degrees in Computer Science, Business Administration, Hospitality, Tourism, Psychology, and Education."
      }
    }, {
      "@type": "Question",
      "name": "Does OLOPSC have a college in Marikina?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, OLOPSC operates a premier higher education institution in Marikina City known as the College of BMSE, providing specialized degree programs for graduating senior high school students."
      }
    }]
  }
  `} />

  <!-- ==================== SECTION 1: The Ivy-SaaS Hero ==================== -->
  <section class="relative bg-primary py-20 lg:py-32 border-b border-slate-800 overflow-hidden">
    <!-- Ambient Glow Layer -->
    <div class="absolute top-0 left-0 w-[500px] h-[500px] bg-primary/20 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2 pointer-events-none z-0"></div>
    <div class="absolute bottom-0 right-0 w-[600px] h-[600px] bg-accent/10 rounded-full blur-3xl translate-x-1/3 translate-y-1/3 pointer-events-none z-0"></div>

    <div class="relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center max-w-7xl mx-auto px-6">

      <!-- Left Column: Typography & Co-Branding -->
      <div>
        <div class="flex items-center gap-4 mb-8">
          <img src={bmseShieldLogo.url} alt={bmseShieldLogo.alt} class="h-16 md:h-20 w-auto drop-shadow-2xl" loading="eager" />
          <div class="flex flex-col">
            <span class="text-accent font-black tracking-widest uppercase text-xs">Our Lady of Perpetual Succor College</span>
            <span class="text-white font-bold tracking-wider uppercase text-sm">College of BMSE</span>
          </div>
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-4xl font-black tracking-tight leading-none mb-6 text-white">College of Business, Management, Science and Education</h1>
        <p class="text-lg md:text-xl text-slate-300 leading-relaxed mb-10">The OLOPSC College of Business, Management, Science, and Education (BMSE) delivers CHED-recognized, outcome-based higher education. We focus on rigorous academic standards and practical mastery, equipping graduates to transition directly into competitive roles within the modern workforce.</p>

        <!-- CTA Group -->
        <div class="flex flex-wrap gap-4">
          <CtaButton cta={{ text: "Contact Admissions", link: { type: "external", external: "/admissions/college-admission" }, style: "primary" }} />
          <CtaButton cta={{ text: "Scholarships", link: { type: "external", external: "/scholarship-programs" }, style: "secondary" }} />
        </div>
      </div>

      <!-- Right Column: Cinematic Visual Frame -->
      <div class="relative rounded-[2rem] overflow-hidden shadow-2xl aspect-[4/3] border border-slate-700/50 group block">
        <img src={heroImage.url} alt={heroImage.alt} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="eager" />
        <div class="absolute inset-0 bg-gradient-to-t from-primary/60 to-transparent"></div>
      </div>

    </div>
  </section>

  <!-- ==================== SECTION 1.5: The OBE Framework ==================== -->
  <section class="bg-white py-24 border-b border-slate-100 overflow-hidden">
    <!-- Header Container -->
    <div class="max-w-3xl mx-auto px-6 text-center mb-16">
      <span class="text-accent font-bold uppercase tracking-wider text-xs mb-3 block">
        Outcome-Based Education
      </span>
      <h2 class="text-3xl md:text-4xl font-black text-primary mb-6 tracking-tight">
        Reverse-Engineered for Industry Success.
      </h2>
      <p class="text-lg text-muted">
        We do not teach to the test; we teach to the industry standard. The College of BMSE's CHED-recognized OBE framework ensures every syllabus, lecture, and laboratory session directly maps to a specific, measurable skill required by modern employers.
      </p>
    </div>

    <!-- The 3-Step Flow Architecture -->
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8 relative">
        <!-- Desktop Connecting Line -->
        <div class="hidden md:block absolute top-8 left-[16.66%] right-[16.66%] h-0.5 bg-slate-200 z-0"></div>

        <!-- Step 1 -->
        <div class="flex flex-col items-center text-center relative z-10 scroll-reveal opacity-0 translate-y-8 transition-all duration-700 ease-out data-[in-view=true]:opacity-100 data-[in-view=true]:translate-y-0">
          <div class="w-16 h-16 rounded-full bg-surface border-2 border-slate-200 flex items-center justify-center text-xl font-black text-primary mb-6">01</div>
          <h3 class="text-xl font-bold text-primary mb-3">Master Core Competencies</h3>
          <p class="text-sm text-muted">Acquire the exact theoretical frameworks and technical skills demanded by global industry standards.</p>
        </div>

        <!-- Step 2 -->
        <div class="flex flex-col items-center text-center relative z-10 scroll-reveal opacity-0 translate-y-8 transition-all duration-700 ease-out data-[in-view=true]:opacity-100 data-[in-view=true]:translate-y-0">
          <div class="w-16 h-16 rounded-full bg-accent flex items-center justify-center text-xl font-black text-primary mb-6 shadow-lg">02</div>
          <h3 class="text-xl font-bold text-primary mb-3">Apply in Real Projects</h3>
          <p class="text-sm text-muted">Translate theory into output through intensive laboratory work, software builds, and corporate simulations.</p>
        </div>

        <!-- Step 3 -->
        <div class="flex flex-col items-center text-center relative z-10 scroll-reveal opacity-0 translate-y-8 transition-all duration-700 ease-out data-[in-view=true]:opacity-100 data-[in-view=true]:translate-y-0">
          <div class="w-16 h-16 rounded-full bg-primary flex items-center justify-center text-xl font-black text-white mb-6">03</div>
          <h3 class="text-xl font-bold text-primary mb-3">Graduate Industry-Ready</h3>
          <p class="text-sm text-muted">Enter the workforce with a verified portfolio of skills, zero retraining required by your future employer.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== SECTION 2: The Degree Matrix ==================== -->
  <section id="degree-matrix" class="bg-white py-24">
    <!-- Header -->
    <div class="max-w-4xl mx-auto px-6 text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-black text-primary mb-6 tracking-tight">The Academic Institutes of the College of BMSE</h2>
      <p class="text-lg text-muted max-w-2xl mx-auto">Six specialized institutes encompassing Business, Management, Science, and Education. One standard of global excellence.</p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-7xl mx-auto px-6">
      {degreeMatrix.map((card) => (
        <a
          href={card.href}
          class="bg-surface rounded-2xl border border-slate-100 hover:shadow-xl hover:-translate-y-2 transition-all duration-300 flex flex-col h-full cursor-pointer group no-underline overflow-hidden"
        >
          {card.image && (
            <div class="aspect-[16/9] w-full overflow-hidden border-b border-slate-100 shrink-0">
              <img
                src={card.image}
                alt={card.alt}
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
              />
            </div>
          )}
          <div class="p-8 flex flex-col flex-1">
            <h3 class="text-2xl font-black text-primary mb-4 group-hover:text-accent transition-colors">
              {card.department}
            </h3>
            <div class="flex flex-wrap gap-2 mb-6">
              {card.tags.map((tag) => (
                <span class="bg-white border border-slate-200 text-xs font-bold px-3 py-1.5 rounded-full text-slate-600">
                  {tag}
                </span>
              ))}
            </div>
            <p class="text-muted text-sm leading-relaxed mt-auto border-t border-slate-200 pt-6">
              {card.text}
            </p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ==================== SECTION 2.5: The 4-Year Professional Roadmap ==================== -->
  <section class="bg-surface py-28 border-b border-slate-200 overflow-hidden relative">
    <div class="max-w-3xl mx-auto px-6 text-center mb-24">
      <span class="text-accent font-bold uppercase tracking-wider text-xs mb-3 block">
        The Academic Life Cycle
      </span>
      <h2 class="text-3xl md:text-5xl font-black text-primary mb-6 tracking-tight">
        Your Path from Learner to Professional
      </h2>
      <p class="text-lg text-muted">
          A degree at the College of BMSE is a structured transformation. Regardless of your specific program's duration, we break down your academic commitment into four core developmental phases engineered to progressively build your competence and market value.
    </div>

    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-4 gap-12 md:gap-8 relative">
