---
import Layout from "../layouts/Layout.astro";
import CtaButton from "../components/common/CtaButton.astro";
import { getAcademicDepartmentByType } from "../lib/sanity/queries";
import { getSanityImageUrl } from "../lib/utils/sanity";
import "../styles/global.css";

// Fetch CMS data
const department = await getAcademicDepartmentByType("gradeSchool");

// --- Image Object Mapping ---
interface SanityImage {
  url: string;
  alt: string;
}

const heroImage: SanityImage = {
  url: department?.hero?.backgroundImage?.asset?.url
    ? getSanityImageUrl(department.hero.backgroundImage, { width: 1200, height: 900, fit: "crop" })
    : "https://images.unsplash.com/photo-1503676260728-1c00da094a0b?q=80&w=1200&auto=format&fit=crop",
  alt: department?.hero?.backgroundImage?.alt
    ?? "OLOPSC Grade School students engaging in active learning",
};

// --- Stepping Stones: Use dedicated academicProgression images ---
const lowerPrimaryImage: SanityImage = {
  url: department?.academicProgression?.[0]?.image?.asset?.url
    ? getSanityImageUrl(department.academicProgression[0].image, { width: 1200, height: 675, fit: "crop" })
    : "https://images.unsplash.com/photo-1497633762265-9d179a990aa6?q=80&w=1200&auto=format&fit=crop",
  alt: department?.academicProgression?.[0]?.image?.alt
    ?? "Grades 1 to 3 foundational literacy and numeracy activities",
};

const upperPrimaryImage: SanityImage = {
  url: department?.academicProgression?.[1]?.image?.asset?.url
    ? getSanityImageUrl(department.academicProgression[1].image, { width: 1200, height: 675, fit: "crop" })
    : "https://images.unsplash.com/photo-1427504494785-3a9ca7044f45?q=80&w=1200&auto=format&fit=crop",
  alt: department?.academicProgression?.[1]?.image?.alt
    ?? "Grades 4 to 6 advanced science and collaborative projects",
};

// --- Extracurriculars: Use dedicated extracurricular image ---
const extracurricularImage: SanityImage = {
  url: department?.extracurricular?.image?.asset?.url
    ? getSanityImageUrl(department.extracurricular.image, { width: 1400, height: 788, fit: "crop" })
    : "https://images.unsplash.com/photo-1529390079861-591de354faf5?q=80&w=1400&auto=format&fit=crop",
  alt: department?.extracurricular?.image?.alt
    ?? "Grade School students participating in holistic extracurricular activities",
};

// --- Facilities Tour: Use facilityTourImages[0],[1],[2] ---
const gsClassroomImage: SanityImage = {
  url: department?.facilityTourImages?.[0]?.asset?.url
    ? getSanityImageUrl(department.facilityTourImages[0], { width: 1200, height: 900, fit: "crop" })
    : "https://images.unsplash.com/photo-1509062522246-3755977927d7?q=80&w=1200&auto=format&fit=crop",
  alt: department?.facilityTourImages?.[0]?.alt
    ?? "Modern tech-integrated OLOPSC Grade School classroom",
};

const gsLabImage: SanityImage = {
  url: department?.facilityTourImages?.[1]?.asset?.url
    ? getSanityImageUrl(department.facilityTourImages[1], { width: 1200, height: 900, fit: "crop" })
    : "https://images.unsplash.com/photo-1532094349884-543bc11b234d?q=80&w=1200&auto=format&fit=crop",
  alt: department?.facilityTourImages?.[1]?.alt
    ?? "OLOPSC Grade School computer and science discovery laboratory",
};

const gsPlayCourtImage: SanityImage = {
  url: department?.facilityTourImages?.[2]?.asset?.url
    ? getSanityImageUrl(department.facilityTourImages[2], { width: 1200, height: 900, fit: "crop" })
    : "https://images.unsplash.com/photo-1542652735873-fb2825bac6e2?q=80&w=1200&auto=format&fit=crop",
  alt: department?.facilityTourImages?.[2]?.alt
    ?? "OLOPSC campus sports court and primary play areas",
};

// SEO metadata
const pageTitle = department?.seo?.title ?? "Grade School (Grades 1-6) | OLOPSC Marikina";
const pageDescription = department?.seo?.description ?? "DepEd-accredited primary education building foundational literacy, STEM competence, and Catholic character formation at OLOPSC Marikina.";
const ogImage = department?.seo?.image?.asset?.url;
---

<Layout title={pageTitle} description={pageDescription} ogImage={ogImage}>

  <!-- ==================== SECTION 1: The Academic Foundation Hero ==================== -->
  <section class="relative bg-surface py-20 lg:py-32 border-b border-slate-200 overflow-hidden">
    <!-- Ambient Glow Layer -->
    <div class="absolute top-0 left-0 w-[500px] h-[500px] bg-primary/5 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2 pointer-events-none z-0"></div>
    <div class="absolute bottom-0 right-0 w-[600px] h-[600px] bg-accent/10 rounded-full blur-3xl translate-x-1/3 translate-y-1/3 pointer-events-none z-0"></div>

    <div class="relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center max-w-7xl mx-auto px-6">

      <!-- Left Column: Text Payload -->
      <div>
        <span class="text-accent font-bold tracking-widest uppercase text-sm mb-4 block">
          Primary Education (Grades 1-6)
        </span>
        <h1 class="text-4xl md:text-6xl font-black text-primary tracking-tight leading-tight mb-6">
          {department?.hero?.headline || "Building the Foundations of Academic Excellence."}
        </h1>
        <p class="text-lg text-muted leading-relaxed mb-8">
          {department?.hero?.subheadline || "The formative years dictate a lifelong love for learning. Our DepEd-accredited Grade School curriculum meticulously bridges the gap between early childhood discovery and rigorous academic competence, deeply rooted in Catholic values."}
        </p>
        <CtaButton cta={{ text: "View Enrollment Requirements", link: { type: "external", external: "/admissions/basic-education-admission" }, style: "primary" }} />
      </div>

      <!-- Right Column: Visual Frame -->
      <div class="rounded-2xl overflow-hidden shadow-2xl aspect-square md:aspect-[4/3] border-4 border-white">
        <img
          src={heroImage.url}
          alt={heroImage.alt}
          width="1200"
          height="900"
          loading="eager"
          decoding="async"
          class="w-full h-full object-cover"
        />
      </div>
    </div>
  </section>

  <!-- ==================== SECTION 2: The Core Pillars ==================== -->
  <section class="bg-primary py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-3xl md:text-5xl font-black text-white mb-6 tracking-tight">
          {department?.curriculum?.title || "A Balanced, Rigorous Curriculum"}
        </h2>
        <p class="text-lg text-white/90 leading-relaxed">
          {department?.curriculum?.description || "Our Grade School curriculum goes beyond national standards by providing a strong foundation in core subjects while supporting learners' physical, creative, and personal growth."}
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {department?.keyFeatures && department.keyFeatures.length > 0 ? (
          department.keyFeatures.map((feature: any) => (
            <div class="bg-surface p-10 rounded-2xl border-t-4 border-accent hover:-translate-y-2 transition-transform duration-300 shadow-sm">
              <h3 class="text-xl font-bold text-white mb-4">
                {feature.title}
              </h3>
              <p class="text-white/90 leading-relaxed">
                {feature.description}
              </p>
            </div>
          ))
        ) : (
          <>
            <!-- Pillar 1 -->
            <div class="bg-surface p-10 rounded-2xl border-t-4 border-accent hover:-translate-y-2 transition-transform duration-300 shadow-sm">
              <h3 class="text-xl font-bold text-white mb-4">
                Enhanced Mathematics and Science Programs
              </h3>
              <p class="text-white/90 leading-relaxed">
                Building strong analytical skills and critical thinking through structured math instruction and hands-on scientific exploration.
              </p>
            </div>

            <!-- Pillar 2 -->
            <div class="bg-surface p-10 rounded-2xl border-t-4 border-accent hover:-translate-y-2 transition-transform duration-300 shadow-sm">
              <h3 class="text-xl font-bold text-white mb-4">
                Enriched Reading and Language Development Program
              </h3>
              <p class="text-white/90 leading-relaxed">
                Fostering confident communication, reading comprehension, and articulate expression to ensure success across all academic subjects.
              </p>
            </div>

            <!-- Pillar 3 -->
            <div class="bg-surface p-10 rounded-2xl border-t-4 border-accent hover:-translate-y-2 transition-transform duration-300 shadow-sm">
              <h3 class="text-xl font-bold text-white mb-4">
                Integrated Information and Communication Technology (ICT)
              </h3>
              <p class="text-white/90 leading-relaxed">
                Equipping students with foundational digital literacy and practical tech skills to confidently navigate a modern, connected world.
              </p>
            </div>

            <!-- Pillar 4 -->
            <div class="bg-surface p-10 rounded-2xl border-t-4 border-accent hover:-translate-y-2 transition-transform duration-300 shadow-sm">
              <h3 class="text-xl font-bold text-white mb-4">
                Dynamic Extracurricular and Talent Development Programs
              </h3>
              <p class="text-white/90 leading-relaxed">
                Encouraging students to discover their passions and develop personal strengths through diverse opportunities in sports, arts, and clubs.
              </p>
            </div>
          </>
        )}
      </div>
    </div>
  </section>

  <!-- ==================== NEW SECTION: General Objective ==================== -->
  <section class="py-24 bg-white relative border-b border-slate-100">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center max-w-4xl mx-auto mb-16">
        <h2 class="text-3xl md:text-5xl font-black text-primary mb-6 tracking-tight">
          General Objective
        </h2>
        <p class="text-lg text-slate-600 leading-relaxed mb-12">
          {department?.learningObjectives?.generalObjective || "The Grade School aims to empower learners by building on the foundational knowledge and skills acquired in Preschool, fostering their holistic development, and preparing them for Junior High School and lifelong success."}
        </p>

        <h3 class="text-2xl md:text-3xl font-black text-primary mb-4 tracking-tight">
          Specific Objectives
        </h3>
        <p class="text-lg text-slate-600 font-medium">
          For the learners to:
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {department?.learningObjectives?.specificObjectives && department.learningObjectives.specificObjectives.length > 0 ? (
          department.learningObjectives.specificObjectives.map((obj: string, i: number) => (
            <div class="flex items-start gap-4 p-6 rounded-2xl bg-slate-50 hover:bg-white hover:shadow-md transition-all duration-300 border border-transparent hover:border-slate-200">
              <div class="flex-shrink-0 w-8 h-8 rounded-full bg-accent text-primary font-bold flex items-center justify-center text-sm shadow-sm mt-0.5">{i + 1}</div>
              <p class="text-slate-700 leading-relaxed">
                {obj}
              </p>
            </div>
          ))
        ) : (
          <>
            <!-- Objective 1 -->
            <div class="flex items-start gap-4 p-6 rounded-2xl bg-slate-50 hover:bg-white hover:shadow-md transition-all duration-300 border border-transparent hover:border-slate-200">
              <div class="flex-shrink-0 w-8 h-8 rounded-full bg-accent text-primary font-bold flex items-center justify-center text-sm shadow-sm mt-0.5">1</div>
              <p class="text-slate-700 leading-relaxed">
                demonstrate effective communication skills through listening, reading, speaking, writing, viewing and visual representation;
              </p>
            </div>
            
            <!-- Objective 2 -->
            <div class="flex items-start gap-4 p-6 rounded-2xl bg-slate-50 hover:bg-white hover:shadow-md transition-all duration-300 border border-transparent hover:border-slate-200">
              <div class="flex-shrink-0 w-8 h-8 rounded-full bg-accent text-primary font-bold flex items-center justify-center text-sm shadow-sm mt-0.5">2</div>
              <p class="text-slate-700 leading-relaxed">
                apply computational, analytical, critical thinking and problem-solving skills effectively;
              </p>
            </div>

            <!-- Objective 3 -->
            <div class="flex items-start gap-4 p-6 rounded-2xl bg-slate-50 hover:bg-white hover:shadow-md transition-all duration-300 border border-transparent hover:border-slate-200">
              <div class="flex-shrink-0 w-8 h-8 rounded-full bg-accent text-primary font-bold flex items-center justify-center text-sm shadow-sm mt-0.5">3</div>
              <p class="text-slate-700 leading-relaxed">
                demonstrate and apply functional understanding of science concepts, principles, skills and processes;
              </p>
            </div>

            <!-- Objective 4 -->
            <div class="flex items-start gap-4 p-6 rounded-2xl bg-slate-50 hover:bg-white hover:shadow-md transition-all duration-300 border border-transparent hover:border-slate-200">
              <div class="flex-shrink-0 w-8 h-8 rounded-full bg-accent text-primary font-bold flex items-center justify-center text-sm shadow-sm mt-0.5">4</div>
              <p class="text-slate-700 leading-relaxed">
                engage actively in and promote sustainable practices and environmental stewardship;
              </p>
            </div>

            <!-- Objective 5 -->
            <div class="flex items-start gap-4 p-6 rounded-2xl bg-slate-50 hover:bg-white hover:shadow-md transition-all duration-300 border border-transparent hover:border-slate-200">
              <div class="flex-shrink-0 w-8 h-8 rounded-full bg-accent text-primary font-bold flex items-center justify-center text-sm shadow-sm mt-0.5">5</div>
              <p class="text-slate-700 leading-relaxed">
                develop deep understanding and appreciation of Philippine history, culture and heritage;
              </p>
            </div>

            <!-- Objective 6 -->
            <div class="flex items-start gap-4 p-6 rounded-2xl bg-slate-50 hover:bg-white hover:shadow-md transition-all duration-300 border border-transparent hover:border-slate-200">
              <div class="flex-shrink-0 w-8 h-8 rounded-full bg-accent text-primary font-bold flex items-center justify-center text-sm shadow-sm mt-0.5">6</div>
              <p class="text-slate-700 leading-relaxed">
                cultivate critical thinking, creativity and accountability through self-awareness and community engagement;
              </p>
            </div>

            <!-- Objective 7 -->
            <div class="flex items-start gap-4 p-6 rounded-2xl bg-slate-50 hover:bg-white hover:shadow-md transition-all duration-300 border border-transparent hover:border-slate-200">
              <div class="flex-shrink-0 w-8 h-8 rounded-full bg-accent text-primary font-bold flex items-center justify-center text-sm shadow-sm mt-0.5">7</div>
              <p class="text-slate-700 leading-relaxed">
                explore and engage in different hands-on activities to develop basic work skills, desirable work habits and positive attitudes;
              </p>
            </div>

            <!-- Objective 8 -->
            <div class="flex items-start gap-4 p-6 rounded-2xl bg-slate-50 hover:bg-white hover:shadow-md transition-all duration-300 border border-transparent hover:border-slate-200">
              <div class="flex-shrink-0 w-8 h-8 rounded-full bg-accent text-primary font-bold flex items-center justify-center text-sm shadow-sm mt-0.5">8</div>
              <p class="text-slate-700 leading-relaxed">
                enhance socio-physical, mental, emotional well-being and creative abilities;
              </p>
            </div>

            <!-- Objective 9 -->
            <div class="flex items-start gap-4 p-6 rounded-2xl bg-slate-50 hover:bg-white hover:shadow-md transition-all duration-300 border border-transparent hover:border-slate-200">
              <div class="flex-shrink-0 w-8 h-8 rounded-full bg-accent text-primary font-bold flex items-center justify-center text-sm shadow-sm mt-0.5">9</div>
              <p class="text-slate-700 leading-relaxed">
                strengthen spiritual, moral and socio-ecological values; and
              </p>
            </div>

            <!-- Objective 10 -->
            <div class="flex items-start gap-4 p-6 rounded-2xl bg-slate-50 hover:bg-white hover:shadow-md transition-all duration-300 border border-transparent hover:border-slate-200">
              <div class="flex-shrink-0 w-8 h-8 rounded-full bg-accent text-primary font-bold flex items-center justify-center text-sm shadow-sm mt-0.5">10</div>
              <p class="text-slate-700 leading-relaxed">
                adapt and apply new technologies and digital literacy in learning.
              </p>
            </div>
          </>
        )}
      </div>
    </div>
  </section>

  <!-- ==================== NEW SECTION: The Facilities Tour ==================== -->
  <section class="bg-surface py-24 border-t border-slate-200">
    <!-- Header -->
    <div class="container mx-auto px-6 max-w-5xl text-center mb-20">
      <h2 class="text-3xl md:text-5xl font-black text-primary mb-6 tracking-tight">
        {department?.facilitiesHeader?.title || "Spaces Engineered for Active Learning"}
      </h2>
      <p class="text-lg text-muted max-w-2xl mx-auto">
        {department?.facilitiesHeader?.description || "Our primary campus infrastructure provides the advanced tools, scientific laboratories, and recreational spaces necessary to support a modern academic curriculum."}
      </p>
    </div>

    <!-- Rows Container -->
    <div class="container mx-auto px-6 max-w-6xl flex flex-col gap-24">

      <!-- Row 1: Tech-Integrated Classrooms (Image Left, Text Right) -->
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">
        <div class="w-full lg:w-1/2 aspect-[4/3] rounded-2xl overflow-hidden shadow-xl shrink-0 border-4 border-white">
          <img
            src={gsClassroomImage.url}
            alt={gsClassroomImage.alt}
            width="1200"
            height="900"
            loading="lazy"
            decoding="async"
            class="w-full h-full object-cover"
          />
        </div>
        <div class="w-full lg:w-1/2 flex flex-col justify-center">
          <h3 class="text-3xl font-bold text-primary mb-4 leading-tight">
            {department?.facilityTourImages?.[0]?.caption || "Modern & Comfortable Classrooms"}
          </h3>
          <p class="text-lg text-muted leading-relaxed">
            {department?.facilityTourImages?.[0]?.description || "Our grade school classrooms are fully air-conditioned, well-lit, and designed for a comfortable learning environment. They are equipped with TVs and multimedia tools to keep students engaged during lessons."}
          </p>
        </div>
      </div>

      <!-- Row 2: Science & Computing Labs (Text Left, Image Right) -->
      <div class="flex flex-col lg:flex-row-reverse items-center gap-12 lg:gap-16">
        <div class="w-full lg:w-1/2 aspect-[4/3] rounded-2xl overflow-hidden shadow-xl shrink-0 border-4 border-white">
          <img
            src={gsLabImage.url}
            alt={gsLabImage.alt}
            width="1200"
            height="900"
            loading="lazy"
            decoding="async"
            class="w-full h-full object-cover"
          />
        </div>
        <div class="w-full lg:w-1/2 flex flex-col justify-center">
          <h3 class="text-3xl font-bold text-primary mb-4 leading-tight">
            {department?.facilityTourImages?.[1]?.caption || "Computer Laboratories"}
          </h3>
          <p class="text-lg text-muted leading-relaxed">
            {department?.facilityTourImages?.[1]?.description || "Students learn basic computer skills and digital literacy early on. Our computer labs have a 1-to-1 computer-to-student ratio, ensuring that every child gets hands-on experience in a safe and guided setting."}
          </p>
        </div>
      </div>

      <!-- Row 3: Sports & Recreation (Image Left, Text Right) -->
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">
        <div class="w-full lg:w-1/2 aspect-[4/3] rounded-2xl overflow-hidden shadow-xl shrink-0 border-4 border-white">
          <img
            src={gsPlayCourtImage.url}
            alt={gsPlayCourtImage.alt}
            width="1200"
            height="900"
            loading="lazy"
            decoding="async"
            class="w-full h-full object-cover"
          />
        </div>
        <div class="w-full lg:w-1/2 flex flex-col justify-center">
          <h3 class="text-3xl font-bold text-primary mb-4 leading-tight">
            {department?.facilityTourImages?.[2]?.caption || "Interactive Science Labs"}
          </h3>
          <p class="text-lg text-muted leading-relaxed">
            {department?.facilityTourImages?.[2]?.description || "We make science fun and easy to understand. Our science laboratories are filled with interactive educational models, like human skeletons and anatomy figures, allowing students to explore biology and life sciences hands-on."}
          </p>
        </div>
      </div>

    </div>
  </section>

  <!-- ==================== SECTION 3: The Stepping Stones (Progression) ==================== -->
  <section class="bg-primary text-white py-24">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-3xl md:text-4xl font-black mb-16 text-center tracking-tight">
        The Academic Progression
      </h2>

      {(() => {
        const defaultProgression = [
          {
            title: "Lower Primary (Grades 1-3)",
            subtitle: "Mastering the Basics",
            description: "The crucial transition phase. We focus heavily on ensuring every student achieves reading fluency, basic mathematical automation, and classroom independence. Teachers provide heavy guidance to build unshakeable confidence in their ability to learn.",
          },
          {
            title: "Upper Primary (Grades 4-6)",
            subtitle: "Preparing for High School",
            description: "A shift towards critical thinking and collaborative output. Students engage in complex science projects, advanced reading analysis, and independent study habits. We increase academic rigor to ensure they are fully equipped for the demands of Junior High School.",
          },
        ];

        const items = department?.academicProgression && department.academicProgression.length > 0
          ? department.academicProgression
          : defaultProgression;

        return items.map((progression: any, index: number) => {
          const defaults = defaultProgression[index] || defaultProgression[0];
          const imgFallback = index === 0 ? lowerPrimaryImage : upperPrimaryImage;

          return (
            <div class={`grid grid-cols-1 lg:grid-cols-2 gap-12 items-center ${index !== items.length - 1 ? 'mb-20' : ''}`}>
              <div class={`aspect-video rounded-2xl overflow-hidden shadow-lg ${index % 2 !== 0 ? 'order-2 lg:order-1' : ''}`}>
                <img
                  src={progression?.image?.asset?.url
                    ? getSanityImageUrl(progression.image, { width: 1200, height: 675, fit: "crop" })
                    : imgFallback.url}
                  alt={progression?.image?.alt || defaults.title}
                  width="1200"
                  height="675"
                  loading="lazy"
                  decoding="async"
                  class="w-full h-full object-cover"
                />
              </div>
              <div class={index % 2 !== 0 ? 'order-1 lg:order-2' : ''}>
                <span class="text-accent font-bold uppercase tracking-wider mb-2 block">
                  {progression.subtitle || defaults.subtitle}
                </span>
                <h3 class="text-3xl font-bold mb-4">
                  {progression.title || defaults.title}
                </h3>
                <p class="text-slate-300 text-lg leading-relaxed">
                  {progression.description || defaults.description}
                </p>
              </div>
            </div>
          );
        });
      })()}

    </div>
  </section>

  <!-- ==================== SECTION 4: Holistic Growth & Extracurriculars ==================== -->
  <section class="bg-white py-24">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 max-w-7xl mx-auto px-6 items-center">

      <!-- Text Block -->
      <div class="lg:col-span-5">
        <h2 class="text-3xl md:text-4xl font-black text-primary mb-6 tracking-tight">
          {department?.extracurricular?.title || "Beyond the Classroom"}
        </h2>
        <p class="text-lg text-muted leading-relaxed">
          {department?.extracurricular?.description || "Academic excellence is only half the equation. Our Grade School department offers vibrant Scouting programs, academic varsity clubs, and performing arts groups. We actively encourage students to discover their passions, build leadership skills, and practice teamwork in a safe, guided environment."}
        </p>
      </div>

      <!-- Visual Block -->
      <div class="lg:col-span-7">
        <div class="relative rounded-3xl overflow-hidden shadow-xl aspect-video group block">
          <img
            src={extracurricularImage.url}
            alt={extracurricularImage.alt}
            width="1400"
            height="788"
            loading="lazy"
            decoding="async"
            class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
          />
        </div>
      </div>

    </div>
  </section>

  <!-- ==================== SECTION 5: Final CTA ==================== -->
  <section class="bg-primary py-24">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-black text-white mb-6 tracking-tight">
        {department?.admissionInfo?.title || "Set Them on the Right Path"}
      </h2>
      <p class="text-lg text-slate-300 leading-relaxed max-w-2xl mx-auto mb-10">
        {department?.admissionInfo?.content || "Enroll your child in a Grade School program that values academic rigor, character formation, and holistic development. Visit our Marikina campus and experience the OLOPSC difference."}
      </p>
      <CtaButton cta={{ text: "Start the Application", link: "/admissions", style: "primary" }} />
    </div>
  </section>

</Layout>
